<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-٢٧٧"
     درنبورج="٢-٣٠٢"
     البكاء="٥-٤٧٦"
     هارون="٤-١٥٩"
     يعقوب="٤-٢٧٣"
     رقم="٤٩٠">

  <عنوان>
    <مقطع هوية='٣٣٠٠٩'>هٰذَا بَاْبُ مَا تَلْحَقُهُ الْهَاْءُ فِي الْوَقْفِ لِتَحَرُّكِ آخِرِ الْحَرْفِ</مقطع>
  </عنوان>

  <مقطع هوية='٧٩٩٥٠'>وَذٰلِكَ قَوْلُكَ فِي بَنَاْتِ الْيَاْءِ وَالْوَاْوِ</مقطع>
  <مقطع هوية='٣٥١١٨'>الَّتِي الْيَاْءُ وَالْوَاْوُ فِيْهِنَّ لَاْمٌ</مقطع>
  <مقطع هوية='٤١٧٦٢'>فِي حَاْلِ الْجَزْمِ <حرف>ارْمِهْ</حرف> وَ<حرف>لَمْ يَغْزُهْ</حرف>
  وَ<حرف>اخْشَهْ</حرف> وَ<حرف>لَمْ يَقْضِهْ</حرف> وَ<حرف>لَمْ يَرْضَهْ</حرف></مقطع>
  <مقطع هوية='٤٥٩٥٧'>وَذٰلِكَ لِأَنَّهُمْ كَرِهُوْا إِذْهَاْبَ اللَّاْمَاْتِ وَالْإِسْكَاْنَ جَمِيْعًا</مقطع>
  <مقطع هوية='٩٥٥٣٨'>فَلَمَّا كَاْنَ ذٰلِكَ إِخْلَاْلًا بِالْحَرْفِ</مقطع>
  <مقطع هوية='٩٩٧٩٢'>كَرِهُوْا أَنْ يُسَكِّنُوْا الْمُتَحَرِّكَ</مقطع>
  <مقطع هوية='٢٨١٢٣'>فَهٰذَا تِبْيَاْنٌ أَنَّهُ قَدْ حَذَفَ آخِرَ هَذِهِ الْحُرُوْفِ</مقطع>

  <رأس/>
  <مقطع هوية='٠٨٤٩١'>وكَذٰلِكَ كُلُّ فِعْلٍ كَاْنَ آخِرُهُ يَاْءً أَوْ وَاوًا</مقطع>
  <مقطع هوية='٢٥٤٦٣'>وَإِنْ كَاْنَتْ الْيَاْءُ زَاْئِدَةً</مقطع>
  <مقطع هوية='٩٧٢٥١'>لِأَنَّهَا تَجْرِي مَجْرَى مَا هُوَ مِنْ نَفْسِ الْحَرْفِ</مقطع>
  <مقطع هوية='١٢٩٨٠'>فَإِذَا كَاْنَ بَعْدَ ذٰلِكَ كَلَاْمٌ تَرَكْتَ الْهَاْءَ</مقطع>
  <مقطع هوية='٣٧٠٥١'>لِأَنَّكَ إِذَا لَمْ تَقِفْ تَحَرَّكَتْ</مقطع>
  <مقطع هوية='٣٦٠٧٠'>وَإِنَّمَا كَاْنَ السُّكُوْنُ لِلْوَقْفِ</مقطع>
  <مقطع هوية='٠٤٧٣٤'>فَإِذَا لَمْ تَقِفْ اسْتَغْنَيْتَ عَنْهَا وَتَرْكْتَهَا</مقطع>

  <رأس/>
  <مقطع هوية='٥٢٥٤٧'>وَقَدْ يَقُوْلُ بَعْضُ الْعَرَبِ <حرف>ارْمْ</حرف> فِي الْوَقْفِ</مقطع>
  <مقطع هوية='١٨٤٤٧'>وَ<حرف>اغْزْ</حرف> وَ<حرف>اخْشْ</حرف></مقطع>
  <مقطع هوية='٠٨٥٥٨'>حَدَّثْنَا بِذٰلِكَ <سند>عِيْسَى بْنُ عَمُرَ</سند> وَ<سند>يُوْنُسُ</سند></مقطع>
  <مقطع هوية='٨٨٦٢٤'>وَهَذِهِ اللُّغَةُ أَقَلُّ اللُّغَتَيْنِ</مقطع>
  <مقطع هوية='٥٥٥٦٠'>جَعَلُوْا آخِرَ الْكَلِمَةِ حَيْثُ وَصَلُوْا إِلَى التَّكَلُّمِ بِهَا</مقطع>
  <مقطع هوية='٩٩١٨٤'>بِمَنْزِلَةِ الْأَوَاْخِرِ الَّتِي تُحَرَّكَ مِمَّا لَمْ يُحْذَفْ مِنْهُ شَيْءٌ</مقطع>
  <مقطع هوية='٨٨٧٤٧'>لِأَنَّ مِنْ كَلَاْمِهِمْ أَنْ يُشَبِّهُوْا الشَّيْءَ بِالشَّيْءِ</مقطع>
  <مقطع هوية='٦٣١٦٠'>وَإِنْ لَمْ يَكُنْ مِثْلَهُ فِي جَمِيْعِ مَا هُوَ فِيْهِ</مقطع>

  <رأس/>
  <مقطع هوية='٢٧٥٦٦'>وأَمَّا <قول هوية='٦٦٣٩٨'>لَا تَقِهْ</قول> مِنْ <حرف>وَقَيْتُ</حرف></مقطع>
  <مقطع هوية='٥٧٧٣١'>وَ<قول هوية='٥٣٠٥٨'>إِنْ تَعِ أَعِهْ</قول> مِنْ <حرف>وَعَيْتُ</حرف></مقطع>
  <مقطع هوية='٥١٥٥١'>فَإِنَّهُ يُلْزِمُهَا الْهَاْءَ فِي الْوَقْفِ مَنْ تَرَكَهَا فِي <حرف>اخْشْ</حرف></مقطع>
  <مقطع هوية='٩٦٢٦٧'>لِأَنَّهُ مُجْحِفٌ بِهَا لِأَنَّهَا ذَهَبَتْ مِنْهَا الْفَاْءُ وَاللَّاْمُ</مقطع>
  <مقطع هوية='٦٠٣٠٥'>فَكَرِهُوْا أَنْ يُسَكِّنُوْا فِي الْوَقْفِ فَيَقُوْلُوْا <قول ج="*" هوية='٨٨٥٠٤'>إِنْ تَعِ أَعْ</قول></مقطع>
  <مقطع هوية='٢٥٣١٦'>فَيُسَكِّنُوْا الْعَيْنَ مَعَ ذَهَاْبِ حَرْفَيْنِ مِنْ نَفْسِ الْحَرْفِ</مقطع>
  <مقطع هوية='٢٦٥٤٥'>وَإِنَّمَا ذَهَبَ مِنْ نَفْسِ الْحَرْفِ الْأَوَّلِ حَرْفٌ وَاْحِدٌ</مقطع>
  <مقطع هوية='٤٤٢٧٠'>وَفِيْهِ أَلْفُ الْوَصْلِ</مقطع>
  <مقطع هوية='٨٥٣٥٤'>فَهُوَ عَلَى ثَلَاْثَةِ أَحْرُفٍ</مقطع>
  <مقطع هوية='٤٤٧٣٩'>وَهٰذَا عَلَى حَرْفَيْنِ</مقطع>
  <مقطع هوية='٤٠٥٢٨'>وَقَدْ ذَهَبَ مِنْ نَفْسِهِ حَرْفَاْنِ</مقطع>
  <مقطع هوية='١٥٠٨٥'>وَزَعَمَ <سند>أَبُو الْخَطَّاْبِ</سند> أَنَّ نَاْسًا مِنَ الْعَرَبِ</مقطع>
  <مقطع هوية='٩٩٣٥١'>يَقُوْلُوْنَ <حرف>ادْعِهْ</حرف> مِنْ <حرف>دَعَوْتُ</حرف>
  فَيَكْسِرُوْنَ الْعَيْنَ</مقطع>
  <مقطع هوية='٥٩٦٦٠'>كَأَنّهَا لَمَّا كَاْنَتْ فِي مَوْضِعِ الْجَزْمِ تَوَهّمُوْا أَنَّهَا سَاْكِنَةٌ</مقطع>
  <مقطع هوية='٩٣٣٤٤'>إِذْ كَاْنَتْ آخِرَ شَيْءٍ فِي الْكَلِمَةِ فِي مَوْضِعِ الْجَزْمِ</مقطع>
  <مقطع هوية='٢٢٩٧٢'>فَكَسَرُوْا حَيْثُ كَاْنَتْ الدّاْلُ سَاْكِنَةً</مقطع>
  <مقطع هوية='٣٢٠٢٤'>لِأَنَّهُ لَا يَلْتَقِي سَاْكِنَاْنِ</مقطع>
  <مقطع هوية='٢١٥٧١'>كَمَا قَاْلُوْا <قول هوية='٤١٤٣٢'>رُدِّ يَا فَتَى</قول></مقطع>
  <مقطع هوية='٧٨٧٨٤'>وَهَذِهِ لُغَةٌ رَدِيْئَةٌ وَإِنَّمَا هُوَ غَلَطٌ</مقطع>
  <مقطع هوية='١٨٠٧٩'>كَمَا قَاْلَ <شاعر>زُهَيْرٌ</شاعر></مقطع>
  <شاهدة هوية='٧٣٠٨٩' شاعر="زُهَيْرٌ">
    <بيت>
      <مصراع>بَدَا لِي أَنِّي لَسْتُ مُدْرِكَ مَا مَضَى</مصراع>
      <مصراع>وَلَا <ثبات>سَاْبِقٍ</ثبات> شَيْئًا إِذَا كَاْنَ جَاْئِيَا</مصراع>
    </بيت>
  </شاهدة>

