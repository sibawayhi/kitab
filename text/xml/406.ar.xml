<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-١٥٧"
     درنبورج="٢-١٦١"
     البكاء="٥-٢٣٢"
     هارون="٣-٥٢٨"
     يعقوب="٤-١١"
     رقم="٤٠٦">

  <عنوان>
    <مقطع هوية='٢٣٩٧٠'>هٰذَا بَاْبُ ثَبَاْتِ الْخَفِيْفَةِ وَالثَّقَيْلَةِ
    فِي بَنَاْتِ الْيَاْءِ وَالْوَاْوِ</مقطع>
    <مقطع هوية='٢٦١٣٦'>الَّتِي الْوَاْوَاْتُ وَالْيَاْءَاْتُ لَاْمَاْتُهُنَّ</مقطع>
  </عنوان>

  <رأس/>
  <مقطع هوية='٩٠٧٤٦'>اعْلَمْ أَنَّ الْيَاْءَ الَّتِي هِيَ لَاْمٌ</مقطع>
  <مقطع هوية='٥٣٨٩٤'>وَالْوَاْوُ الَّتِي هِيَ بِمَنْزِلَتِهَا</مقطع>
  <مقطع هوية='٢٣٦٧٢'>إِذَا حُذِفَتَا فِي الْجَزْمِ ثُمَّ أَلْحَقْتَ الْخَفِيْفَةَ أَوْ الثَّقِيْلَةَ</مقطع>
  <مقطع هوية='٩١١٢٤'>أَخْرَجْتَهَا</مقطع>
  <مقطع هوية='٣٧٨٣٢'>كَمَا تُخْرِجُهَا إِذَا جِئْتَ بِالْأَلِفِ لِلِاثْنَيْنِ</مقطع>
  <مقطع هوية='٤٩٤٨٤'>لِأَنَّ الْحَرْفَ يُبْنَى عَلَيْهَا</مقطع>
  <مقطع هوية='١٩٥٧٩'>كَمَا يُبْنَى عَلَى تِلْكَ الْأَلِفِ</مقطع>
  <مقطع هوية='١٨٧٣٨'>وَمَا قَبْلَهَا مَفْتُوْحٌ</مقطع>
  <مقطع هوية='٢٥٥٨٥'>كَمَا يُفْتَحُ مَا قَبْلَ الْأَلِفِ</مقطع>
  <مقطع هوية='٧٦٠٣٥'>وَذٰلِكَ قَوْلُكَ <قول هوية='٣٣٩٢١'>ارْمِيَنَّ زَيْدًا</قول>
  وَ<قول هوية='٢٣١٤٩'>اخِشَيَنَّ زَيْدًا</قول> وَ<حرف>اغْزُوَنَّ</حرف></مقطع>

  <مقطع هوية='٤٨٠٤٨'>قَاْلَ الشَّاْعِرُ</مقطع>
  <شاهدة هوية='٦٦٩٧٠'>
    <بيت>
      <مصراع>اِسْتَقْدِرِ اللهَ خَيْرًا وَ<ثبات>ارْضَيَنَّ</ثبات> بِهِ</مصراع>
      <مصراع>فَبَيْنَمَا الْعُسْرُ إِذْ دَاْرَتْ مَيَاْسِيْرُ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٨٤٤٧٩'>وَإِنْ كَاْنَتِ الْوَاْوُ وَالْيَاْءُ غَيْرَ مَحْذُوْفَتَيْنِ سَاْكِنَتَيْنِ</مقطع>
  <مقطع هوية='٦٥٥٤٠'>ثُمَّ أَلْحَقْتَ الْخَفِيْفَةَ أَوِ الثَّقِيْلَةَ</مقطع>
  <مقطع هوية='٥٨٤٥٩'>حَرَّكْتَهَا كَمَا تُحَرِّكُهَا لأَلِفِ الِاثْنَيْنِ</مقطع>
  <مقطع هوية='٧٢٧٥٩'>وَالتَّفْسِيْرُ فِي ذٰلِكَ كَالتَّفْسِيْرِ فِي الْمَحْذُوْفِ</مقطع>
  <مقطع هوية='٤٠٦٦٦'>وَذٰلِكَ قَوْلُكَ <حرف>لَأَدْعُوَنَّ</حرف>
  وَ<حرف>لَأَرْضَيَنَّ</حرف> وَ<حرف>لَأَرْمِيَنَّ</حرف></مقطع>
  <مقطع هوية='٤٥٥٩٠'>وَ<قول هوية='٠٨٢٠٢'>هَلْ تَرْضَيَنَّ</قول> أَوْ <حرف>تَرْمِيَنَّ</حرف></مقطع>
  <مقطع هوية='٣٢٩٨٧'>وَ<قول هوية='٩٩٠٧٨'>هَلْ تَدْعُوَنَّ</قول></مقطع>
  <مقطع هوية='٢٢٦١١'>وكَذٰلِكَ كُلَّ يَاْءٍ أُجْرِيَتْ مَجْرَى الْيَاْءِ مِنْ نَفْسِ الْحَرْفِ</مقطع>
  <مقطع هوية='٤٩٧٨٤'>وَكَاْنَتْ فِي الْحَرْفِ</مقطع>
  <مقطع هوية='٦١٨٥٤'>نَحْوُ يَاْءِ <حرف>سَلْقَيْتُ</حرف>
  وَ<قول هوية='٩٧١٣٠'>تَجَعْبَيْتُ جَعْبَاْهُ</قول> أَيْ صَرَعَهُ</مقطع>
  <مقطع هوية='١٧٢٥٧'>وَ<حرف>تَجَعْبَى</حرف> انْصَرَعَ</مقطع>

