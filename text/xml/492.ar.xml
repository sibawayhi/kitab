<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-٢٧٩"
     درنبورج="٢-٣٠٤"
     البكاء="٥-٤٨٠"
     هارون="٤-١٦٣"
     يعقوب="٤-٢٧٧"
     رقم="٤٩٢">

  <!-- derenbourg: يُبْقُوْن instead of يبيْنوْن -->

  <عنوان>
    <مقطع هوية='٠٧٨٦٥'>هٰذَا بَاْبُ مَا يُبَيِّنُوْنَ حَرَكَتَهُ وَمَا قَبْلَهُ مُتَحَرِّكُ</مقطع>
  </عنوان>

  <مقطع هوية='٧٢٢٨٩'>فَمِنْ ذٰلِكَ الْيَاْءُ</مقطع>
  <مقطع هوية='٤٦١٧٠'>الَّتِي تَكُوْنُ عَلَاْمَةَ الْمُضْمَرِ الْمَجْرُوْرِ</مقطع>
  <مقطع هوية='٨٤٥٠٦'>أَوْ تَكُوْنُ عَلَاْمَةَ الْمُضْمَرِ الْمَنْصُوْبِ</مقطع>
  <مقطع هوية='١٤٤٧٨'>وَذٰلِكَ قَوْلُكَ <قول هوية='٠٢٣٥١'>هٰذَا غُلَاْمِيَهْ</قول>
  وَ<قول هوية='٨٥٨٦١'>جَاْءَ مِنْ بَعْدِيَهْ</قول>
  وَ<قول هوية='١٢٣٩٩'>إِنَّهُ ضَرَبَنِيَهْ</قول></مقطع>
  <مقطع هوية='٩٧٥٤٤'>كَرِهُوْا أَنْ يُسَكِّنُوْهَا إذْ لَمْ تَكُنْ حَرْفَ الْإِعْرَاْبِ</مقطع>
  <مقطع هوية='٦٨٢٧٤'>وَكَاْنَتْ خَفِيَّةً فَبَيَّنُوْهَا</مقطع>

  <رأس/>
  <مقطع هوية='٢٢٤٧٧'>وَأَمَّا مَنْ رَأَى أَنْ يُسَكِّنَ الْيَاْءَ</مقطع>
  <مقطع هوية='٧٥٢٧٥'>فَإِنَّهُ لَا يُلْحِقُ الْهَاْءَ</مقطع>
  <مقطع هوية='٤٣٤٢٠'>لِأَنَّ ذٰلِكَ أَمْرُهَا فِي الْوَصْلِ</مقطع>
  <مقطع هوية='٦٣٩٩٧'>فَلَمْ يُحْذَفْ مِنْهَا فِي الْوَقْفِ شَيْءٌ</مقطع>

  <رأس/>
  <مقطع هوية='٤٤٥٤٣'>وَقَاْلُوْا <حرف>هِيَهْ</حرف> وَهُمْ يُرِيْدُوْنَ <حرف>هِيَ</حرف></مقطع>
  <مقطع هوية='٤٧٩٢٣'>شَبَّهُوْهَا بِيَاْءِ <حرف>بَعْدِي</حرف></مقطع>
  <مقطع هوية='٠٢٧١٨'>وَقَاْلُوْا <حرف>هُوَهْ</حرف></مقطع>
  <مقطع هوية='٢٣٥٧٣'>لَمَّا كَاْنَتْ الْوَاْوُ لَا تَصَرَّفُ لِلْإِعْرَاْبِ</مقطع>
  <مقطع هوية='٥٩٣٨٤'>كَرِهُوْا أَنْ يُلْزِمُوْهَا الْإِسْكَاْنَ فِي الْوَقْفِ</مقطع>
  <مقطع هوية='٨٧٧٦٩'>فَجَعَلُوْهَا بِمَنْزِلَةِ الْيَاْءِ</مقطع>
  <مقطع هوية='٧٨٣٦٨'>كَمَا جَعَلُوْا <حرف>كَيْفَهْ</حرف> بِمَنْزِلَةِ <حرف>مُسْلِمُوْنَهْ</حرف></مقطع>
  <مقطع هوية='٩٩٢٠١'>وَمِثْلُ ذٰلِكَ قَوْلُهُمْ <حرف>خُذْهُ بِحُكْمِكَهْ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٢٠٢٢٥'>وَجَمِيْعُ هٰذَا فِي الْوَصْلِ بِمَنْزِلَةِ الْأَوَّلِ</مقطع>
  <مقطع هوية='٧٥٦١٢'>وَمَنْ لَمْ يُلْحِقْ هُنَاْكَ الْهَاْءَ فِي الْوَقْفِ لَمْ يُلْحِقْهَا هُنَا</مقطع>

  <رأس/>
  <مقطع هوية='٢٨٣٨٨'>وَقَدِ اسْتَعْمَلُوْا فِي شَيْءٍ مِنْ هٰذَا الْأَلِفَ فِي الْوَقْفِ</مقطع>
  <مقطع هوية='٣٦٥٥٣'>كَمَا اسْتَعْمَلُوْا الْهَاْءَ</مقطع>
  <مقطع هوية='٤٣٦٨٩'>لِأَنَّ الْهَاْءَ أَقْرَبُ الْمَخَاْرِجِ إلَى الْأَلِفِ وَهِيَ شَبِيْهَةٌ بِهَا</مقطع>
  <مقطع هوية='٣٤٦٩١'>فَمِنْ ذٰلِكَ قَوْلُ الْعَرَبِ <حرف>حَيَّهَلَا</حرف></مقطع>
  <مقطع هوية='٧٢٤٣٤'>فَإِذَا وَصَلُوْا قَاْلُوْا <قول هوية='٧٤٤٥٧'>حَيَّهَلَ بِعُمَرَ</قول></مقطع>
  <مقطع هوية='٩٩٨٢٣'>وَإِنْ شِئْتَ قُلْتَ <حرف>حَيَّهَلْ</حرف> كَمَا تَقُوْلُ <حرف>بِحُكْمِكْ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٦١٩٨٤'>وَمِنْ ذٰلِكَ قَوْلُهُمْ <حرف>أَنَا</حرف></مقطع>
  <مقطع هوية='٢٣٠٧٣'>فَإِذَا وَصَلَ قَاْلَ <قول هوية='٥١٩٨٦'>أَنَ أَقُوْلُ ذَاْكَ</قول></مقطع>
  <مقطع هوية='١٣٥٤٩'>وَلَا يَكُوْنُ فِي الْوَقْفِ فِي <حرف>أَنَا</حرف> إِلَّا الْأَلِفُ</مقطع>
  <مقطع هوية='٠٠٠٧٩'>لَمْ تُجْعَلْ بِمَنْزِلَةِ <حرف>هُوَ</حرف></مقطع>
  <مقطع هوية='٠٦٥٠٨'>لِأَنَّ <حرف>أَنَا</حرف> <!-- هُوَ --> آخِرُهَا حَرْفُ مَدٍّ وَالنُّوْنُ خَفِيَّةٌ</مقطع>
  <مقطع هوية='٨٥٨٢٥'>فَجَمَعَتْ أَنَّهَا عَلَى أَقَلِّ عَدَدِ مَا يُتَكَلَّمُ بِهِ مُفْرَدًا</مقطع>
  <مقطع هوية='٣٥٧٣٨'>وَأَنَّ آخِرَهَا خَفِيٌ لَيْسَ بِحَرْفِ إعْرَاْبٍ</مقطع>
  <مقطع هوية='٢٦٦٠٤'>فَحَمَلَهُمْ ذٰلِكَ عَلَى هٰذَا</مقطع>

  <مقطع هوية='٠٢١٢٨'>وَنَظِيْرَةُ <حرف>أَنَا</حرف> مَعَ هٰذَا</مقطع>
  <مقطع هوية='٢٨٥٢٨'>الْهَاْءُ الَّتِي تَلْزَمُ <حرف>طَلْحَةَ</حرف> فِي أَكْثَرِ كَلَاْمِهِمْ فِي النِّدَاْءِ إذَا وَقَفْتَ</مقطع>
  <مقطع هوية='٩٨٠١٨'>فَكَمَا لَزِمَتْ تِلْكَ لَزِمَتْ هَذِهِ الْأَلِفُ</مقطع>

  <رأس/>
  <مقطع هوية='٦٢٨٩٥'>وَأَمَّا <حرف>أَحْمَرُ</حرف> وَنَحْوُهُ</مقطع>
  <مقطع هوية='٦١٩٤٤'>إذَا قُلْتَ <قول هوية='٨٤٩١٤'>رَأَيْتُ أَحْمَرَ</قول>
  لَمْ تُلْحِقْ الْهَاْءَ</مقطع>
  <مقطع هوية='٤٩٤٤٤'>لِأَنَّ هٰذَا الْآخِرَ حَرْفُ إعْرَاْبٍ</مقطع>
  <مقطع هوية='٧٣١٥٠'>يَدْخُلُهُ الرَّفْعُ وَالنَّصْبُ</مقطع>
  <مقطع هوية='٩٧٥٤٩'>وَهُوَ اسْمٌ يَدْخُلُهُ الْأَلِفُ وَاللَّاْمُ فَيُجَرُّ آخِرُهُ</مقطع>
  <مقطع هوية='٨٣٣٧٠'>فَفَرَّقُوْا بَيْنَهُ وَبَيْنَ مَا لَيْسَ كَذٰلِكَ</مقطع>
  <مقطع هوية='٠٩٩٤٠'>وَكَرِهُوْا الْهَاْءَ فِي هٰذَا الِاسْمِ فِي كُلِّ مَوْضِعٍ</مقطع>
  <مقطع هوية='٥٤٧٣٩'>وَأَدْخَلُوْهَا فِي الَّتِي لَا تَزُوْلُ حَرَكَتُهَا</مقطع>
  <مقطع هوية='٠٧٤١١'>وَصَاْرَ دُخُوْلُ كُلِّ الْحَرَكَاْتِ فِيْهِ
  وَأَنَّ نَظِيْرَهُ فِيْمَا يَنْصَرِفُ مُنَوَّنٌ</مقطع>
  <مقطع هوية='٦٧٠٢٥'>عِوَضًا مِنْ الْهَاْءِ</مقطع>
  <مقطع هوية='١٦٤٠٩'>حَيْثُ قَوِيَتْ هَذِهِ الْقُوَّةَ</مقطع>

  <رأس/>
  <مقطع هوية='٥٩٤٤٤'>وَكَذٰلِكَ الْأَفْعَاْلُ نَحْوُ <حرف>ظَنَّ</حرف> وَ<حرف>ضَرَبَ</حرف></مقطع>
  <مقطع هوية='٣٠٦٠٢'>لَمَّا كَاْنَتْ اللَّاْمُ قَدْ تَصَرَّفُ حَتَّى يَدْخُلَهَا الرَّفْعُ وَالنَّصْبُ وَالْجَزْمُ شُبِّهَتْ بِـ<حرف>أَحْمَرَ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٢٣٢٤٥'>وَأَمَّا قَوْلُهُمْ <حرف>عَلَاْمَهْ</حرف>
  وَ<حرف>فِيْمَهْ</حرف> وَ<حرف>لِمَهْ</حرف> وَ<حرف>بِمَهْ</حرف> وَ<حرف>حَتَّاْمَهْ</حرف></مقطع>
  <مقطع هوية='٧٥٧٧١'>فَالْهَاْءُ فِي هَذِهِ الْحُرُوْفِ أَجْوَدُ إذَا وَقَفْتَ</مقطع>
  <مقطع هوية='٥٢٧٤١'>لِأَنَّكَ حَذَفْتَ الْأَلِفَ مِنْ <حرف>مَا</حرف></مقطع>
  <مقطع هوية='٨٨٧٠٤'>فَصَاْرَ آخِرُهُ كَآخِرِ <حرف>ارْمِهْ</حرف> وَ<حرف>اغْزُهْ</حرف></مقطع>

  <مقطع هوية='٣٩٨٣٦'>وَقَدْ قَاْلَ قَوْمٌ <حرف>فِيْمْ</حرف> وَ<حرف>عَلَاْمْ</حرف>
  وَ<حرف>بِمْ</حرف> وَ<حرف>لِمْ</حرف></مقطع>
  <مقطع هوية='٢٤٢١٥'>كَمَا قَاْلُوْا <حرف>اخْشْ</حرف></مقطع>
  <مقطع هوية='٢٧٢٤٢'>وَلَيْسَ هَذِهِ مِثْلَ <حرف>إِنَّ</حرف></مقطع>
  <مقطع هوية='٠٤٠١٤'>لِأَنَّهُ لَمْ يُحْذَفْ مِنْهَا شَيْءٌ مِنْ آخِرِهَا</مقطع>

  <رأس/>
  <مقطع هوية='٤٣٦٦٣'>وَأَمَّا قَوْلُهُمْ <قول هوية='٩٥٦١٦'>مَجِيْءَ مَ جِئْتَ</قول></مقطع>
  <مقطع هوية='٨٤٥٤٩'>وَ<حرف>مِثْلُ مَ أَنْتَ</حرف></مقطع>
  <مقطع هوية='٢٣٠٩٦'>فَإِنَّكَ إِذَا وَقَفْتَ أَلْزَمْتَهَا الْهَاْءَ</مقطع>
  <مقطع هوية='٤٥٧٤٨'>وَلَمْ يَكُنْ فِيْهِ إِلَّا ثَبَاْتُ الْهَاْءِ</مقطع>
  <مقطع هوية='٦٤١٠٣'>لأَنَّ <حرف>مَجِيْءَ</حرف> وَ<حرف>مَثْلَ</حرف> يُسْتَعْمَلاْنِ فِي الْكَلَاْمِ مُفْرَدَيْنِ لَأَنَّهُمَا اسْمَاْنِ</مقطع>
  <مقطع هوية='٣٣٠٣٠'>وَأَمَّا الْحُرُوْفُ الْأَوَّلُ</مقطع>
  <مقطع هوية='٧٤٢٩٢'>فَإِنَّهَا لَا يُتَكَلَّمُ بِهَا مُفْرَدَةً مِنْ <حرف>مَا</حرف></مقطع>
  <مقطع هوية='٠٠٤٧٧'>لِأَنَّهَا لَيْسَتْ بِأَسْمَاْءٍ</مقطع>
  <مقطع هوية='٣٨٨٤٠'>فَصَاْرَ الْأَوَّلُ وَالْآخِرُ بِمَنْزِلَةِ حَرْفٍ وَاْحِدٍ لِذٰلِكَ</مقطع>
  <مقطع هوية='٦٩٢٦٣'>وَمَعَ هٰذَا أَنَّهُ أَكْثَرُ فِي كَلَاْمِهِمْ</مقطع>
  <مقطع هوية='٧٤٥٣٢'>فَصَاْرَ هٰذَا بِمَنْزِلَةِ حَرْفٍ وَاْحِدٍ نَحْوَ <حرف>اخْشْ</حرف></مقطع>
  <مقطع هوية='٦٥٧١٤'>وَالْأَوَّلُ مِنْ <حرف>مَجِيْءَ مَ جِئْتَ</حرف>
  وَ<حرف>مِثْلَ مَ أَنْتَ</حرف> لَيْسَ كَذٰلِكَ</مقطع>
  <مقطع هوية='٧٠٣٨١'>أَلَا تَرَاْهُمْ يَقُوْلُوْنَ <حرف>مِثْلَ مَا أَنْتَ</حرف>
  وَ<حرف>مَجِيْءَ مَا جِئْتَ</حرف></مقطع>
  <مقطع هوية='٤٠٨٠٢'>لِأَنَّ الْأَوَّلَ اسْمٌ</مقطع>
  <مقطع هوية='٥٨١١٢'>وَإِنَّمَا حَذَفُوْا لِأَنَّهُمْ شَبَّهُوْهَا بِالْحُرُوْفِ الْأَوَّلِ</مقطع>
  <مقطع هوية='٧٧٨٧٤'>فَلَمَّا كَاْنَتْ الْأَلِفُ قَدْ تَلْزَمُ فِي هٰذَا الْمَوْضِعِ</مقطع>
  <مقطع هوية='٥٢٥٧٣'>كَاْنَتْ الْهَاْءُ فِي الْحَرْفِ لَاْزِمَةً فِي الْوَقْفِ</مقطع>
  <مقطع هوية='٤٣٨١٣'>لِيُفَرِّقُوْا بَيْنَهَا وَبَيْنَ الْأَوَّلِ</مقطع>

  <رأس/>
  <مقطع هوية='٦٨٥٧٥'>وَقَدْ لَحِقَتْ هَذِهِ الْهَاْءَاْتُ بَعْدَ الْأَلِفِ فِي الْوَقْفِ</مقطع>
  <مقطع هوية='٦٣٣٦٦'>لِأَنَّ الْأَلِفَ خَفِيَّةٌ فَأَرَاْدُوْا الْبَيَاْنَ</مقطع>
  <مقطع هوية='٩٧٣٣٢'>وَذٰلِكَ قَوْلُهُمْ <حرف>هَؤْلَاْهْ</حرف> وَ<حرف>هٰهُنَاْهْ</حرف></مقطع>
  <مقطع هوية='٠٩١١٦'>وَلَا يَقُوْلُوْنَهُ فِي <حرف>أَفْعَى</حرف> وَ<حرف>أَعْمَى</حرف> وَنَحْوِهِمَا مِنْ الْأَسْمَاْءِ الْمُتَمَكِّنَةِ</مقطع>
  <مقطع هوية='٥٦٨٤٨'>كَرَاْهِيَةَ أَنْ تَلْتَبِسَ بِهَاْءِ الْإِضَاْفَةِ</مقطع>
  <مقطع هوية='٢٢٢٦٢'>وَمَعَ هٰذَا أَنَّ هَذِهِ الْأَلِفَاْتِ حُرُوْفُ إعْرَاْبٍ</مقطع>
  <مقطع هوية='١٨٣٩٩'>أَلَا تَرَى أَنَّهُ لَوْ كَاْنَ فِي مَوْضِعِهَا غَيْرُ الْأَلِفِ</مقطع>
  <مقطع هوية='١١٩٤٢'>دَخَلَهُ الرَّفْعُ وَالنَّصْبُ وَالْجَرُّ</مقطع>
  <مقطع هوية='٥٩١٦٥'>كَمَا يَدْخُلُ رَاْءَ <حرف>أَحْمَرَ</حرف></مقطع>
  <مقطع هوية='٩٦٦٧٤'>وَلَوْ كَاْنَ فِي مَوْضِعِ أَلِفِ <حرف>هَؤْلَا</حرف>
  حَرْفٌ مُتَحَرِّكٌ سِوَاْهَا</مقطع>
  <مقطع هوية='١٩٧٥٣'>كَاْنَتْ لَهَا حَرَكَةٌ وَاْحِدَةٌ كَحَرَكَةِ <حرف>أَنَا</حرف> وَ<حرف>هُوَ</حرف></مقطع>
  <مقطع هوية='٩٢٧٣١'>فَلَمَّا كَاْنَ كَذٰلِكَ أَجْرَوْا الْأَلِفَ مَجْرَى مَا يَتَحَرَّكُ فِي مَوْضِعِهَا</مقطع>

  <رأس/>
  <مقطع هوية='٧٢٩٢٣'>وَاعْلَمْ أَنَّهُمْ لَا يُتْبِعُوْنَ الْهَاْءَ سَاْكِنًا سِوَى هٰذَا الْحَرْفَ الْمَمْدُوْدَ</مقطع>
  <مقطع هوية='٨٤٢٣٦'>لِأَنَّهُ خَفِيٌ فَأَرَاْدُوْا الْبَيَاْنَ</مقطع>
  <مقطع هوية='٧٦٢٩٧'>كَمَا أَرَاْدُوْا أَنْ يُحَرِّكُوْا</مقطع>
  <مقطع هوية='٩٨٤٠٩'>وَنَاْسٌ كَثِيْرٌ مِنَ الْعَرَبِ لَا يُلْحِقُوْنَ الْهَاْءَ</مقطع>
  <مقطع هوية='٣٦٣٦٩'>كَمَا لَمْ يُلْحِقُوْا <حرف>هُوَ</حرف> وَ<حرف>هُنَّ</حرف> وَنَحْوَهُمَا</مقطع>

  <رأس/>
  <مقطع هوية='٦٦٨٣١'>وَقَدْ يُلْحِقُوْنَ فِي الْوَقْفِ هَذِهِ الْهَاْءَ الأَلِفَ الَّتِي فِي النِّدَاْءِ</مقطع>
  <مقطع هوية='٥٨٩٩٦'>وَالأَلِفَ وَالْيَاْءَ وَالْوَاْوَ فِي النُّدْبَةِ</مقطع>
  <مقطع هوية='٥٦٠٦١'>لأَنَّهُ مَوْضِعُ تَصْوِيْتٍ وَتَبْيِيْنٍ</مقطع>
  <مقطع هوية='٧١٠٢١'>فَأَرَاْدُوْا أَنْ يَمُدُّوْا فَأَلْزَمُوْهَا الَهَاْءَ فِي الْوَقْفِ لِذٰلِكَ</مقطع>
  <مقطع هوية='٧٦٢٤٠'>وَتَرَكُوْهَا فِي الْوَصْلِ لِأَنَّهُ يُسْتَغْنَى عَنْهَا</مقطع>
  <مقطع هوية='٩٨٣١٤'>كَمَا يُسْتَغْنَى عَنْهَا فِي الْمُتَحَرِّكِ فِي الْوَصْلِ</مقطع>
  <مقطع هوية='٠٣٢٧٣'>لِأَنَّهُ يَجِيْءُ مَا يَقُوْمُ مَقَاْمَهَا</مقطع>
  <مقطع هوية='٧٠٧٠٩'>وَذٰلِكَ قَوْلُكَ <قول هوية='٤٦٤٨٢'>يَا غُلَاْمَاْهْ</قول>
  وَ<قول هوية='٣٦٨٥٨'>وَاْزَيْدَاْهْ</قول> وَ<قول هوية='٣١٦٥٤'>وَاْغُلَاْمَهُوْهْ</قول>
  وَ<قول هوية='٦٤٣٢٤'>وَاْذَهَاْبَ غُلاْمِهِيْهْ</قول></مقطع>

