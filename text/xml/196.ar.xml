<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="١-٣٧٢"
     درنبورج="١-٣٢٥"
     البكاء="٣-٢٥٨"
     هارون="٢-٣٣٨"
     يعقوب="٢-٣٥٥"
     رقم="١٩٦">

   <عنوان>
      <مقطع هوية='٦٣٣٩٦'>هٰذَا بَاْبُ مَا تَكُوْنُ فِيْهِ فِي الْمُسْتَثْنَى الثَّاْنِي بِالْخَيَاْرِ</مقطع>
   </عنوان>
   <مقطع هوية='٣٨٦٠٩'>وَذٰلِكَ قَوْلُكَ <قول هوية='٩٩٠٨١'>مَاْلِي إِلَّا زَيْدًا صَدِيْقٌ وَعَمْرًا</قول> وَ<حرف>عَمْرٌو</حرف></مقطع>
   <مقطع هوية='٢٤٦٤١'>وَ<قول هوية='١٩٠٧٤'>مَنْ لِي إِلَّا أَبَاْكَ صَدِيْقٌ وَزَيْدًا</قول> وَ<حرف>زَيْدٌ</حرف></مقطع>

   <مقطع هوية='١٠٣٥٤'>أَمَّا النَّصْبُ فَعَلَى الْكَلَاْمِ الْأَوَّلِ</مقطع>
   <مقطع هوية='٧٤٩٧٠'>وَأَمَّا الرَّفْعُ فَكَأَنَّهُ قَاْلَ <حرف>وَعَمْرٌو لِي</حرف></مقطع>
   <مقطع هوية='١١٢٣١'>لِأَنَّ هٰذَا الْمَعْنَى لَا يَنْقُضُ مَا تُرِيْدُ فِي النَّصْبِ</مقطع>
   <مقطع هوية='١٧٥٥٩'>وَهٰذَا قَوْلُ يُوْنُسَ وَالْخَلِيْلِ رَحِمَهُمَا اللهُ</مقطع>

   <التحرير>
