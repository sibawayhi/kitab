<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-١٤٣"
     درنبورج="٢-١٤٦"
     البكاء="٥-١٩٩"
     هارون="٣-٤٩٦"
     يعقوب="٣-٥٥٢"
     رقم="٣٩٧">

  <عنوان>
    <مقطع هوية='٢١٢٢٦'>هٰذَا بَاْبُ حُرُوْفِ الْإِضَاْفَةِ إلَى الْمَحْلُوْفِ بِهِ وَسُقُوْطِهَا</مقطع>
  </عنوان>

  <رأس/>
  <مقطع هوية='٠٦٨٨٥'>وَلِلْقَسَمِ وَالْمُقْسَمِ بِهِ أَدَوَاْتٌ فِي حُرُوْفِ الْجَرِّ</مقطع>
  <مقطع هوية='١٩٤٤٠'>وَأَكْثَرُهَا الْوَاْوُ ثُمَّ الْبَاْءُ</مقطع>
  <مقطع هوية='١٧٧٥١'>يَدْخُلَاْنِ عَلَى كُلِّ مَحْلُوْفٍ بِهِ</مقطع>
  <مقطع هوية='٨٠٧١٤'>ثُمَّ التَّاْءُ وَلَا تَدْخُلُ إِلَّا فِي وَاْحِدٍ</مقطع>
  <مقطع هوية='٣٢٨٤١'>وَذٰلِكَ قَوْلُكَ <قول هوية='٥٣٧٦٣'>وَاللهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='١٢١٣١'>وَ<قول هوية='٢٥٣٠٨'>بِاللهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='٣٣٨٧٠'>وَ<آية هوية='٨١٠٦٥' سورة="٢١" آية="٥٧">تَٱللّٰهِ لَأَكِيْدَنَّ أَصْنَاْمَكُمْ</آية></مقطع>

  <رأس/>
  <مقطع هوية='٠٩٦٤٣'>وَقَاْلَ الْخَلِيْلُ إِنَّمَا تَجِيْءُ بِهَذِهِ الْحُرُوْفِ</مقطع>
  <مقطع هوية='٤٨٧٦٩'>لِأَنَّكَ تُضِيْفُ حَلِفَكَ إِلَى الْمَحْلُوْفِ بِهِ</مقطع>
  <مقطع هوية='٤٧٣٤٩'>كَمَا تُضِيْفُ <حرف>مَرَرْتُ بِهِ</حرف> بِالْبَاْءِ</مقطع>
  <مقطع هوية='١٢٧٩٥'>إِلَّا أَنَّ الْفِعْلَ يَجِيْءُ مُضْمَرًا فِي هٰذَا الْبَاْبِ</مقطع>
  <مقطع هوية='٤٢٧٢٨'>وَالْحَلِفُ تَوْكِيْدٌ</مقطع>

  <رأس/>
  <مقطع هوية='٧٩٤٣٠'>وَقَدْ تَقُوْلُ <حرف>تَـاللّٰهِ</حرف> وَفِيْهَا مَعْنَى التَّعَجُّبِ</مقطع>
  <مقطع هوية='٤٧٤٩٧'>وَبَعْضُ الْعَرَبِ يَقُوْلُ فِي هٰذَا الْمَعْنَى <حرف>لِلّٰهِ</حرف></مقطع>
  <مقطع هوية='٢٧٢٣١'>فَيَجِيْءُ بِاللَّاْمِ وَلَا تَجِيْءُ إِلَّا أَنْ يَكُوْنَ فِيْهَا مَعْنَى التَّعَجُّبِ</مقطع>

  <مقطع هوية='٥٤١٩٣'>قَاْلَ <شاعر>أُمَيَّةُ بْنُ أَبِي عَاْئِذٍ</شاعر></مقطع>

  <شاهدة هوية='٥٥٩٣٢' شاعر="أُمَيَّةُ بْنُ أَبِي عَاْئِذٍ">
    <بيت>
      <مصراع><ثبات>لِلّٰهِ</ثبات> يَبْقَى عَلَى الْأَيَّاْمِ ذُو حِيَدٍ</مصراع>
      <مصراع>بِمُشْمَخِرٍّ بِهِ الظَّيَّاْنُ وَالْآسُ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٣٨٦٢٠'>وَاعْلَمْ أَنَّكَ إِذَا حَذَفْتَ مِنَ الْمَحْلُوْفِ بِهِ حَرْفَ الْجَرِّ نَصَبْتَهُ</مقطع>
  <مقطع هوية='٦١٩٩٠'>كَمَا تَنْصِبُ <حرف>حَقًّا</حرف> إِذَا قُلْتَ <قول هوية='٦٠٣٧٠'>إِنَّكَ ذَاْهِبٌ حَقًّا</قول></مقطع>
  <مقطع هوية='١٤٤٠٣'>فَالْمَحْلُوْفُ بِهِ مُؤَكَّدٌ بِهِ الْحَدِيْثُ</مقطع>
  <مقطع هوية='٨٩٦٢٣'>كَمَا تُؤَكِّدُهُ بِالْـ<حرف>حَقِّ</حرف></مقطع>
  <مقطع هوية='٥٦٥١٩'>وَيُجَرُّ بِحُرُوْفِ الإِضَاْفَةِ</مقطع>
  <مقطع هوية='٣٥٠٥٣'>كَمَا يُجَرُّ <حرف>حَقٌ</حرف> إِذَا قُلْتَ
  <قول هوية='٤٥٣٥٠'>إِنَّكَ ذَاْهِبٌ بِحَقٍّ</قول></مقطع>
  <مقطع هوية='٥٧٠٠١'>وَذٰلِكَ قَوْلُكَ <قول هوية='٨٢٧٨٢'>اللهَ لَأَفْعَلَنَّ</قول></مقطع>

  <مقطع هوية='١١٩٥١'>وَقَاْلَ <شاعر>ذُو الرِّمَّةَ</شاعر></مقطع>
  <شاهدة هوية='٩١٦١١' شاعر="ذُو الرِّمَّةَ">
    <بيت>
      <مصراع>أَلَا رُبَّ مَنْ قَلْبِي لَهُ <ثبات>اللهَ</ثبات> نَاْصِحٌ</مصراع>
      <مصراع>وَمَنْ قَلْبُهُ لِي فِي الظِّبَاْءِ السَّوَاْنَحِ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٩٦٦٥٠'>وَقَاْلَ الْآخَرُ</مقطع>
  <شاهدة هوية='٩١٦٠٠'>
    <بيت>
      <مصراع>إِذَا مَا الْخُبْزُ تَأْدِمُهُ بِلَحْمٍ</مصراع>
      <مصراع>فَذَاْكَ <ثبات>أَمَاْنَةَ اللهِ</ثبات> الثَّرِيْدُ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٧٨٣٠٣'>فَأَمَّا <حرف>تَاللّٰهِ</حرف></مقطع>
  <مقطع هوية='٩٩٩٢٣'>فَلَا تَحْذِفُ مِنْهُ التَّاْءَ إذَا أَرَدْتَ مَعْنَى التَّعَجُّبِ</مقطع>
  <مقطع هوية='٨٣٢٢٢'>وَ<حرف>لِلّٰهِ</حرف> مِثْلُهَا إذَا تَعَجَّبْتَ لَيْسَ إِلَّا</مقطع>

  <رأس/>
  <مقطع هوية='٦٧٧٨٧'>وَمِنَ الْعَرَبِ مَنْ يَقُوْلُ <قول هوية='٨٤٧١٨'>اللهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='٨٠٠١٩'>وَذٰلِكَ أَنَّهُ أَرَاْدَ حَرْفَ الْجَرِّ وَإِيَّاْهُ نَوَى</مقطع>
  <مقطع هوية='٦١٥٣٠'>فَجَاْزَ حَيْثُ كَثُرَ فِي كَلَاْمِهِمْ</مقطع>
  <مقطع هوية='٣٧٦٤٠'>وَحَذَفُوْهُ تَخْفِيْفًا وَهُمْ يَنْوُوْنَهُ</مقطع>
  <مقطع هوية='٥٨٦١٧'>كَمَا حَذَفَ <حرف>رُبَّ</حرف> فِي قَوْلِهِ</مقطع>

  <شاهدة هوية='٥٣٥٣٤'>
    <بيت>
      <مصراع><ثبات>وَجَدَّاْءَ</ثبات> مَا يُرْجَى بِهَا ذُو قَرَاْبَةٍ</مصراع>
      <مصراع>لِعَطْفٍ وَمَا يَخْشَى السُّمَاْةَ رَبِيْبُهَا</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٦٤٥٠٨'>إِنَّمَا يُرِيْدُوْنَ <حرف>رُبَّ جَدَاْءَ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٠٧٨٣٠'>وَحَذَفُوْا الْوَاْوَ كَمَا حَذَفُوْا اللَّاْمَيْنِ مِنْ قَوْلِهِمْ <حرف>لَاْهِ أَبُوْكَ</حرف></مقطع>
  <مقطع هوية='٠٦٦٨٦'>حَذَفُوْا لَاْمَ الْإِضَاْفَةِ وَاللَّاْمَ الْأُخْرَى لِيُخَفِّفُوْا الْحَرْفَ عَلَى اللِّسَاْنِ وَذٰلِكَ يَنْوُوْنَ</مقطع>
  <مقطع هوية='٥٠٥١١'>وَقَاْلَ بَعْضُهُمْ <حرف>لَهْيَ أَبُوْكَ</حرف> فَقَلَّتِ الْعَيْنُ</مقطع>
  <مقطع هوية='٩٢٤٨٥'>وَجُعِلَ اللَّاْمُ سَاْكِنَةً إِذَا صَاْرَتْ مَكَاْنَ الْعَيْنِ كَمَا الْعَيْنُ سَاْكِنَةً</مقطع>
  <مقطع هوية='٣٠٢٤٠'>تَرَكُوْا آخِرَ الِاسْمِ مَفْتُوْحًا</مقطع>
  <مقطع هوية='٤٣٤٧٨'>كَمَا تَرَكُوْا آخِرَ <حرف>أَيْنَ</حرف> مَفْتُوْحَةً</مقطع>
  <مقطع هوية='٦٩٩٧٠'>إَنَّمَا فَعَلُوْا ذٰلِكَ بِهِ حَيْثُ غَيَّرُوْهُ لِكَثْرَتِهِ فِي كَلَاْمِهِمْ</مقطع>
<مقطع هوية='٣٢٣٣٨'>فَغَيَّرُوْا إِعْرَاْبَهُ كَمَا غَيَّرُوْهُ</مقطع>

  <رأس/>
  <مقطع هوية='٢١٦٧٤'>وَاعَلِمْ أَنَّ مِنَ الْعَرَبِ مَنْ يَقُوْلُ
  <قول هوية='٧٠٤١٧'>مِنْ رَبِّي لَأَفْعَلَنَّ ذٰلِكَ</قول></مقطع>
  <مقطع هوية='٦٦٥٢٤'>وَ<قول هوية='٧٣٣٨٥'>مُنْ رَبِّي إِنَّكَ لَأَشِرٌ</قول></مقطع>
  <مقطع هوية='٠٩٩٢١'>يَجْعَلُهَا فِي هٰذَا الْمَوْضِعِ بِمَنْزِلَةِ الْوَاْوِ وَالْبَاْءِ
  فِي قَوْلِهِ <قول هوية='٩٠٨١٢'>وَاللهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='٥٤٢٠٣'>وَلَا يُدْخِلُوْنَهَا فِي غَيْرِ <حرف>رَبِّي</حرف></مقطع>
  <مقطع هوية='٦٤١٩٢'>كَمَا لَا يُدْخِلُوْنَ التَّاْءَ فِي غَيْرِ <حرف>اللهِ</حرف></مقطع>
  <مقطع هوية='٠٩٣٧٧'>وَلَكِنَّ الْوَاْوَ لَاْزِمَةٌ لِكُلِّ اسْمٍ يُقْسَمُ بِهِ وَالْبَاْءُ</مقطع>
  <مقطع هوية='٣١٤٥١'>وَقَدْ يَقُوْلُ بَعْضُ الْعَرَبِ <قول هوية='٩٥٠٤٠'>لِلّٰهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='٥٣٢٦٨'>كَمَا تَقُوْلُ <قول هوية='٧٤٨٧٠'>تَاللّٰهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='٥٠٢٢٨'>وَلَا تَدْخُلُ الضَّمَّةُ فِي <حرف>مِنْ</حرف> إِلَّا هَهُنَا</مقطع>
  <مقطع هوية='٧٢٨٧٩'>كَمَا لَا تَدْخُلُ الْفَتْحَةُ فِي <حرف>لَدُنْ</حرف>
  إِلَّا مَعَ <حرف>غُدْوَةٍ</حرف></مقطع>
  <مقطع هوية='٧٢٠٦٨'>حِيْنَ تَقُوْلُ <حرف>لَدُن غُدْوَةً إِلَى الْعَشِيِّ</حرف></مقطع>

