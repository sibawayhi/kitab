<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-١٤٣"
     درنبورج="٢-١٤٦"
     البكاء="٥-١٩٩"
     هارون="٣-٤٩٦"
     يعقوب="٣-٥٥٢"
     رقم="٣٩٧">

  <عنوان>
    <مقطع هوية='٢١٢٢٦'>هٰذَا بَاْبُ حُرُوْفِ الْإِضَاْفَةِ إلَى الْمَحْلُوْفِ بِهِ وَسُقُوْطِهَا</مقطع>
  </عنوان>

  <رأس/>
  <مقطع هوية='٠٦٨٨٥'>وَلِلْقَسَمِ وَالْمُقْسَمِ بِهِ أَدَوَاْتٌ فِي حُرُوْفِ الْجَرِّ</مقطع>
  <مقطع هوية='١٩٤٤٠'>وَأَكْثَرُهَا الْوَاْوُ ثُمَّ الْبَاْءُ</مقطع>
  <مقطع هوية='١٧٧٥١'>يَدْخُلَاْنِ عَلَى كُلِّ مَحْلُوْفٍ بِهِ</مقطع>
  <مقطع هوية='٨٠٧١٤'>ثُمَّ التَّاْءُ وَلَا تَدْخُلُ إِلَّا فِي وَاْحِدٍ</مقطع>
  <مقطع هوية='٣٢٨٤١'>وَذٰلِكَ قَوْلُكَ <قول هوية='٥٣٧٦٣'>وَاللهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='١٢١٣١'>وَ<قول هوية='٢٥٣٠٨'>بِاللهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='٣٣٨٧٠'>وَ<آية  سورة="٢١" آية="٥٧">تَٱللّٰهِ لَأَكِيْدَنَّ أَصْنَاْمَكُمْ</آية></مقطع>

  <رأس/>
  <مقطع هوية='٠٩٦٤٣'>وَقَاْلَ الْخَلِيْلُ إِنَّمَا تَجِيْءُ بِهَذِهِ الْحُرُوْفِ</مقطع>
  <مقطع هوية='٤٨٧٦٩'>لِأَنَّكَ تُضِيْفُ حَلِفَكَ إِلَى الْمَحْلُوْفِ بِهِ</مقطع>
  <مقطع هوية='٤٧٣٤٩'>كَمَا تُضِيْفُ <حرف>مَرَرْتُ بِهِ</حرف> بِالْبَاْءِ</مقطع>
  <مقطع هوية='١٢٧٩٥'>إِلَّا أَنَّ الْفِعْلَ يَجِيْءُ مُضْمَرًا فِي هٰذَا الْبَاْبِ</مقطع>
  <مقطع هوية='٤٢٧٢٨'>وَالْحَلِفُ تَوْكِيْدٌ</مقطع>

  <رأس/>
  <مقطع هوية='٧٩٤٣٠'>وَقَدْ تَقُوْلُ <حرف>تَـاللّٰهِ</حرف> وَفِيْهَا مَعْنَى التَّعَجُّبِ</مقطع>
  <مقطع هوية='٤٧٤٩٧'>وَبَعْضُ الْعَرَبِ يَقُوْلُ فِي هٰذَا الْمَعْنَى <حرف>لِلّٰهِ</حرف></مقطع>
  <مقطع هوية='٢٧٢٣١'>فَيَجِيْءُ بِاللَّاْمِ وَلَا تَجِيْءُ إِلَّا أَنْ يَكُوْنَ فِيْهَا مَعْنَى التَّعَجُّبِ</مقطع>

  <مقطع هوية='٥٤١٩٣'>قَاْلَ <شاعر>أُمَيَّةُ بْنُ أَبِي عَاْئِذٍ</شاعر></مقطع>

  <شاهدة هوية='٥٥٩٣٢' شاعر="أُمَيَّةُ بْنُ أَبِي عَاْئِذٍ">
    <بيت>
      <مصراع><ثبات>لِلّٰهِ</ثبات> يَبْقَى عَلَى الْأَيَّاْمِ ذُو حِيَدٍ</مصراع>
      <مصراع>بِمُشْمَخِرٍّ بِهِ الظَّيَّاْنُ وَالْآسُ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٣٨٦٢٠'>وَاعْلَمْ أَنَّكَ إِذَا حَذَفْتَ مِنَ الْمَحْلُوْفِ بِهِ حَرْفَ الْجَرِّ نَصَبْتَهُ</مقطع>
  <مقطع هوية=''>كَمَا تَنْصِبُ <حرف>حَقًّا</حرف> إِذَا قُلْتَ <قول هوية=''>إِنَّكَ ذَاْهِبٌ حَقًّا</قول></مقطع>
  <مقطع هوية=''>فَالْمَحْلُوْفُ بِهِ مُؤَكَّدٌ بِهِ الْحَدِيْثُ</مقطع>
  <مقطع هوية=''>كَمَا تُؤَكِّدُهُ بِالْـ<حرف>حَقِّ</حرف></مقطع>
  <مقطع هوية=''>وَيُجَرُّ بِحُرُوْفِ الإِضَاْفَةِ</مقطع>
  <مقطع هوية=''>كَمَا يُجَرُّ <حرف>حَقٌ</حرف> إِذَا قُلْتَ
  <قول هوية=''>إِنَّكَ ذَاْهِبٌ بِحَقٍّ</قول></مقطع>
  <مقطع هوية=''>وَذٰلِكَ قَوْلُكَ <قول هوية=''>اللهَ لَأَفْعَلَنَّ</قول></مقطع>

  <مقطع هوية=''>وَقَاْلَ <شاعر>ذُو الرِّمَّةَ</شاعر></مقطع>
  <شاهدة هوية='٩١٦١١' شاعر="ذُو الرِّمَّةَ">
    <بيت>
      <مصراع>أَلَا رُبَّ مَنْ قَلْبِي لَهُ <ثبات>اللهَ</ثبات> نَاْصِحٌ</مصراع>
      <مصراع>وَمَنْ قَلْبُهُ لِي فِي الظِّبَاْءِ السَّوَاْنَحِ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٩٦٦٥٠'>وَقَاْلَ الْآخَرُ</مقطع>
  <شاهدة هوية='٩١٦٠٠'>
    <بيت>
      <مصراع>إِذَا مَا الْخُبْزُ تَأْدِمُهُ بِلَحْمٍ</مصراع>
      <مصراع>فَذَاْكَ <ثبات>أَمَاْنَةَ اللهِ</ثبات> الثَّرِيْدُ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٧٨٣٠٣'>فَأَمَّا <حرف>تَاللّٰهِ</حرف></مقطع>
  <مقطع هوية=''>فَلَا تَحْذِفُ مِنْهُ التَّاْءَ إذَا أَرَدْتَ مَعْنَى التَّعَجُّبِ</مقطع>
  <مقطع هوية=''>وَ<حرف>لِلّٰهِ</حرف> مِثْلُهَا إذَا تَعَجَّبْتَ لَيْسَ إِلَّا</مقطع>

  <رأس/>
  <مقطع هوية='٦٧٧٨٧'>وَمِنَ الْعَرَبِ مَنْ يَقُوْلُ <قول هوية=''>اللهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية=''>وَذٰلِكَ أَنَّهُ أَرَاْدَ حَرْفَ الْجَرِّ وَإِيَّاْهُ نَوَى</مقطع>
  <مقطع هوية=''>فَجَاْزَ حَيْثُ كَثُرَ فِي كَلَاْمِهِمْ</مقطع>
  <مقطع هوية=''>وَحَذَفُوْهُ تَخْفِيْفًا وَهُمْ يَنْوُوْنَهُ</مقطع>
  <مقطع هوية=''>كَمَا حَذَفَ <حرف>رُبَّ</حرف> فِي قَوْلِهِ</مقطع>

  <شاهدة هوية='٥٣٥٣٤'>
    <بيت>
      <مصراع><ثبات>وَجَدَّاْءَ</ثبات> مَا يُرْجَى بِهَا ذُو قَرَاْبَةٍ</مصراع>
      <مصراع>لِعَطْفٍ وَمَا يَخْشَى السُّمَاْةَ رَبِيْبُهَا</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٦٤٥٠٨'>إِنَّمَا يُرِيْدُوْنَ <حرف>رُبَّ جَدَاْءَ</حرف></مقطع>

  <مقطع هوية=''>وَحَذَفُوْا الْوَاْوَ كَمَا حَذَفُوْا</مقطع>

  <رأس/>
  <مقطع هوية=''>وَاعَلِمْ أَنَّ مِنَ الْعَرَبِ مَنْ يَقُوْلُ مِنْ رَبِّي لَأَفْعَلَنَّ ذٰلِكَ وَمِنْ رَبِّي إِنَّكَ لَأَشَرٌ يَجْعَلُهَا فِي هٰذَا الْمَوْضِعِ بِمَنْزِلَةِ الْوَاْوِ وَالْيَاْءِ فِي قَوْلِهِ وَاللَّهِ لَأَفْعَلَنَّ وَلَا يَدْخُلُوْنَهَا فِي غَيْرِ رَبِّي كَمَا لَا يَدْخُلُوْنَ التَّاْءَ فِي غَيْرِ اللَّهِ وَلَكِنَّ الْوَاْوَ لَاْزِمَةٌ لِكُلِّ اسْمٍ يُقْسَمُ بِهِ وَالْبَاْءُ وَقَدْ يَقُوْلُ بَعْضُ الْعَرَبِ لِلَّهِ لَأَفْعَلَنَّ كَمَا تَقُوْلُ تَاْللَّهِ لَأَفْعَلَنَّ وَلَا تَدْخُلُ الضَّمَّةُ فِي مَنْ إِلَّا هَهُنَا كَمَا لَا تَدْخُلُ الْفَتْحَةُ فِي لَدُنْ إِلَّا مَعَ غَدْوَةٍ حِيْنَ تَقُوْلُ لَدْنَ غُدْوَةً إِلَى الْعَشِي</مقطع>

  <التحرير>
