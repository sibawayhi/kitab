<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-٢٣٩"
     درنبورج="٢-٢٥٤"
     البكاء="٥-٣٨٠"
     هارون="٤-٧٠"
     يعقوب="٤-١٨٣"
     رقم="٤٤٩">

  <عنوان>
    <مقطع هوية='٢٢٣١٤'>هٰذَا بَاْبُ <مثال>اسْتَفْعَلْتُ</مثال> [وَ<مثال>تَفَعَّلْتُ</مثال>]</مقطع>
  </عنوان>
  <مقطع هوية='٦٩٣٦٠'>تَقُوْلُ <تمثيل>اسْتَجَدْتُهُ</تمثيل> أَيْ <حرف>أَصَبْتُهُ جَيِّدًا</حرف></مقطع>
  <مقطع هوية='٤١٦٨٢'>وَ<تمثيل>اسْتَكْرَمْتُهُ</تمثيل> أَيْ <حرف>أَصَبْتُهُ كَرِيْمًا</حرف></مقطع>
  <مقطع هوية='٨١٢٢٠'>وَ<تمثيل>اسْتَعْظَمْتُهُ</تمثيل> أَيْ <حرف>أَصَبْتُهُ عَظِيْمًا</حرف></مقطع>
  <مقطع هوية='٦٩٠٧٥'>وَ<تمثيل>اسْتَسْمَنْتُهُ</تمثيل> أَيْ <حرف>أَصَبْتُهُ سَمِيْنًا</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٧٣٧٧٧'>وَقَدْ يَجِيْءُ <مثال>اسْتَفْعَلْتُ</مثال> عَلَى غَيْرِ هٰذَا الْمَعْنَى</مقطع>
  <مقطع هوية='٦٢٧٧٣'>كَمَا جَاْءَ <حرف>تَذَاْءَبْتُ</حرف> وَ<حرف>عَاْقَبْتُ</حرف></مقطع>
  <مقطع هوية='٧٤٧٦٥'>تَقُوْلُ <تمثيل>اسْتَلْأَمَ</تمثيل></مقطع>
  <مقطع هوية='١٩٦٩٩'>وَ<تمثيل>اسْتَخْلَفَ لِأَهْلِهِ</تمثيل></مقطع>
  <مقطع هوية='٩٧٢١٠'>كَمَا تَقُوْلُ <حرف>أَخْلَفَ لِأَهْلِهِ</حرف> الْمَعْنَى وَاْحِدٌ</مقطع>

  <رأس/>
  <مقطع هوية='٦٩٤٧٣'>وَتَقُوْلُ <تمثيل>اسْتَعْطَيْتُ</تمثيل>
  أَيْ <حرف>طَلَبْتُ الْعَطِيَّةَ</حرف></مقطع>
  <مقطع هوية='٣٤٧١٥'>وَ<تمثيل>اسْتَعْتَبْتُهُ</تمثيل>
  أَيْ <حرف>طَلَبْتُ إِلَيْهِ الْعُتْبَى</حرف></مقطع>
  <مقطع هوية='٣٨١٦١'>وَمِثْلُ ذٰلِكَ <تمثيل>اسْتَفْهَمْتُ</تمثيل></مقطع>
  <مقطع هوية='٥٥٠١٩'>وَ<تمثيل>اسْتَخْبَرْتُ</تمثيل> أَيْ <حرف>طَلَبْتُ إِلَيْهِ أَنْ يُخْبِرَنِي</حرف></مقطع>
  <مقطع هوية='٩٠٤١٩'>وَمِثْلُهُ <تمثيل>اسْتَثَرْتُهُ</تمثيل></مقطع>

  <مقطع هوية='٨٠٤٤٩'>وَتَقُوْلُ <تمثيل>اسْتَخْرَجْتُهُ</تمثيل>
  أَيْ <حرف>لَمْ أَزَلْ أَطْلُبُ إِلَيْهِ حَتَّى خَرَجَ</حرف></مقطع>
  <مقطع هوية='٤٥٦٤٤'>وَقَدْ يَقُوْلُوْنَ <حرف>اخْتَرَجْتُهُ</حرف>
  شَبَّهُوْهُ بِـ<مثال>افْتَعَلْتُهُ</مثال> وَ<حرف>انْتَزَعْتُهُ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٦٩٤٨٧'>وَقَاْلُوْا <قول هوية='٦٠٢٤٠'>قَرَّ فِي مَكَاْنِهِ</قول>
  وَ<تمثيل>اسْتَقَرَّ</تمثيل></مقطع>
  <مقطع هوية='٨٧٣٧٠'>كَمَا يَقُوْلُوْنَ <قول هوية='٩٢١٦٢'>جَلَبَ الْجُرْحُ</قول> وَ<حرف>أَجْلَبَ</حرف> يُرِيْدُوْنَ بِهِمَا شَيْئًا وَاْحِدًا</مقطع>
  <مقطع هوية='٨٣٤٥٧'>كَمَا بُنِيَ ذٰلِكَ عَلَى <مثال>أَفْعَلْتُ</مثال>
  بُنِيَ هٰذَا عَلَى <مثال>اسْتَفْعَلْتُ</مثال></مقطع>

  <رأس/>
  <مقطع هوية='٩٢٠٨٥'>وأَمَّا <تمثيل>اسْتَحَقَّهُ</تمثيل>
  فَإِنَّهُ يَكُوْنُ <حرف>طَلَبَ حَقَّهُ</حرف></مقطع>
  <مقطع هوية='٥٧٢٣٣'>وَأَمَّا <تمثيل>اسْتَخَفَّهُ</تمثيل>
  فَإِنَّهُ يَقُوْلُ <حرف>طَلَبَ خِفَّتَهُ</حرف></مقطع>
  <مقطع هوية='٥٨١٢١'>وَكَذٰلِكَ <تمثيل>اسْتَعْمَلَهُ</تمثيل>
  أَيْ <حرف>طَلَبَ إِلَيْهِ الْعَمَلَ</حرف></مقطع>
  <مقطع هوية='٢٣٩٠٩'>وَكَذٰلِكَ <تمثيل>اسْتَعْجَلْتُ</تمثيل>
  وَ<حرف>مَرَّ مُسْتَعْجِلًا</حرف> أَيْ مَرَّ طَاْلِبًا ذَاْكَ مِنْ نَفْسِهِ مُتَكَلِّفًا إِيَّاْهَ</مقطع>

  <رأس/>
  <مقطع هوية='٩٠٥٩٩'>وَأَمَّا <قول هوية='٠٠٧٢٠'>عَلَا قَرْنَهُ</قول>
  وَ<تمثيل>اسْتَعْلَاْهُ</تمثيل> فَإِنَّهُ مِثْلُ <حرف>قَرَّ</حرف> وَ<تمثيل>اسْتَقَرَّ</تمثيل></مقطع>
  <مقطع هوية='٨٤١٨٣'>وَقَاْلُوْا فِي التَّحَوُّلِ مِنْ حَاْلٍ إِلَى حَاْلٍ هَكَذَا</مقطع>
  <مقطع هوية='٤٢٣٢٩'>وَذٰلِكَ قَوْلُكَ <قول هوية='٨٨٣٠٦'>اسْتَنْوَقَ الْجَمَلُ</قول>
  وَ<قول هوية='٤٠٠٠١'>اسْتَتْيَسَتْ الشَّاْةُ</قول></مقطع>

  <رأس/>
  <مقطع هوية='٢٨٨٦٦'>وإِذَا أَرَاْدَ الرَّجُلُ أَنْ يُدْخِلَ نَفْسَهُ فِي أَمْرٍ</مقطع>
  <مقطع هوية='٧٤٢٧٩'>حَتَّى يُضَاْفَ إِلَيْهِ وَيَكُوْنَ مِنْ أَهْلِهِ</مقطع>
  <مقطع هوية='٥٦١٨٨'>فَإِنَّكَ تَقُوْلُ <مثال>تَفَعَّلَ</مثال></مقطع>
  <مقطع هوية='٩٢٩٣٩'>وَذٰلِكَ <تمثيل>تَشَجَّعَ</تمثيل>
  وَ<تمثيل>تَبَصَّرَ</تمثيل>
  وَ<تمثيل>تَحَلَّمَ</تمثيل>
  وَ<تمثيل>تَجَلَّدَ</تمثيل></مقطع>
  <مقطع هوية='٢٧٣٩٤'>وَ<تمثيل>تَمَرَّأَ</تمثيل> وَتَقْدِيْرُهَا <تمثيل>تَمَرَّعَ</تمثيل> أَيْ <حرف>صَاْرَ ذَا مُرُوْءَةٍ</حرف></مقطع>

  <مقطع هوية='٠٨٦٧٣'>وَقَاْلَ حَاْتِمُ طَيَّئٍ</مقطع>
  <شاهدة هوية='٢٢٧٣٠'>
    <بيت>
      <مصراع>تَحَلَّمْ عَنِ الْأَدْنَيْنَ وَاسْتَبِق وُدَّهُمْ</مصراع>
      <مصراع>وَلَنْ تَسْتَطِيْعَ الْحِلْمَ حَتَّى تَحَلَّمَا</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٣٢٤٣٥'>وَلَيْسَ هٰذَا بِمَنْزِلَةِ <حرف>تَجَاْهَلَ</حرف>
  لِأَنَّ هٰذَا يَطْلُبُ أَنْ يَصِيْرَ حَلِيْمًا</مقطع>
  <مقطع هوية='٧٠١٥٩'>وَقَدْ يَجِيْءُ <تمثيل>تَقَيَّسَ</تمثيل>
  وَ<تمثيل>تَنَزَّرَ</تمثيل>
  وَ<تمثيل>تَعَرَّبَ</تمثيل>
  عَلَى هٰذَا</مقطع>
  <مقطع هوية='٠٣٣٨٧'>وَقَدْ دَخَلَ <مثال>اسْتَفْعَلَ</مثال> هٰهُنَا</مقطع>
  <مقطع هوية='٣٨٢٧٢'>قَاْلُوْا <تمثيل>تَعَظَّمَ</تمثيل> وَ<تمثيل>اسْتَعْظَمَ</تمثيل></مقطع>
  <مقطع هوية='٩٨٢١٨'>وَ<تمثيل>تَكَبَّرَ</تمثيل> وَ<تمثيل>اسْتَكْبَرَ</تمثيل></مقطع>

  <رأس/>
  <مقطع هوية='٦٢٣٣٨'>كَمَا شَاْرَكَتْ <مثال>تَفَاْعَلْتُ</مثال> <مثال>تَفَعَّلْتُ</مثال> الَّذِي لَيْسَ فِي هٰذَا الْمَعْنَى وَلَكِنَّهُ اسْتِثْبَاْتٌ</مقطع>
  <مقطع هوية='٦١٤٦١'>وَذٰلِكَ قَوْلُهُمْ <تمثيل>تَيَقَّنْتُ</تمثيل> وَ<تمثيل>اسْتَيْقَنْتُ</تمثيل></مقطع>
  <مقطع هوية='٢٨٧٩٠'>وَ<تمثيل>تَبَيَّنْتُ</تمثيل> وَ<تمثيل>اسْتَبَنْتُ</تمثيل></مقطع>
  <مقطع هوية='٢٥٤٧٨'>وَ<تمثيل>تَثَبَّتُّ</تمثيل> وَ<تمثيل>اسْتَثْبَتُّ</تمثيل></مقطع>

  <رأس/>
  <مقطع هوية='٥٧٣٧٩'>وَمِثْلَ ذٰلِكَ يَعْنِي <تمثيل>تَحَلَّمَ</تمثيل></مقطع>
  <مقطع هوية='٦٠٦٣٥'><تمثيل>تَقَعَّدْتُهُ</تمثيل> أَيْ
  <قول هوية='٩٢٦٩٠'>رَيَّثْتُهُ عَنْ حَاْجَتِهِ وَعُقْتُهُ</قول></مقطع>
  <مقطع هوية='٨٢٧٠٥'>وَمِثْلُهُ <قول هوية='٣٤٠٤٥'>تَهَيَّبَنِي كَذَا وَكَذَا</قول>
  وَ<قول هوية='٣٩٢٣٢'>تَهَيَّبَتْنِي الْبِلَاْدُ</قول></مقطع>
  <مقطع هوية='٧١٦٠٠'>وَ<قول هوية='٨٢٨٧٧'>تَكَاْءَدَنِي ذَاْكَ الْأَمْرُ تَكَاْؤُدًا</قول>
  أَيْ <حرف>شَقَّ عَلَيَّ</حرف></مقطع>

  <مقطع هوية='١٨١١٧'>وَأَمَّا قَوْلُهُ <تمثيل>تَنَقَّصْتُهُ</تمثيل>
  وَ<تمثيل>تَنَقَّصَنِي</تمثيل> فَكَأَنَّهُ الْأَخْذُ مِنْ الشَّيْءِ الْأَوَّلَ فَالْأَوَّلَ</مقطع>

  <رأس/>
  <مقطع هوية='٠٩٤٥٤'>وَأَمَّا <تمثيل>تَفَهَّمَ</تمثيل>
  وَ<تمثيل>تَبَصَّرَ</تمثيل> وَ<تمثيل>تَأَمَّلَ</تمثيل>
  فَاسْتِثْبَاْتٌ بِمَنْزِلَةِ <تمثيل>تَيَقَّنَ</تمثيل></مقطع>
  <مقطع هوية='٣٩٤٧٤'>وَقَدْ تَشْرَكُهُ <مثال>اسْتَفْعَلَ</مثال>
  نَحْوَ <تمثيل>اسْتَثْبَتَ</تمثيل></مقطع>

  <رأس/>
  <مقطع هوية='٤٧٣٤٤'>وَأَمَّا <تمثيل>يَتَجَرَّعُهُ</تمثيل>
  وَ<تمثيل>يَتَحَسَّاْهُ</تمثيل> وَ<تمثيل>يَتَفَوَّقُهُ</تمثيل></مقطع>
  <مقطع هوية='٨٩٥٢٧'>فَهُوَ <تمثيل>يَتَنَقَّصُهُ</تمثيل>
  لِأَنَّهُ لَيْسَ مِنْ مُعَاْلَجَتِكَ الشَّيْءَ بِمَرَّةٍ وَلَكِنَّهُ فِي مُهْلَةٍ</مقطع>

  <رأس/>
  <مقطع هوية='٨٩٣٦٥'>وَأَمَّا <تمثيل>تَعَقَّلَهُ</تمثيل>
  فَهُوَ نَحْوُ <تمثيل>تَقَعَّدَهُ</تمثيل></مقطع>
  <مقطع هوية='١٥١٠٤'>لِأَنَّهُ يُرِيْدُ أَنْ يَخْتِلِهِ عَنْ أَمْرٍ يَعُوْقُهُ عَنْهُ</مقطع>
  <مقطع هوية='٨٢٣٢٥'>وَ<تمثيل>يَتَمَلَّقُهُ</تمثيل> نَحْوُ ذٰلِكَ
  لِأَنَّهُ إِنَّمَا يُدِيْرُهُ عَنْ شَيْءٍ</مقطع>

  <رأس/>
  <مقطع هوية='٦٢١٢٧'>وَقَاْلَ <تمثيل>تَظَلَّمَنِي</تمثيل>
  أَيْ <حرف>ظَلَمَنِي</حرف> مَاْلِي</مقطع>
  <مقطع هوية='٠٧٠٦٦'>فَبَنَاْهُ فِي هٰذَا الْمَوْضِعِ عَلَى <مثال>تَفَعَّلَ</مثال></مقطع>
  <مقطع هوية='٣١٢٥٤'>كَمَا قَاْلُوْا <حرف>جُزْتُهُ</حرف> وَ<حرف>جَاْوَزْتُهُ</حرف>
  وَهُوَ يُرِيْدُ شَيْئًا وَاْحِدًا</مقطع>
  <مقطع هوية='٩٠١٤٧'>وَ<حرف>قِلْتُهُ</حرف> وَ<حرف>أَقَلْتُهُ</حرف>
  وَ<حرف>لِقْتُهُ</حرف> وَ<حرف>أَلَقْتُهُ</حرف> وَهُوَ إِذَا لَطَخْتَهُ بِالطِّيْنِ</مقطع>
  <مقطع هوية='٨١٤٩٤'>وَ<حرف>أَلَقْتُ الدَّوَاْةَ</حرف> وَ<حرف>لِقْتُهَا</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٤٨٧٠٧'>وَأَمَّا <تمثيل>تَهَيَّبَهُ</تمثيل></مقطع>
  <مقطع هوية='٧٨٠٨١'>فَإِنَّهُ حَصَرٌ لَيْسَ فِيْهِ مَعْنَى شَيْءٍ مِمَّا ذَكَرْنَا</مقطع>
  <مقطع هوية='٣٣٢٠٩'>كَمَا أَنَّكَ تَقُوْلُ <تمثيل>اسْتَعْلَيْتُهُ</تمثيل>
  لَا تُرِيْدُ إِلَّا مَعْنَى <حرف>عَلَوْتُهُ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٧٧٨٦٠'>وَأَمَّا <تمثيل>تَخَوَّفَهُ</تمثيل></مقطع>
  <مقطع هوية='٠٥٥٣١'>فَهُوَ أَنْ يُوْقِعَ أَمْرًا يَقَعُ بِكَ فَلَا تَأْمَنُهُ فِي حَاْلِكَ
  الَّتِي تَكَلَّمْتَ فِيْهَا أَنْ يُوْقِعَ أَمْرًا</مقطع>
  <مقطع هوية='٦٦٩٥٢'>وَأَمَا <حرف>خَاْفَهُ</حرف></مقطع>
  <مقطع هوية='٧٩٥٤٧'>فَقَدْ يَكُوْنُ وَهُوَ لَا يَتَوَقَّعُ مِنْهُ فِي تِلْكَ الْحَاْلِ شَيْئًا</مقطع>

  <رأس/>
  <مقطع هوية='٤٧٣٥١'>وَأَمَّا <تمثيل>تَخَوَّنَتْهُ الْأَيَّاْمُ</تمثيل></مقطع>
  <مقطع هوية='٦٢٥٥٤'>فَهُوَ <تمثيل>تَنَقَّصَتْهُ</تمثيل></مقطع>
  <مقطع هوية='٤١٠٤٠'>وَلَيْسَ فِي <تمثيل>تَخَوَّنَتْهُ</تمثيل> مِنْ هَذِهِ الْمَعَاْنِي شَيْءً</مقطع>
  <مقطع هوية='٥٢٥٨٧'>كَمَا لَمْ يَكُنْ فِي <تمثيل>تَهَيَّبَهُ</تمثيل></مقطع>

  <رأس/>
  <مقطع هوية='٧٤٠٩٩'>وَأَمَّا <تمثيل>يَتَسَمَّعُ</تمثيل>
  وَ<تمثيل>يَتَحَفَّظُ</تمثيل> فَهُوَ <تمثيل>يَتَبَصَّرُ</تمثيل></مقطع>
  <مقطع هوية='٨٠٥٨٤'>وَهَذِهِ الْأَشْيَاْءُ نَحْوُ <تمثيل>يَتَجَرَّعُ</تمثيل>
  وَ<تمثيل>يَتَفَوَّقُ</تمثيل> لِأَنَّهَا فِي مُهْلَةٍ</مقطع>
  <مقطع هوية='١٧٨٣٧'>وَمِثْلُ ذٰلِكَ <تمثيل>تَخَيَّرَهُ</تمثيل></مقطع>
  <مقطع هوية='٩٤٧٤١'>وَأَمَّا <تمثيل>التَّعَمُّجُ</تمثيل>
  وَ<تمثيل>التَّعَمُّقُ</تمثيل> فَنَحْوٌ مِنْ هٰذَا</مقطع>
  <مقطع هوية=''>وَ<تمثيل>التَّدَخُّلُ</تمثيل> مِثْلُهُ لِأَنَّهُ عَمَلٌ بَعْدَ عَمَلٍ فِي مُهْلَةٍ</مقطع>

  <رأس/>
  <مقطع هوية='٤٠٧١٦'>وَأَمَّا <تمثيل>تَنَجَّزَ حَوَاْئِجَهُ</تمثيل>
  وَ<تمثيل>اسْتَنْجَزَ</تمثيل></مقطع>
  <مقطع هوية=''>فَهُوَ بِمَنْزِلَةِ <تمثيل>تَيَقَّنَ</تمثيل> وَ<تمثيل>اسْتَيْقَنَ</تمثيل> فِي شَرِكَةِ <مثال>اسْتَفْعَلْتُ</مثال></مقطع>
  <مقطع هوية='٥٣٢٦٨'>فَالِاسْتِثْبَاْتُ وَالتّقَعُّدُ وَالتَّنَقُّصُ وَالتَّنَجُّزُ
  وَهٰذَا النَّحْوُ</مقطع>
  <مقطع هوية=''>كُلُّهُ فِي مُهْلَةٍ وَعَمَلٍ بَعْدَ عَمَلٍ</مقطع>
  <مقطع هوية=''>وَقَدْ بَيَّنَّا مَا لَيْسَ مِثْلَهُ فِي <مثال>تَفَعَّلَ</مثال></مقطع>

