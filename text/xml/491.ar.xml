<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-٢٧٨"
     درنبورج="٢-٣٠٣"
     البكاء="٥-٤٧٨"
     هارون="٤-١٦١"
     يعقوب="٤-٢٧٥"
     رقم="٤٩١">

  <عنوان>
    <مقطع هوية='٣٤٥١٧'>هٰذَا بَاْبُ مَا تَلْحَقُهُ الْهَاْءُ لِتُبَيِّنَ الْحَرَكَةَ</مقطع>
    <مقطع هوية='٨٩٩٧٩'>مِنْ غَيْرِ مَا ذَكَرْنَا مِنْ بَنَاْتِ الْيَاْءِ وَالْوَاْوِ
    الَّتِي حُذِفَ أَوَاْخِرُهَا</مقطع>
    <مقطع هوية='٨٠٢٢٩'>وَلَكِنَّهَا تُبَيِّنُ حَرَكَةَ أَوَاْخِرِ الْحُرُوْفِ الَّتِي لَمْ يَذْهَبْ بَعْدَهَا شَيْءٌ</مقطع>
  </عنوان>

  <رأس/>
  <مقطع هوية='٥٩٥٧٠'>فَمِنْ ذٰلِكَ النُّوْنَاْتُ الَّتِي لَيْسَتْ بِحُرُوْفِ إِعْرَاْبٍ</مقطع>
  <مقطع هوية='٤٤٧١٩'>وَلَكِنَّهَا نُوْنُ الِاثْنَيْنِ وَالْجَمِيْعِ</مقطع>
  <مقطع هوية='٦٢٣٨٩'>وَكَاْنَ هٰذَا أَجْدَرَ أَنْ تُبَيَّنَ حَرَكَتُهُ</مقطع>
  <مقطع هوية='٦٢١٢١'>حَيْثُ كَاْنَ مِنْ كَلَاْمِهِمْ أَنْ يُبَيِّنُوْا حَرَكَةَ مَا كَاْنَ قَبْلَهُ مُتَحَرِّكًا</مقطع>
  <مقطع هوية='١١٢٩٢'>مِمَّا لَمْ يُحْذَفْ مِنْ آخِرِهِ شَيْءٌ</مقطع>
  <مقطع هوية='٩٣٧٩٢'>لِأَنَّ مَا قَبْلَهُ مُسَكَّنٌ</مقطع>
  <مقطع هوية='٠٢٥٨٩'>فَكَرِهُوْا أَنْ يَسْكُنَ وَيَسْكُنُ مَا قَبْلَهُ</مقطع>
  <مقطع هوية='١٨٤٥٢'>وَذٰلِكَ إِخْلَاْلٌ بِهِ</مقطع>
  <مقطع هوية='٣٤٠٧٥'>وَذٰلِكَ <قول هوية='٠٦٠٧٦'>هُمَا ضَاْرِبَاْنِهْ</قول></مقطع>
  <مقطع هوية='٣١٣٩٩'>وَ<قول هوية='٤٨٤١٠'>هُمْ مُسْلِمُوْنَهْ</قول></مقطع>
  <مقطع هوية='٨٧٧٩٧'>وَ<قول هوية='٠٣٣٢٢'>هُمْ قَاْئِلُوْنَهْ</قول></مقطع>

  <رأس/>
  <مقطع هوية='٤٦٤١٤'>وَمِثْلُ ذٰلِكَ <حرف>هُنَّهْ</حرف> وَ<حرف>ضَرَبْتُنَّهْ</حرف>
  وَ<حرف>ذَهَبَتُنَّهْ</حرف></مقطع>
  <مقطع هوية='٠٢٧٤٨'>فَعَلُوْا ذٰلِكَ لِمَا ذَكَرْتُ لَكَ</مقطع>
  <مقطع هوية='٩٠٧٢٨'>وَمَعَ ذٰلِكَ أَيْضًا أَنَّ النُّوْنَ خَفِيَّةٌ</مقطع>
  <مقطع هوية='١١٠٩٦'>فَذٰلِكَ أَيْضًا مِمَّا يُؤَكِّدُ التَّحْرِيْكَ</مقطع>
  <مقطع هوية='٠٥٤٤٦'>إِذْ كَاْنَ يُحَرَّكُ مَا هُوَ أَبْيَنُ مِنْهَا</مقطع>
  <مقطع هوية='٠٧٤٥٤'>وَسَتَرَى ذٰلِكَ وَمَا حُرِّكَ وَمَا قَبْلَهُ مُتَحَرِّكٌ إِنْ شَاْءَ اللهُ</مقطع>

  <رأس/>
  <مقطع هوية='١٥٥٧٩'>وَمِثْلُ ذٰلِكَ <حرف>أَيْنَهْ</حرف> تُرِيْدُ <حرف>أَيْنَ</حرف></مقطع>
  <مقطع هوية='٧٦٦٣٧'>لِأَنَّهَا نُوْنٌ قَبْلَهَا سَاْكِنٌ</مقطع>
  <مقطع هوية='١٠٥٧١'>وَلَيْسَتْ بِنُوْنٍ تُغَيَّرُ لِلْإِعْرَاْبِ</مقطع>
  <مقطع هوية='١٠٣٣٢'>وَلٰكِنَّهَا مَفْتُوْحَةٌ عَلَى كُلِّ حَاْلٍ</مقطع>
  <مقطع هوية='٨٩١٦٤'>فَأُجْرِيَتْ ذٰلِكَ الْمُجْرَى</مقطع>

  <رأس/>
  <مقطع هوية='٤٦٨٤٥'>وَمِثْلُ ذٰلِكَ قَوْلُهُمْ <حرف>ثَمَّهْ</حرف></مقطع>
  <مقطع هوية='٠٥٨٢٢'>لِأَنَّ فِي هٰذَا الْحَرْفِ مَا فِي <حرف>أَيْنَ</حرف></مقطع>
  <مقطع هوية='٩٠٢٧٢'>أَنَّ مَا قَبْلَهُ سَاْكِنٌ</مقطع>
  <مقطع هوية='٥٨١٥٨'>وَهِيَ خَفِيَّةٌ كَالنُّوْنِ</مقطع>
  <مقطع هوية='٥٠٦٨٩'>وَهِيَ أَشْبَهُ الْحُرُوْفِ بِهَا فِي الصَّوْتِ</مقطع>
  <مقطع هوية='٨٨٨٦٧'>فَلِذٰلِكَ كَاْنَتْ مِثْلَهَا فِي الْخَفَاْءِ</مقطع>
  <مقطع هوية='١٥٤٣٢'>وَنُبَيِّنُ ذٰلِكَ فِي الْإِدْغَاْمِ</مقطع>

  <رأس/>
  <مقطع هوية='٣٢٦٣٣'>وَمِثْلُ ذٰلِكَ قَوْلُهُمْ <حرف>هَلَّمَهْ</حرف>
  يُرِيْدُ <حرف>هَلُمَّ</حرف></مقطع>

  <مقطع هوية='٩٣٦١٧'>قَاْلَ الرَّاْجِزُ</مقطع>
  <شاهدة هوية='٦٣١٠٢'>
    <بيت>
      <مصراع>يَا أَيُّهَا النَّاْسُ أَلَا <ثبات>هَلُمَّهْ</ثبات></مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='١٣٧١٦'> وَإِنَمَا يُرِيْدُ <حرف>هَلُمَّ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٦١٤١٩'>وَغَيْرُ هَؤُلَاْءِ مِنَ الْعَرَبِ وَهُمْ كَثِيْرٌ</مقطع>
  <مقطع هوية='٦٣٥١٨'>لَا يُلْحِقُوْنَ الْهَاْءَ فِي الْوَقْفِ</مقطع>
  <مقطع هوية='٩٤٨٤٢'>وَلَا يُبَيِّنُوْنَ الْحَرَكَةَ</مقطع>
  <مقطع هوية='٩١١٧١'>لِأَنَّهُمْ لَمْ يَحْذِفُوْا شَيْئًا</مقطع>
  <مقطع هوية='٩٦٨٧٦'>يَلْزَمُ هٰذَا الِاسْمَ فِي كَلَاْمِهِمْ فِي هٰذَا الْمَوْضِعِ</مقطع>
  <مقطع هوية='٥٩١٥٥'>كَمَا فَعَلُوْا ذٰلِكَ فِي بَنَاْتِ الْيَاْءِ وَالْوَاْوِ</مقطع>

  <رأس/>
  <مقطع هوية='٨٣٣٠٤'>وَجَمِيْعُ هٰذَا إِذَا كَاْنَ بَعْدَهُ كَلَاْمٌ ذَهَبَتْ مِنْهُ الْهَاْءُ</مقطع>
  <مقطع هوية='٦٦٤٢٨'>لِأَنَّهُ قَدُ اسْتُغْنِيَ عَنْهَا</مقطع>
  <مقطع هوية='٦٥١٤١'>وَإِنَّمَا احْتَاْجَ إِلَيْهَا فِي الْوَقْفِ</مقطع>
  <مقطع هوية='٦٣٦٧٠'>لِأَنَّهُ لَا يَسْتَطِيْعُ أَنْ يُحَرِّكَ مَا يَسْكُتُ عِنْدَهُ</مقطع>

  <رأس/>
  <مقطع هوية='٧٧٥٨٦'>وَمِثْلُ مَا ذَكَرْتُ لَكَ قَوْلُ الْعَرَبِ <حرف>إِنَّهْ</حرف></مقطع>
  <مقطع هوية='٣٠٥١٠'>وَهُمْ يُرِيْدُوْنَ <حرف>إِنَّ</حرف> وَمَعْنَاْهَا <حرف>أَجَلْ</حرف></مقطع>

  <مقطع هوية='٨٧٩٤٧'>وَقَاْلَ</مقطع>
  <شاهدة هوية='٣٢٢٣٠'>
    <بيت>
      <مصراع>وَيَقُلْنَ شَيْبٌ قَدْ عَلَاْ</مصراع>
      <مصراع>كَ وَقَدْ كَبِرْتَ فَقُلْتُ <ثبات>إِنَّهْ</ثبات></مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٠٠٥٦٢'>وَمِثْلُ نُوْنِ الْجَمِيْعِ قَوْلُهُمْ <حرف>اعْلَمَنَّهْ</حرف></مقطع>
  <مقطع هوية='٣٧٣٦٢'>لِأَنَّهَا نُوْنٌ زَاْئِدَةٌ وَلَيْسَتْ بِحَرْفِ إِعْرَاْبٍ وَقَبْلَهَا حَرْفٌ سَاْكِنٌ</مقطع>
  <مقطع هوية='٢٧٣٤٥'>فَصَاْرَ هٰذَا الْحَرْفُ بِمَنْزِلَةِ <حرف>هُنَّ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٠٢٥٠٠'>وَقَاْلُوْا فِي الْوَقْفِ
  <حرف>كَيْفَهْ</حرف> وَ<حرف>لَيْتَهْ</حرف> وَ<حرف>لَعَلَّهْ</حرف></مقطع>
  <مقطع هوية='٦٤٣٤٤'>فِي <حرف>كَيْفَ</حرف> وَ<حرف>لَيْتَ</حرف> وَ<حرف>لَعَلَّ</حرف></مقطع>
  <مقطع هوية='٤٢٣٤٤'>لَمَّا لَمْ يَكُنْ حَرْفًا يَتَصَرَّفُ لِلْإِعْرَاْبِ</مقطع>
  <مقطع هوية='٩٦٦٠٧'>وَكَاْنَ مَا قَبْلَهَا سَاْكِنًا</مقطع>
  <مقطع هوية='٠١٨٦٥'>جَعَلُوْهَا بِمَنْزِلَةِ مَا ذَكَرْنَا</مقطع>

  <رأس/>
  <مقطع هوية='٢٣٢٢٩'>وَزَعَمَ <سند>الْخَلِيْلُ</سند>
  أَنَّهُمْ يَقُوْلُوْنَ <حرف>انْطَلَقْتُهْ</حرف> يُرِيْدُوْنَ <حرف>انْطَلَقْتُ</حرف></مقطع>
  <مقطع هوية='٤٤٩٨٠'>لأَنَّهَا لَيْسَتْ بِتَاْءِ إِعْرَاْبٍ وَمَا قَبْلَهَا سَاْكِنٌ</مقطع>

  <رأس/>
  <مقطع هوية='٢٥٣٨١'>وَمِمَّا أُجْرِيَ مَجْرَى <حرف>مُسْلِمُوْنَهْ</حرف></مقطع>
  <مقطع هوية='٤٥٢٦٥'>عَلَاْمَةُ الْمُضْمَرِ الَّتِي هِيَ يَاْءٌ وَقَبْلَهَا أَلِفٌ أَوْ يَاْءٌ</مقطع>
  <مقطع هوية='٥٧٧٢٥'>لِأَنَّهَا جَمَعَتْ أَنَّهَا خَفِيَّةٌ وَأَنَّ قَبْلَهَا سَاْكِنًا</مقطع>
  <مقطع هوية='١٣٣٤١'>فَأُجْرِيَتْ مَجْرَى <حرف>مُسْلِمَاْنِهْ</حرف> وَ<حرف>مُسْلِمُوْنَهْ</حرف> وَ<حرف>نَعْلَيْنِهْ</حرف></مقطع>
  <مقطع هوية='٣٧٨٠٠'>وَذٰلِكَ قَوْلُكَ <حرف>غُلَاْمَاْيَهْ</حرف>
  وَ<حرف>غُلَاْمَيَّهْ</حرف> وَ<حرف>عَصَاْيَهْ</حرف> وَ<حرف>بُشِرَاْيَهْ</حرف>
  وَ<حرف>يَا قَاْضِيَّهْ</حرف></مقطع>

