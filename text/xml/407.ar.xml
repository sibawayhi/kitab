<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-١٥٨"
     درنبورج="٢-١٦١"
     البكاء="٥-٢٣٣"
     هارون="٣-٥٢٩"
     يعقوب="٤-١٣"
     رقم="٤٠٧">

  <عنوان>
    <مقطع هوية='٣٠٨٧٣'>هٰذَا بَاْبُ مَا لَا تَجُوْزُ فِيْهِ نُوْنٌ خَفِيْفَةٌ وَلَا ثَقِيْلَةٌ</مقطع>
  </عنوان>

  <مقطع هوية='٤٠٥٩٦'>وَذٰلِكَ الْحُرُوْفُ الَّتِي لِلْأَمْرِ وَالنَّهْيِ وَلَيْسَتْ بِفِعْلٍ</مقطع>
  <مقطع هوية='٨٦٩٥٨'>وَذٰلِكَ نَحْوُ <حرف>إِيْهٍ</حرف> وَ<حرف>صَهْ</حرف> وَ<حرف>مَهْ</حرف> وَأَشْبَاْهُهَا</مقطع>
  <مقطع هوية='٠٢٥٥٣'>وَ<حرف>هَلُمَّ</حرف> فِي لُغَةِ أَهْلِ الْحِجَاْزِ كَذٰلِكَ</مقطع>
  <مقطع هوية='٠٢١٩١'>أَلَا تَرَاْهُمْ جَعَلُوْهَا لِلْوَاْحِدِ وَالِاثْنَيْنِ وَالْجَمِيْعِ
  وَالذَّكَرِ وَالْأُنْثَى سَوَاْءً</مقطع>
  <مقطع هوية='٢٦٨٤٥'>وَزُعِمَ أَنَّهَا <حرف>لُمَّ</حرف> أَلْحَقْتَهَا هَاْءً لِلتَّنْبِيْهِ فِي اللُّغْتَيْنَ</مقطع>
  <مقطع هوية='٥٤٦١١'>وَقَدْ تَدْخُلُ الْخَفِيْفَةُ وَالثَّقِيْلَةُ <!-- فِي هَلُمْ --> فِي لُغَةِ بَنِي تَمِيْمٍ</مقطع>
  <مقطع هوية='٩٠٨٧٢'>لِأَنَّهَا عِنْدَهُمْ بِمَنْزِلَةِ <حرف>رُدَّو</حرف> وَ<حرف>رُدَّا</حرف>
  وَ<حرف>رُدِّي</حرف> وَ<حرف>ارْدُدْنَ</حرف></مقطع>
  <مقطع هوية='١٣٤٣٠'>كَمَا تَقُوْلُ <حرف>هَلُمَّ</حرف> وَ<حرف>هَلُمَّا</حرف>
  وَ<حرف>هَلُمِّي</حرف> وَ<حرف>هَلْمُمْنَ</حرف></مقطع>
  <مقطع هوية='٦٧١٨٧'>وَالْهَاْءُ فَضْلٌ</مقطع>
  <مقطع هوية='٤٢٠٨٩'>إِنَّمَا هِيَ هَا الَّتِي لِلتَّنْبِيْهِ</مقطع>
  <مقطع هوية='٦٥٤٨٤'>وَلَكِنَّهُمْ حَذَفُوْا الْأَلِفَ لِكَثْرَةِ اسْتِعْمَاْلِهِمْ هٰذَا فِي كَلَاْمِهِمْ</مقطع>

  <التحرير>
