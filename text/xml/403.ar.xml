<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-١٥٣"
     درنبورج="٢-١٥٦"
     البكاء="٥-٢٢٥"
     هارون="٣-٥١٨"
     يعقوب="٤-٣"
     رقم="٤٠٣">

  <عنوان>
    <مقطع هوية='٠٨٥٧٦'>هٰذَا بَاْبُ أَحْوَاْلِ الْحُرُوْفِ الَّتِي قَبْلَ النُّوْنِ الْخَفِيْفَةِ وَالثَّقِيْلَةِ</مقطع>
  </عنوان>

  <مقطع هوية='٩٠٨١٨'>اعْلَمْ أَنَّ فِعْلَ الْوَاْحِدِ</مقطع>
  <مقطع هوية='٨١٦٩٢'>إِذَا كَاْنَ مَجْزُوْمًا فَلَحِقَتْهُ الْخَفِيْفَةُ وَالثَّقِيْلَةُ</مقطع>
  <مقطع هوية='٤٦٨٦٣'>حَرَّكْتَ الْمَجْزُوْمَ وَهُوَ الْحَرْفُ الَّذِي أَسْكَنْتَ لِلْجَزْمِ</مقطع>
  <مقطع هوية='٣٢٦٢٢'>لأَنَّ الْخَفِيْفَةَ سَاْكِنَةٌ</مقطع>
  <مقطع هوية='٩٧٠٢٦'>وَالثَّقِيْلَةَ نُوْنَاْنِ الْأُوْلَى مِنْهُمَا سَاْكِنَةٌ</مقطع>
  <مقطع هوية='٧١٧٠٥'>وَالْحَرَكَةُ فَتْحَةٌ</مقطع>
  <مقطع هوية='٦٥٣٦١'>وَلَمْ يَكْسِرُوْا فَيَلْتَبِسَ الْمُذَكَّرُ بِالْمُؤَنَّثِ</مقطع>
  <مقطع هوية='٩٤٤٣٩'>وَلَمْ يَضُمُّوْا فَيَلْتَبِسَ الْوَاْحِدُ بِالْجَمِيْعِ</مقطع>
  <مقطع هوية='١٣٥٠٥'>وَذٰلِكَ قَوْلُكَ <قول هوية='٣٨٣٩٣'>اعْلَمَنْ ذٰلِكَ</قول>
  وَ<قول هوية='٢٢٥٨١'>أَكْرِمَنْ زَيْدًا</قول> وَ<قول هوية='٣٥٨٢٦'>إِمَّا تُكْرِمَنْهُ أُكْرِمْهُ</قول></مقطع>

  <رأس/>
  <مقطع هوية='٢٧٢٧١'>وَإِذَا كَاْنَ فِعْلُ الْوَاْحِدِ مَرْفُوْعًا</مقطع>
  <مقطع هوية='٦٧٦٦٢'>ثُمَّ لَحِقَتْهُ النُّوْنُ</مقطع>
  <مقطع هوية='٥٢٤٠٤'>صَيَّرْتَ الْحَرْفَ الْمَرْفُوْعَ مَفْتُوْحًا
  لِئَلَّا يَلْتَبِسَ الْوَاْحِدُ بِالْجَمِيْعِ</مقطع>
  <مقطع هوية='٢٧٧٣٤'>وَذٰلِكَ قَوْلُكَ <قول هوية='٧٤٦٥١'>هَلْ تَفْعَلَنْ ذَاْكَ</قول> وَ<قول هوية='٤٣٠٩٧'>هَلْ تَخْرُجَنْ يَا زَيْدُ</قول></مقطع>

  <رأس/>
  <مقطع هوية='٠٢٦٨٧'>وَإِذَا كَاْنَ فِعْلُ الِاثْنَيْنِ مَرْفُوْعًا</مقطع>
  <مقطع هوية='٠٨٧٦٩'>وَأَدْخَلْتَ النُّوْنَ الثَّقِيْلَةَ</مقطع>
  <مقطع هوية='٧٨٥٤٩'>حَذَفْتَ نُوْنَ الِاثْنَيْنِ لِاجْتِمَاْعِ النُّوْنَاْتِ</مقطع>
  <مقطع هوية='٠٥٨٠٤'>وَلَمْ تَحْذِفْ الْأَلِفَ لِسُكُوْنِ النُّوْنِ</مقطع>
  <مقطع هوية='٩٦٩٩٦'>لِأَنَّ الْأَلِفَ تَكُوْنُ قَبْلَ السَّاْكِنِ الْمُدْغَمِ</مقطع>
  <مقطع هوية='١٣٣٧٨'>وَلَوْ أَذْهَبْتَهَا لَمْ يُعْلَمْ أَنَّكَ تُرِيْدُ الِاثْنَيْنِ</مقطع>
  <مقطع هوية='٠٣٢٠٣'>وَلَمْ تَكُنْ الْخَفِيْفَةُ هٰهُنَا</مقطع>
  <مقطع هوية='٨٦١٠٤'>لِأَنَّهَا سَاْكِنَةٌ لَيْسَتْ مَدْغَمَةً فَلَا تَثْبُتُ مَعَ الْأَلِفِ</مقطع>
  <مقطع هوية='٢٧١٦٢'>وَلَا يَجُوْزُ حَذْفُ الْأَلِفِ فَيَلْتَبِسَ بِالْوَاْحِدِ</مقطع>

  <رأس/>
  <مقطع هوية='١٢٢٤١'>وَإِذَا كَاْنَ فِعْلُ الْجَمِيْعِ مَرْفُوْعًا</مقطع>
  <مقطع هوية='٢٣١٨٦'>ثُمَّ أَدْخَلْتَ فِيْهِ النُّوْنَ الْخَفِيْفَةَ أَوِ الثَّقِيْلَةَ</مقطع>
  <مقطع هوية='٣٨٦٣٨'>حَذَفْتَ نُوْنَ الرَّفْعِ</مقطع>
  <مقطع هوية='٧٨٠١٣'>وَذٰلِكَ قَوْلُكَ <قول هوية='٢٠٣٧٤'>لَتَفْعَلُنَّ ذَاْكَ</قول>
  وَ<قول هوية='٥٧٥٠٢'>لَتَذْهَبُنَّ</قول></مقطع>
  <مقطع هوية='٩٦٣٩١'>لأَنَّهُ اجْتَمَعَتْ فِيْهِ ثَلاْثُ نُوْنَاْتٍ</مقطع>
  <مقطع هوية='٦٣٧٠٨'>فَحَذَفُوْهَا اسْتِثْقَاْلًا</مقطع>
  <مقطع هوية='٦٤٩٠٩'>وَتَقُوْلُ <قول هوية='٢٤٧٧٣'>هَلْ تَفْعَلُنَّ ذَاْكَ</قول></مقطع>
  <مقطع هوية='٨٠١٣٤'>تَحْذِفُ نُوْنَ الرَّفْعِ لأَنَّكَ ضَاْعَفْتَ النُّوْنَ</مقطع>
  <مقطع هوية='٦٤٤٦٩'>وَهُمْ يَسْتَثْقِلُوْنَ التَّضْعِيْفَ</مقطع>
  <مقطع هوية='٢٩٣٨١'>فَحَذَفُوْهَا إِذْ كَاْنَتْ تُحْذَفُ</مقطع>
  <مقطع هوية='٧٦١٤٥'>وَهُمْ فِي ذَا الْمَوْضِعِ أَشَدُّ اسْتِثْقَاْلًا لِلنُّوْنَاْتِ</مقطع>
  <مقطع هوية='٨٧٩٤٢'>وَقَدْ حَذَفُوْهَا فِيْمَا هُوَ أَشَدُّ مِنْ ذَا</مقطع>
  <مقطع هوية='٨٣٧١٥'>بَلَغَنَا أَنَّ بَعْضَ الْقُرَّاْءِ قَرَأَ
  <آية هوية='٥٥٦٣٨' سورة="٦" آية="٨٠">أَتُحَــٰۤـجُّوٓنِّي</آية></مقطع>
  <مقطع هوية='٨٥٤٦٥'>وَكَاْنَ يَقْرَأُ
  <آية هوية='٦٨٤٩٥' سورة="١٥" آية="٥٤">فَبِمَ تُبَشِّرُوْنَ</آية></مقطع>
  <مقطع هوية='٥٢٧٨٧'>وَهِيَ قِرَاْءَةِ أَهْلِ الْمَدِيْنَةِ</مقطع>
  <مقطع هوية='٨٤٣٧٩'>وَذٰلِكَ لِأَنَّهُمِ اسْتَثْقَلُوْا التَّضْعِيْفَ</مقطع>

  <مقطع هوية='٥٧٠٢٩'>وَقَاْلَ <شاعر>عَمْرُو بْنُ مَعْدِيْكَرِبَ</شاعر></مقطع>
  <شاهدة هوية='١٤٧٤٤' شاعر="عَمْرُو بْنُ مَعْدِيْكَرِبَ">
    <بيت>
      <مصراع>تَرَاْهُ كَالثَّغَاْمِ يُعَلُّ مِسْكًا</مصراع>
      <مصراع>يَسُوْءُ الْفَاْلِيَاْتِ إِذَا <ثبات>فَلَيْنِيِ</ثبات></مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٣٢٨٩١'>يْرِيْدُ <حرف>فَلَيْنَنِي</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٠١٣١٦'>وَاعْلَمْ أَنَّ الْخَفِيْفَةَ وَالثّقِيْلَةَ إِذَا جَاْءَتْ بَعْدَ عَلَاْمَةِ إِضْمَاْرٍ</مقطع>
  <مقطع هوية='٩٢٧٦٤'>تَسْقُطُ إِذَا كَاْنَتْ بَعْدَهَا أَلِفٌ خَفِيْفَةٌ أَوْ أَلِفٌ وَلَاْمٌ</مقطع>
  <مقطع هوية='٦١٣٧٧'>فَإِنَّهَا تَسْقُطُ أَيْضًا مَعَ النُّوْنِ الْخَفِيْفَةِ وَالثَّقِيْلَةِ</مقطع>
  <مقطع هوية='٦٢٣٩٢'>وَإِنَّمَا سَقَطَتْ لِأَنَّهَا لَمْ تُحَرَّكْ</مقطع>
  <مقطع هوية='٥٨١١٣'>فَإِذَا لَمْ تُحَرَّكْ حُذِفَتْ</مقطع>
  <مقطع هوية='٢٠٨٠٥'>فَتُحْذَفُ لِئَلَّا يَلْتَقِيَ سَاْكِنَاْنِ</مقطع>
  <مقطع هوية='٣٧٤٢٨'>وَذٰلِكَ قَوْلُكَ لِلْمَرْأَةِ <قول هوية='٤٤٤٣١'>اضْرِبِنَّ زَيْدًا</قول>
  وَ<قول هوية='٧٦٣٩٠'>أَكْرِمِنَّ عَمْرًا</قول></مقطع>
  <مقطع هوية='١٣٨١٦'>تَحْذِفُ الْيَاْءَ لِمَا ذَكَرْتُ لَكَ</مقطع>
  <مقطع هوية='٤٤٥٨٧'>وَ<قول هوية='٠٤٣٧٤'>لَتَضْرِبِنَّ زَيْدًا</قول> وَ<قول هوية='٧٤٣٥٧'>لَتُكْرِمِنَّ عَمْرًا</قول></مقطع>
  <مقطع هوية='٣١٠٩٨'>لِأَنَّ نُوْنَ الرَّفْعِ تَذْهَبُ</مقطع>
  <مقطع هوية='٣١٢٨١'>فَتَبْقَى يَاْءً كَالْيَاْءِ الَّتِي فِي <حرف>اضْرِبِي</حرف>
  وَ<حرف>أَكْرِمِي</حرف></مقطع>
  <مقطع هوية='٥٣٨٣٨'>وَمِنْ ذٰلِكَ قَوْلُهُمْ لِلْجَمِيْعِ <قول هوية='١٣٠٩٧'>اضْرِبُنَّ زَيْدًا</قول>
  وَ<قول هوية='٩١٩٩٧'>أَكْرِمُنَّ عَمْرًا</قول>
  وَ<قول هوية='٦٦٠٦٦'>لَتُكْرِمُنَّ بِشْرًا</قول></مقطع>
  <مقطع هوية='١٨٨٧٦'>لِأَنَّ نُوْنَ الرّفْعِ تَذْهَبُ</مقطع>
  <مقطع هوية='٩٢٦٤٧'>فَتَبْقَى وَاْوٌ كَوَاْوِ <حرف>ضَرَبُوْا</حرف> وَ<حرف>أَكْرَمُوْا</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٥٦١٩١'>فَإِذَا جَاْءَتْ بَعْدَ عَلَاْمَةِ مُضْمَرٍ</مقطع>
  <مقطع هوية='١٣٣٨٣'>تَتَحَرَّكُ لِلأَلِفِ الْخَفِيْفَةِ أَوْ لِلأَلْفِ وَاللَّاْمِ حُرِّكَتْ لَهَا</مقطع>
  <مقطع هوية='٠٠٤٢٣'>وَكَاْنَتْ الْحَرَكَةُ هِيَ الْحَرَكَةُ الَّتِي تَكُوْنُ</مقطع>
  <مقطع هوية='٢٢٧٤٦'>إِذَا جَاْءَتْ الْأَلِفُ الْخَفِيْفَةُ أَوْ الْأَلِفُ وَاللَّاْمُ</مقطع>
  <مقطع هوية='٣٢٥٥٣'>لِأَنَّ عِلَّةَ حَرَكَتِهَا هٰهُنَا هِيَ الْعِلَّةُ الَّتِي ذَكَرْتُهَا ثَمَّ</مقطع>
  <مقطع هوية='٤٢٠١٩'>وَالْعِلَّةُ الْتِقَاْءُ السَّاْكِنَيْنِ</مقطع>
  <مقطع هوية='٩٥٤٢٤'>وَذٰلِكَ قَوْلُكَ <قول هوية='٦٩٣٨٥'>ارْضَوُنَّ زَيْدًا</قول> تُرِيْدُ الْجَمِيْعَ وَ<قول هوية='٢٨٩٣٦'>اخْشَوُنَّ زَيْدًا</قول></مقطع>
  <مقطع هوية='٣٩٥٧٥'>وَ<قول هوية='٥١٥٣٨'>اخْشَيِنَّ زَيْدًا</قول>
  وَ<قول هوية='٧٠٥٦٦'>ارْضَيِنَّ زَيْدًا</قول></مقطع>
  <مقطع هوية='٧٢٧٨٣'>فَصَاْرَ التَّحْرِيْكُ هُوَ التَّحْرِيْكُ الَّذِي يَكُوْنُ</مقطع>
  <مقطع هوية='٧٣٥١١'>إِذَا جَاْءَتْ الْأَلِفُ وَاللَّاْمُ أَوْ الْأَلِفُ الْخَفِيْفَةُ</مقطع>

