<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-٣٠٤"
     درنبورج="٢-٣٣٠"
     البكاء="٥-٥٣٥"
     هارون="٤-٢١٦"
     يعقوب="٤-٣٣٩"
     رقم="٥٠٨">

  <عنوان>
    <مقطع هوية='٨٧٦٥٩'>هٰذَا بَاْبُ عِدَّةِ مَا يَكُوْنُ عَلَيْهِ الْكَلِمُ</مقطع>
  </عنوان>

  <مقطع هوية='٤٥٤٩٨'>فَأَقَلُّ مَا تَكُوْنُ عَلَيْهِ الْكَلِمَةُ حَرْفٌ وَاْحِدٌ</مقطع>
  <مقطع هوية='٦٩٦٦٤'>وَسَأَكْتُبُ لَكَ مَا جَاْءَ عَلَى حَرْفٍ بِمَعْنَاْهُ إِنِ شَاْءَ اللهُ</مقطع>

  <رأس/>
  <مقطع هوية='٨٤٠٠٥'>أَمَّا مَا يَكُوْنُ قَبْلَ الْحَرْفِ الَّذِي يُجَاْءُ بِهِ لَهُ</مقطع>
  <مقطع هوية='٧٤٨٨٨'>فَالْوَاْوُ الَّتِي فِي قَوْلِكَ <قول هوية='٦٤٥٣٦'>مَرَرْتُ بِعَمْرٍو وَزَيْدٍ</قول></مقطع>
  <مقطع هوية='٤١١٣٩'>وَإِنَّمَا جِئْتَ بِالْوَاْوِ لِتَضُمَّ الْآخِرَ إِلَى الْأَوَّلِ وَتَجْمَعُهُمَا</مقطع>
  <مقطع هوية='١٩٧٨٣'>وَلَيْسَ فِيْهِ دَلِيْلٌ عَلَى أَنَّ أَحَدَهُمَا قَبْلَ الْآخَرِ</مقطع>

  <رأس/>
  <مقطع هوية='١٦٠٣٣'>وَالْفَاْءُ وَهِيَ تَضُمُّ الشَّيْءَ إِلَى الشَّيْءِ كَمَا فَعَلَتْ الْوَاْوُ</مقطع>
  <مقطع هوية='٩٠٤٢١'>غَيْرَ أَنَّهَا تَجْعَلُ ذٰلِكَ مُتَّسِقًا بَعْضُهُ فِي إِثْرِ بَعْضٍ</مقطع>
  <مقطع هوية='٣٧٤٨٥'>وَذٰلِكَ قَوْلُكَ <قول هوية='٥٤٦٢١'>مَرَرْتُ بِعَمْرٍو فَزَيْدٍ فَخَاْلِدٍ</قول></مقطع>
  <مقطع هوية='١٢٣٧٠'>وَ<قول هوية='٣٢٩٦٠'>سَقَطَ الْمَطَرُ بِمَكَاْنِ كَذَا وَكَذَا فَمَكَاْنِ كَذَا وَكَذَا</قول>
  </مقطع>
  <مقطع هوية='٠٤٧١٨'>وَإِنَّمَا يَقْرُو أَحَدُهُمَا بَعْدَ الْآخَرِ</مقطع>

  <رأس/>
  <مقطع هوية='٤٧٤٤٦'>وَكَاْفُ الْجَرِّ الَّتِي تَجِيْءُ لِلتَّشْبِيْهِ</مقطع>
  <مقطع هوية='٨٥٦١٢'>وَذٰلِكَ قَوْلُكَ <قول هوية='٤٦٣٧٧'>أَنْتَ كَزَيْدٍ</قول>
  </مقطع>

  <رأس/>
  <مقطع هوية='٧٩٣٩٦'>وَلَاْمُ الْإِضَاْفَةِ وَمَعْنَاْهَا الْمِلْكُ وَاسْتِحْقَاْقُ الشَّيْءِ</مقطع>
  <مقطع هوية='٩١٨٣٦'>أَلَا تَرَى أَنَّكَ تَقُوْلُ <قول هوية='٨٠٣١٢'>الْغُلَاْمُ لَكَ</قول> وَ<قول هوية='٧٠٧٣٢'>الْعَبْدُ لَكَ</قول>
  </مقطع>
  <مقطع هوية='٩٢٦٣٥'>فَيَكُوْنُ فِي مَعْنَى <قول هوية='٦٣٦٩٤'>هُوَ عَبْدُكَ</قول></مقطع>
  <مقطع هوية='٢٧٣٠٤'>وَ<قول هوية='٥٥٦٨٧'>هُوَ أَخٌ لَهُ </قول> فَيَصِيْرُ نَحْوَ <قول هوية='٠٩١١٣'>هُوَ أَخُوْكَ</قول>
  </مقطع>
  <مقطع هوية='٨٧٩٠٢'>فَيَكُوْنُ مُسْتَحِقًّا لِهٰذَا</مقطع>
  <مقطع هوية='٠٥٥٩١'>كَمَا يَكُوْنُ مُسْتَحِقًّا لِمَا يَمْلِكُ</مقطع>
  <مقطع هوية='١٥٥٠٧'>فَمَعْنَى هَذِهِ اللَّاْمِ مَعْنَى إِضَاْفَةِ الِاسْمِ</مقطع>
  <مقطع هوية='٦٨٤٣٠'>وَقَدْ بُيِّنَ ذٰلِكَ أَيْضًا فِي بَاْبِ النَّفْيِ</مقطع>

  <رأس/>
  <مقطع هوية='٧٧٢٢٥'>وَبَاْءُ الْجَرِّ إِنَّمَا هِيَ لِلْإِلْزَاْقِ وَالِاخْتِلَاْطِ</مقطع>
  <مقطع هوية='٤٩٩٠١'>وَذٰلِكَ قَوْلُكَ <قول هوية='١٨٧٧٣'>خَرَجْتُ بِزَيْدٍ</قول></مقطع>
  <مقطع هوية='٣٥٥٠٣'>وَ<قول هوية='٥١٤٨٠'>دَخَلْتُ بِهِ</قول></مقطع>
  <مقطع هوية='١٥٨٢٤'>وَ<قول هوية='٢٧٢٦٣'>ضَرَبْتُهُ بِالسَّوْطِ</قول> أَلْزَقْتَ ضَرْبَكَ إِيَّاْهُ بِالسَّوْطِ</مقطع>
  <مقطع هوية='١٠٣٢٨'>فَمَا اتَّسَعَ مِنْ هٰذَا فِي الْكَلَاْمِ فَهٰذَا أَصْلُهُ</مقطع>

  <رأس/>
  <مقطع هوية='٩٦٢٨٧'>وَالْوَاْوُ الَّتِي تَكُوْنُ لِلْقَسَمِ بِمَنْزِلَةِ الْبَاْءِ</مقطع>
  <مقطع هوية='٩٨٧٩٤'>وَذٰلِكَ قَوْلُكَ <قول هوية='٠٥٩٥٨'>وَاللهِ لَا أَفْعَلُ</قول></مقطع>

  <رأس/>
  <مقطع هوية='٥١٨٣٢'>وَالتَّاْءُ الَّتِي فِي الْقَسَمِ بِمَنْزِلَتِهَا وَهِيَ <قول هوية='٨٤٦٤١'>تَاللّٰهِ لَا أَفْعَلُ</قول>
  </مقطع>

  <رأس/>
  <مقطع هوية='٢٥٥١٨'>وَالسِّيْنُ الَّتِي فِي قَوْلِكَ <قول هوية='٤٢٦٣٥'>سَيَفْعَلُ</قول></مقطع>
  <مقطع هوية='٠١٧٧٠'>وَزَعَمَ <سند>الْخَلِيْلُ</سند> أَنَّهَا جَوَاْبُ <قول هوية='٤٨٦١٨'>لَنْ يَفْعَلَ</قول>
  </مقطع>

  <رأس/>
  <مقطع هوية='٤٤٦٥١'>وَالْأَلِفُ فِي الِاسْتِفْهَاْمِ</مقطع>

  <رأس/>
  <مقطع هوية='٣٣٦٥١'>وَلَاْمُ الْيَمِيْنِ الَّتِي فِي <حرف>لَأَفْعَلَّنَ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٦٦٩٦٣'>وَأَمَّا مَا جَاْءَ مِنْهُ بَعْدَ الْحَرْفِ الَّذِي جِيْءَ بِهِ لَهُ</مقطع>
  <مقطع هوية='٩٩٥٣١'>فَعَلَاْمَةُ الْإِضْمَاْرِ</مقطع>

  <رأس/>
  <مقطع هوية='٤٨٨٢١'>وَهِيَ الْكَاْفُ الَّتِي فِي <حرف>رَأَيْتُكَ</حرف> وَ<حرف>غُلَاْمُكَ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٩٩٢٥٥'>وَالتَّاْءُ الَّتِي فِي <حرف>فَعَلْتُ</حرف> وَ<حرف>ذَهَبْتُ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٢٥٤٣١'>وَالْهَاْءُ الَّتِي فِي <حرف>عَلَيْهِ</حرف> وَنَحْوِهَا</مقطع>

  <رأس/>
  <مقطع هوية='٥٥٤٨١'>وَقَدْ تَكُوْنُ الْكَاْفُ غَيْرَ اسْمٍ</مقطع>
  <مقطع هوية='٤٠٨٧٣'>وَلَكِنَّهَا تَجِيْءُ لِلْمُخَاْطَبَةِ</مقطع>
  <مقطع هوية='٢١٣٣٣'>وَذٰلِكَ نَحْوُ كَاْفِ <حرف>ذٰلِكَ</حرف></مقطع>
  <مقطع هوية='٨٧١٠٧'>فَالْكَاْفُ فِي هٰذَا بِمَنْزِلَةِ التَّاْءِ فِي قَوْلِكَ <حرف>فَعَلَتْ فُلَاْنَةُ</حرف> وَنَحْوِ ذٰلِكَ</مقطع>
  <مقطع هوية='٧٦٧٢٤'>وَالتَّاْءُ تَكُوْنُ بِمَنْزِلَتِهَا وَهِيَ الَّتِي فِي <حرف>أَنْتَ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٠٣٤٥٦'>وَاعْلَمْ أَنَّ مَا جَاْءَ فِي الْكَلَاْمِ عَلَى حَرْفٍ قَلِيْلٌ</مقطع>
  <مقطع هوية='٢٦٧٣١'>وَلَمْ يَشُذَّ عَلَيْنَا مِنْهُ شَيْءٌ إِلَّا مَا لَا بَاْلَ لَهُ إِنْ كَاْنَ شَذَّ</مقطع>
  <مقطع هوية='٤٤٣٧٨'>وَذٰلِكَ لِأَنَّهُ عِنْدَهُمْ إِجْحَاْفٌ</مقطع>
  <مقطع هوية='٩٦٠٩٨'>أَنْ يَذْهَبَ مِنْ أَقَلِّ الْكَلَاْمِ عَدَدًا حَرْفَاْنِ</مقطع>
  <مقطع هوية='٣٧٦٧٨'>وَسَنُبَيِّنُ ذٰلِكَ إِنْ شَاْءَ اللهُ</مقطع>

  <رأس/>
  <مقطع هوية='٢٩٧٧١'>وَاعْلَمْ أَنَّهُ لَا يَكُوْنُ اسْمٌ مَظْهَرٌ عَلَى حَرْفٍ أَبَدًا</مقطع>
  <مقطع هوية='٨٢٨٣٦'>لِأَنَّ الْمُظْهَرَ يُسْكَتُ عِنْدَهُ وَلَيْسَ قَبْلَهُ شَيْءٌ</مقطع>
  <مقطع هوية='٠١٥٧٥'>وَلَا يُلْحَقُ بِهِ شَيْءٌ</مقطع>
  <مقطع هوية='٨٨١٩٧'>وَلَا يُوْصَلُ إِلَى ذٰلِكَ بِحَرْفٍ</مقطع>
  <مقطع هوية='٠٨٧٩٠'>وَلَمْ يَكُوْنُوْا لَيُجْحِفُوْا بِالِاسْمِ</مقطع>
  <مقطع هوية='٦٩٨٥٨'>فَيَجْعَلُوْهُ بِمَنْزِلَةِ مَا لَيْسَ بِاسْمٍ وَلَا فِعْلٍ
  وَإِنَّمَا يَجِيْءُ لِمَعْنًى</مقطع>

  <رأس/>
  <مقطع هوية='٤٦٢٩٩'>وَالِاسْمُ أَبَدًا لَهُ مِنَ الْقُوَّةِ مَا لَيْسَ لِغَيْرِهِ</مقطع>
  <مقطع هوية='٥٢٠٤٥'>أَلَا تَرَى أَنَّكَ لَوْ جَعَلْتَ <حرف>فِي</حرف> وَ<حرف>لَوْ</حرف> وَنَحْوَهَا اسْمًا ثَقَّلْتَ</مقطع>
  <مقطع هوية='٨٣٦٥٨'>وَإِنَّمَا فَعَلُوْا ذٰلِكَ بِعَلَاْمَةِ الْإِضْمَاْرِ</مقطع>
  <مقطع هوية='٥٦٢٩٤'>حَيْثُ كَاْنَتْ لَا تَصَرَّفُ وَلَا تُذْكَرُ إِلَّا فِيْمَا قَبْلَهَا</مقطع>
  <مقطع هوية='٧٠٦٧٨'>فَأَشْبَهَتْ الْوَاْوَ وَنَحْوَهَا</مقطع>
  <مقطع هوية='٣٤٢٢٩'>وَلَمْ يَكُوْنُوْا لَيُخِلُّوْا بِالْمُظْهَرِ</مقطع>
  <مقطع هوية='٤٢٦٧٩'>وَهُوَ الْأَوَّلُ الْقَوِيُّ</مقطع>
  <مقطع هوية='٤٢٠٦٣'>إِذْ كَاْنَ ذٰلِكَ قَلِيْلًا فِي سِوَى الِاسْمِ الْمُظْهَرِ</مقطع>

  <رأس/>
  <مقطع هوية='٢٣٩٩٥'>وَلَا يَكُوْنُ شَيْءٌ مِنَ الْفِعْلِ عَلَى حَرْفٍ وَاْحِدٍ</مقطع>
  <مقطع هوية='٤٧٩٦٨'>لِأَنَّ مِنْهُ مَا يُضَاْرِعُ الِاسْمَ وَهُوَ يَتَصَرَّفُ وَيُبْنَى أَبْنِيَةً</مقطع>
  <مقطع هوية='٥٠٣٥٣'>وَهُوَ الَّذِي يَلِي الِاسْمَ</مقطع>
  <مقطع هوية='٠٥٧٠١'>فَلَمَّا قَرُبَ هٰذَا الْقُرْبَ لَمْ يُجْحَفُ بِهِ</مقطع>
  <مقطع هوية='١٩٨٢٩'>إِلَّا أَنَّ تُدْرِكَ الْفِعْلَ عِلَّةٌ مُطَّرِدَةٌ فِي كَلَاْمِهِمْ فِي مَوْضِعٍ وَاْحِدٍ</مقطع>
  <مقطع هوية='٩٩٠٠٥'>فَيَصِيْرَ عَلَى حَرْفٍ</مقطع>
  <مقطع هوية='٧٥٨٦٧'>فَإِذَا جَاْوَزْتَ ذٰلِكَ الْمَوْضِعَ رَدَدْتَ مَا حَذَفْتَ</مقطع>
  <مقطع هوية='٢٢٣٦٨'>وَلَمْ يَلْزَمْهَا أَنْ تَكُوْنَ عَلَى حَرْفٍ وَاْحِدٍ إِلَّا فِي ذٰلِكَ الْمَوْضِعِ</مقطع>
  <مقطع هوية='٧٦٤٣٦'>وَذٰلِكَ قَوْلُكَ <قول هوية='٠٣٦٣٨'>عِ كَلَاْمًا</قول></مقطع>
  <مقطع هوية='٩٩٩٩٦'>وَنَحْوُ <قول هوية='١٥٠١٢'>عِهْ</قول> وَ<قول هوية='١٠٨٧١'>شِهْ</قول></مقطع>
  <مقطع هوية='٢٨٩٢٨'>وَ<قول هوية='٧٩٠٨٧'>فِهْ</قول> مِنَ الْوِفَاْءِ</مقطع>
  <مقطع هوية='٦٨٣٣٦'>ثُمَّ الَّذِي يَلِي مَا يَكُوْنُ عَلَى حَرْفٍ مَا يَكُوْنُ عَلَى حَرْفَيْنِ</مقطع>
  <مقطع هوية='٦٩٢٣٨'>وَقَدْ تَكُوْنُ عَلَيْهِمَا الْأَسْمَاْءُ الْمُظْهَرَةُ الْمُتَمَكِّنَةُ وَالْأَفْعَاْلُ الْمُتَصَرِّفَةُ</مقطع>
  <مقطع هوية='٣٠٨٦٨'>وَذٰلِكَ قَلِيْلٌ لِأَنَّهُ إِخْلَاْلٌ عِنْدَهُمْ بِهِنَّ</مقطع>
  <مقطع هوية='٩٣٧٠٦'>لِأَنَّهُ حَذْفٌ مِنْ أَقَلِّ الْحُرُوْفِ عَدَدًا</مقطع>

  <رأس/>
  <مقطع هوية='٤٦٥٥٧'>فَمِنَ الْأَسْمَاْءِ الَّتِي وَصَفْتُ لَكَ <حرف>يَدٌ</حرف> وَ<حرف>دَمٌ</حرف> وَ<حرف>حِرٌ</حرف></مقطع>
  <مقطع هوية='٢٤٣٠٨'>وَ<حرف>سَتٌ</حرف> وَ<حرف>سَهٌ</حرف> يَعْنِي <حرف>الْأِسْتُ</حرف></مقطع>
  <مقطع هوية='٤٨٨٨٢'>وَ<حرف>دَدٌ</حرف> وَهُوَ اللهْوُ وَعِنْدَ بَعْضِهِمْ هُوَ الْحِيْنُ</مقطع>
  <مقطع هوية='٢٧٨٧٣'>فَإِذَا أَلْحَقْتَهَا الْهَاْءَ كَثُرَتْ</مقطع>
  <مقطع هوية='٣٧٩٣٣'>لِأَنَّهَا تَقْوَى وَتَصِيْرُ عِدَّتُهَا ثَلَاْثَةَ أَحْرُفٍ</مقطع>

  <رأس/>
  <مقطع هوية='٦٧٦٩٦'>وَأَمَّا مَا جَاْءَ مِنَ الْأَفْعَاْلِ فَـ<حرف>خُذْ</حرف> وَ<حرف>كُلْ</حرف> وَ<حرف>مُرْ</حرف></مقطع>
  <مقطع هوية='٤٩٥٣٣'>وَبَعْضُ الْعَرَبِ يَقُوْلُ <حرف>أُوْكُلْ</حرف> فَيَتِمُّ</مقطع>
  <مقطع هوية='١٢٩٦٨'>كَمَا أَنَّ بَعْضَهُمْ يَقُوْلُ فِي <حرف>غَدٍ</حرف> <حرف>غَدْوٌ</حرف></مقطع>
  <مقطع هوية='٥٠٠٧٥'>فَهٰذَا مَا جَاْءَ مِنَ الْأَفْعَاْلِ وَالْأَسْمَاْءِ عَلَى حَرْفَيْنِ</مقطع>
  <مقطع هوية='٨٧٤٤٣'>وَإِنْ كَاْنَ شَذَّ شَيْءٌ فَقَلِيْلٌ</مقطع>
  <مقطع هوية='٥٥٠٦٦'>وَلَا يَكُوْنُ مَنَ الْأَفْعَاْلِ شَيْءٌ عَلَى حَرْفَيْنِ إِلَّا مَا ذَكَرْتُ لَكَ</مقطع>
  <مقطع هوية='٤٢١٦٠'>إِلَّا أَنْ تَلْحَقَ الْفِعْلَ عِلَّةٌ مُطَّرِدَةٌ فِي كَلَاْمِهِمْ</مقطع>
  <مقطع هوية='٣٠٣٥٩'>فَتُصَيِّرَهُ عَلَى حَرْفَيْنِ فِي مَوْضِعٍ وَاْحِدٍ</مقطع>
  <مقطع هوية='١٦٥٨٨'>ثُمَّ إِذَا جَاْوَزْتَ ذٰلِكَ الْمَوْضِعَ رَدَدْتَ إِلَيْهِ مَا حَذَفْتَ مِنْهُ</مقطع>
  <مقطع هوية='٦٤٢٤٨'>وَذٰلِكَ قَوْلُكَ <حرف>قُلْ</حرف> وَ<حرف>إِنْ تَقِ أَقِهْ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٢٩٠٩٧'>وَمَا لَحِقَتْهُ الْهَاْءُ مِنَ الْحَرْفَيْنِ</مقطع>
  <مقطع هوية='٣٩٣٧٤'>أَقَلَُ مِمَّا فِيْهِ الْهَاْءُ مِنَ الثَّلَاْثَةِ</مقطع>
  <مقطع هوية='٧٢١٨٩'>لِأَنَّ مَا كَاْنَ عَلَى حَرْفَيْنِ</مقطع>
  <مقطع هوية='٧٩٥٦٤'>لَيْسَ بِشَيْءٍ مَعَ مَا هُوَ عَلَى ثَلَاْثَةِ أَحْرُفٍ</مقطع>
  <مقطع هوية='٦٨٣٦٦'>وَذٰلِكَ نَحْوُ <حرف>قُلَةٍ</حرف> وَ<حرف>ثُبَةٍ</حرف></مقطع>
  <مقطع هوية='٦٤٢٤٦'>وَ<حرف>لِثَةٍ</حرف> وَ<حرف>شِيَةٍ</حرف></مقطع>
  <مقطع هوية='٩٨٥٤٤'>وَ<حرف>شَفَةٍ</حرف> وَ<حرف>رِئَةٍ</حرف> وَ<حرف>سَنَةٍ</حرف></مقطع>
  <مقطع هوية='٨٢٠١٠'>وَ<حرف>زِنَةٍ</حرف> وَ<حرف>عِدَةٍ</حرف></مقطع>
  <مقطع هوية='٢٨٣٨١'>وَأَشْبَاْهُ ذٰلِكَ</مقطع>

  <رأس/>
  <مقطع هوية='٧٦٧٧٠'>وَلَا يَكُوْنُ شَيْءٌ عَلَى حَرْفَيْنِ صِفَةً</مقطع>
  <مقطع هوية='٤٦١٩٣'>حَيْثُ قَلَّ فِي الِاسْمِ وَهُوَ الْأَوَّلُ الْأَمْكَنُ</مقطع>

  <رأس/>
  <مقطع هوية='٣٧٧١١'>وَقَدْ جَاْءَ عَلَى حَرْفَيْنِ مَا لَيْسَ بِاسْمٍ وَلَا فِعْلٍ</مقطع>
  <مقطع هوية='٧٧٥٠٨'>وَلَكِنَّهُ كَالْفَاْءِ وَالْوَاْوِ</مقطع>
  <مقطع هوية='١٣٧٥٥'>وَهُوَ عَلَى حَرْفَيْنِ أَكْثَرُ لِأَنَّهُ أَقْوَى</مقطع>
  <مقطع هوية='٦٤٤٧٠'>وَهُوَ فِي هٰذَا أَجْدَرُ أَنْ يَكُوْنَ إِذْ كَاْنَ يَكُوْنُ عَلَى حَرْفٍ</مقطع>
  <مقطع هوية='٥٦٢٩٠'>وَسَنَكْتُبُ ذٰلِكَ بِمَعْنَاْهُ إِنِ شَاْءَ اللهُ</مقطع>
  <مقطع هوية='٧١٣٤٨'>فَمِنْ ذٰلِكَ <حرف>أَمْ</حرف> وَ<حرف>أَوْ</حرف> وَقَدْ بُيِّنَ مَعْنَاْهُمَا فِي بَاْبِهِمَا</مقطع>
  <مقطع هوية='٣٨٨٩٣'>وَ<حرف>هَلْ</حرف> وَهِيَ لِلِاْسْتِفْهَاْمِ</مقطع>
  <مقطع هوية='٩٩٤٣٩'>وَ<حرف>لَمْ</حرف> وَهِيَ نَفْيٌ لِقَوْلِهِ <حرف>فَعَلَ</حرف>
  </مقطع>
  <مقطع هوية='٦٧٠٠٣'>وَ<حرف>لَنْ</حرف> وَهِيَ نَفْيٌ لِقَوْلِهِ <حرف>سَيَفْعَلُ</حرف>
  </مقطع>
  <مقطع هوية='٩٨٢٦٩'>وَ<حرف>إِنْ</حرف> وَهِيَ لِلْجَزَاْءِ</مقطع>
  <مقطع هوية='٩٠١٧٨'>وَتَكُوْنُ لَغْوًا فِي قَوْلِكَ <قول هوية='٠١١٦٥'>مَا إِنْ تَفْعَلُ</قول></مقطع>
  <شاهدة هوية='٢٢٨٥٧'>
    <بيت>
      <مصراع>وَمَا <ثبات>إِنْ</ثبات> طِبُّنَا جُبْنٌ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٧٩١٤٢'>وَأَمَّا <حرف>إِنْ</حرف> مَعَ <حرف>مَا</حرف> فِي لُغَةِ أَهْلِ الْحِجَاْزِ</مقطع>
  <مقطع هوية='٧٨٣٨٩'>فَهِيَ بِمَنْزِلَةِ <حرف>مَا</حرف> فِي قَوْلِكَ <حرف>إِنَّمَا</حرف> الثَّقِيْلَةِ</مقطع>
  <مقطع هوية='١٥٥٨٣'>تَجْعَلُهَا مِنْ حُرُوْفِ الِابْتِدَاْءِ</مقطع>
  <مقطع هوية='٩٤٦٣٢'>وَتَمْنَعُهَا أَنْ تَكُوْنَ مِنْ حُرُوْفِ <حرف>لَيْسَ</حرف> وَبِمَنْزِلْتِهَا</مقطع>

  <رأس/>
  <مقطع هوية='٨٠٦٩٥'>وَأَمَّا <حرف>مَا</حرف> فَهِيَ نَفْيٌ لِقَوْلِهِ <قول هوية='١١٢٨١'>هُوَ يَفْعَلُ</قول> إِذْ كَاْنَ فِي حَاْلِ الْفِعْلِ</مقطع>
  <مقطع هوية='٩١٩٦٠'>فَتَقُوْلُ <قول هوية='٠٦٤٨٦'>مَا يَفْعَلُ</قول> وَتَكُوْنُ بِمَنْزِلَةِ <حرف>لَيْسَ</حرف> فِي الْمَعْنَى</مقطع>
  <مقطع هوية='٤٨٣٥٠'>تَقُوْلُ <قول هوية='٠١٠٧٢'>عَبْدُ اللهِ مُنْطَلِقٌ</قول></مقطع>
  <مقطع هوية='٦٣٧٢٣'>فَتَقُوْلُ <قول هوية='٩٩٦٦٥'>مَا عَبْدُ اللهِ مُنْطَلِقٌ</قول> أَوْ <حرف>مُنْطَلِقًا</حرف></مقطع>
  <مقطع هوية='٣٦٣٦٠'>فَتَنْفِي بِهٰذَا اللَّفْظِ</مقطع>
  <مقطع هوية='٣٣٧٥٣'>كَمَا تَقُوْلُ <قول هوية='٣٥٩٣٥'>لَيْسَ عَبْدُ اللهِ مُنْطَلِقًا</قول></مقطع>

  <رأس/>
  <مقطع هوية='٨٧٤٩٧'>وَتَكُوْنُ تَوْكِيْدًا لَغْوًا وَذٰلِكَ قَوْلُكَ <قول هوية='٥٤٧٢٨'>مَتَى مَا تَأْتِنِي آتِكَ</قول></مقطع>
  <مقطع هوية='٢٦٧٣٤'>وَقَوْلُكَ <قول هوية='٧١١٨٤'>غَضِبْتَ مِنْ غَيْرِ مَا جُرْمٍ</قول></مقطع>
  <مقطع هوية='١٤٥٩٥'>وَقَاْلَ اللهُ عَزَّ وَجَلَّ
  <آية هوية='٥٢٧٩٤' سورة="٤" آية="١٥٥">فَبِمَا نَقْضِهِمْ مِّيْثَاْقَهُمْ</آية></مقطع>
  <مقطع هوية='٤٥٨١٢'>وَهِيَ لَغْوٌ فِي أَنَّهَا لَمْ تُحْدِثْ إِذْ جَاْءَتْ شَيِئًا</مقطع>
  <مقطع هوية='١٤٣٧٧'>لَمْ يَكُنْ قَبْلَ أَنْ تَجِيْءَ مِنَ الْعَمَلِ</مقطع>
  <مقطع هوية='٨٦٠٨٤'>وَهِيَ تَوْكِيْدٌ لِلْكَلَاْمِ</مقطع>

  <!-- gloss: "ma" may change the harf to which it is attached so that its function after ma is attached is different from its function before it is attached; it converts them to terms of initiation -->
  
  <مقطع هوية='٤٧٢٢٦'>وَقَدْ تُغَيِّرُ الْحَرْفَ حَتَّى يَصِيْرَ يَعْمَلُ لِمَجِيْئِهَا</مقطع>
  <مقطع هوية='٧٥٦١٩'>غَيْرَ عَمَلِهِ الْذِي كَاْنَ قَبْلَ أَنْ تَجِيْءَ</مقطع>
  <مقطع هوية='٩٩٨٨٠'>وَذٰلِكَ نَحْوُ قَوْلِهِ <حرف>إِنَّمَا</حرف> وَ<حرف>كَأَنَّمَا</حرف> وَ<حرف>لَعَلَّمَا</حرف></مقطع>
  <مقطع هوية='٨٥٦٧٧'>جَعَلْتَهُنَّ بِمَنْزِلَةِ حُرُوْفِ الِابْتِدَاْءِ</مقطع>
  <مقطع هوية='٣٤٨٠٢'>وَمِنْ ذٰلِكَ <حرف>حَيْثُمَا</حرف> صَاْرَتْ لِمَجِيْئِهَا بِمَنْزِلَةِ <حرف>أَيْنَ</حرف></مقطع>
  <مقطع هوية='١٠٥٥٦'>وَتَكُوْنُ <حرف>إِنْ</حرف> كَمَا فِي مَعْنَى <حرف>لَيْسَ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٤٣٧٤٦'>وَأَمَّا <حرف>لَا</حرف> فَتَكُوْنُ كَمَا فِي التَّوْكِيْدِ وَاللَّغْوِ</مقطع>
  <مقطع هوية='٢٢٣٨٧'>قَاْلَ اللهُ عَزَّ وَجَلَّ
  <آية هوية='٦٥٩٤٧' سورة="٥٧" آية="٢٩">لِّئَلَّا يَعْلَمَ أَهْلُ ٱلْكِتَاْبِ</آية>
  أَيْ <حرف>لِأَنْ يَعْلَمَ</حرف></مقطع>
  <مقطع هوية='٧٤٥٩٠'>وَتَكُوْنُ <حرف>لَا</حرف> نَفْيًا لِقَوْلِهِ <قول هوية='٨٨٣٤٦'>يَفْعَلُ</قول> وَلَمْ يَقَعْ الْفِعْلُ فَتَقُوْلُ <قول هوية='٠٠٣٢٧'>لَا يَفْعَلُ</قول>
  </مقطع>
  <مقطع هوية='٠٢٨٩٤'>وَقَدْ تُغَيِّرُ الشَّيْءَ عَنْ حَاْلِهِ كَمَا تَفْعَلُ <حرف>مَا</حرف>
  </مقطع>
  <مقطع هوية='٢٨٠٤٤'>وَذٰلِكَ قَوْلُكَ <حرف>لَوْلَا</حرف> صَاْرَتْ <حرف>لَوْ</حرف> فِي مَعْنًى آخَرَ</مقطع>
  <مقطع هوية='٥٦٩٦٨'>كَمَا صَاْرَتْ حِيْنَ قُلْتَ <حرف>لَوْ مَا</حرف> تَغَيَّرَتْ</مقطع>
  <مقطع هوية='٧٢٨٢٩'>كَمَا تَغَيَّرَتْ <حرف>حَيْثُ</حرف> بِـ<حرف>ـمَا</حرف> وَ<حرف>إِنْ</حرف> بِـ<حرف>ـمَا</حرف></مقطع>
  <مقطع هوية='٢٠٦٠٦'>وَمِنْ ذٰلِكَ أَيْضًا <حرف>هَلَّا فَعَلْتَ</حرف></مقطع>
  <مقطع هوية='٢٠٠٥٤'>فَتَصِيْرُ <حرف>هَلْ</حرف> مَعَ <حرف>لَا</حرف> فِي مَعْنًى آخَرَ</مقطع>
  <مقطع هوية='٤٩٠٩٣'>وَتَكُوْنُ <حرف>لَا</حرف> ضِدًّا لِـ<حرف>نَعَمْ</حرف> وَ<حرف>بَلَى</حرف></مقطع>
  <مقطع هوية='١١٢٨٨'>وَقَدْ بُيِّنَ أَحْوَالُهَا أَيْضًا فِي بَاْبِ النَّفْيِ</مقطع>

  <رأس/>
  <مقطع هوية='٣٥٥٠٧'>وَأَمَّا <حرف>أَنْ</حرف></مقطع>
  <مقطع هوية='٥٢٠١٨'>فَتَكُوْنُ بِمَنْزِلَةِ لَاْمُ الْقَسَمِ فِي قَوْلِهِ
  <قول هوية='٤٣٨٧٤'>أَمَّا وَاللهِ أَنْ لَوْ فَعَلْتَ لَفَعَلْتُ</قول>
  </مقطع>
  <مقطع هوية='٦٦٩١٣'>وَقَدْ بَيَّنَّا ذٰلِكَ فِي مَوْضِعِهِ</مقطع>
  <مقطع هوية='٣٦٥١٠'>وَتَكُوْنُ تَوْكِيْدًا أَيْضًا
  فِي قَوْلِكَ <قول هوية='٨٨٣٠٥'>لَمَّا أَنْ فَعَلَ</قول></مقطع>
  <مقطع هوية='٠٩٧٢٩'>كَمَا كَاْنَتْ تَوْكِيْدًا فِي الْقَسَمِ وَكَمَا كَاْنَتْ <حرف>إِنْ</حرف> مَعَ <حرف>مَا</حرف></مقطع>
  <مقطع هوية='٨٠٣٧٩'>وَقَدْ تُلْغَى <حرف>إِنْ</حرف> مَعَ <حرف>مَا</حرف> إِذَا كَاْنَتْ اسْمًا وَكَاْنَتْ حِيْنًا</مقطع>
  <مقطع هوية='٦٤٦١١'>وَقَاْلَ الشَّاْعِرُ</مقطع>
  <شاهدة هوية='٩٠٢١٠'>
    <بيت>
      <مصراع>وَرَجِّ الْفَتَى لِلْخَيْرِ <ثبات>مَا إِنْ</ثبات> رَأَيْتَهُ</مصراع>
      <مصراع>عَلَى السِّنِّ خَيْرًا لَا يَزَاْلُ يَزِيْدُ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٧٢٤٩٣'>وَأَمَّا <حرف>كَيْ</حرف> فَجَوَاْبٌ لِقَوْلِهِ <قول هوية='٩٣١٨١'>كَيْمَهْ</قول></مقطع>
  <مقطع هوية='٨٣٤٢٩'>كَمَا يَقُوْلُ <قول هوية='٦٨٩٤٩'>لِمَهْ</قول>
  فَتَقُوْلَ <قول هوية='٨١٤٩٩'>لِيَفْعَلَ كَذَا وَكَذَا</قول></مقطع>
  <مقطع هوية='٩١٨١٨'>وَقَدْ بُيِّنَ أَمَرُهَا فِي بَاْبِهَا</مقطع>

  <رأس/>
  <مقطع هوية='٥٩٦٧١'>وَأَمَّا <حرف>بَلْ</حرف> فَلِتَرْكِ شَيْءٍ مِنَ الْكَلَاْمِ
  وَأَخْذٍ فِي غَيْرِهِ</مقطع>
  <مقطع هوية='٣٨٥١٠'>قَاْلَ الشَّاْعِرُ حَيْثُ تَرَكَ أَوَلَّ الْحَدِيْثِ
  وَهُوَ <شاعر>أَبُو ذُؤَيْبٍ</شاعر></مقطع>
  <شاهدة هوية='٩١٥١٢' شاعر="أَبُو ذُؤَيْبٍ">
    <بيت>
      <مصراع><ثبات>بَلْ</ثبات> هَلْ أُرِيْكَ حُمُوْلَ الْحَيِّ غَاْدِيَةً</مصراع>
      <مصراع>كَالنَّخْلِ زَيَّنَهَا يَنْعٌ وَإِفْضَاْحُ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٨٥٧٣٠'><حرف>أَيْنَعَ</حرف> <حرف>أَدْرَكَ</حرف></مقطع>
  <مقطع هوية='٢٩٤٠٨'>وَ<حرف>أَفْضَحَ</حرف> حِيْنَ تَدْخُلُهُ الْحُمْرَةُ وَالصُّفْرَةُ يَعْنِي الْبُسْرَ</مقطع>

  <مقطع هوية='٤٤٠٣٢'>وَقَاْلَ <شاعر>لَبِيْدٌ</شاعر></مقطع>
  <شاهدة هوية='٥٨٩٣٢' شاعر="لَبِيْدٌ">
    <بيت>
      <مصراع><ثبات>بَلْ</ثبات> مَنْ يَرَى الْبَرْقَ بِتُّ أَرْقُبُهُ</مصراع>
      <مصراع>يُزْجِي حَبِيًّا إِذَا خَبَا ثَقَبَا</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٧٩٥١٠'>وَأَمَّا <حرف>قَدْ</حرف> فَجَوَاْبٌ لِقَوْلِهِ <قول هوية='٧٦٣٠٦'>لَمَّا يَفْعَلْ</قول></مقطع>
  <مقطع هوية='٢٤٣٠٠'>فَتَقُوْلَ <قول هوية='٠٦٧٢٨'>قَدْ فَعَلَ</قول></مقطع>
  <مقطع هوية='٤٦٩٤٥'>وَزَعَمَ <سند>الْخَلِيْلُ</سند>
  أَنَّ هٰذَا الْكَلَاْمَ لِقَوْمٍ يَنْتَظِرُوْنَ الْخَبَرَ</مقطع>
  <مقطع هوية='٢٢٩٣٣'>وَ<حرف>مَا</حرف> فِي <حرف>لَمَّا</حرف> مُغَيِّرَةٌ لَهَا عَنْ حَاْلِ <حرف>لَمْ</حرف></مقطع>
  <مقطع هوية='٠٤٩٥٠'>كَمَا غَيَّرَتْ <حرف>لَوْ</حرف> إِذَا قُلْتَ <حرف>لَوْ مَا</حرف> وَنَحْوَهَا</مقطع>
  <مقطع هوية='٨٨٤٥٦'>أَلَا تَرَى أَنَّكَ تَقُوْلُ <حرف>لَمَّا</حرف> وَلَا تُتْبِعُهَا شَيْئًا</مقطع>
  <مقطع هوية='٢٩٩٣٤'>وَلَا تَقُوْلُ ذٰلِكَ فِي <حرف>لَمْ</حرف></مقطع>
  <مقطع هوية='٥٢٨٣٣'>وَتَكُوَنُ <حرف>قَدْ</حرف> بِمَنْزِلَةِ <حرف>رُبَّمَا</حرف>
  </مقطع>
  <مقطع هوية='٢٠٧٦٠'>وَقَاْلَ الشَّاْعِرُ الْهُذَلِيُّ</مقطع>
  <شاهدة هوية='٠٢٤٥٧'>
    <بيت>
      <مصراع><ثبات>قَدْ</ثبات> أَتْرُكُ الْقِرْنَ مُصْفَرًّا أَنَاْمِلُهُ</مصراع>
      <مصراع>كَأَنَّ أَثْوَاْبَهُ مُجَّتْ بِفِرْصَاْدِ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='١٢٨٦١'>كَأَنَّهُ قَاْلَ <حرف>رُبَّمَا</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٨٥٠٥٣'>وَأَمَّا <حرف>لَوْ</حرف></مقطع>
  <مقطع هوية='٠١٢٠٦'>فَلِمَا كَاْنَ سَيَقَعُ لِوُقُوْعِ غَيْرِهِ</مقطع>

  <رأس/>
  <مقطع هوية='٨٤١٧٧'>وَأَمَّا <حرف>يَا</حرف> فَتَنْبِيْهٌ</مقطع>
  <مقطع هوية='٩٧٢٥٢'>أَلَا تَرَاْهَا فِي النِّدَاْءِ وَفِي الْأَمْرِ كَأَنَّكَ تُنَبِّهُ الْمَأْمُوْرَ</مقطع>
  <مقطع هوية='٣٩٤٤٦'>قَاْلَ الشَّاْعِرُ وَهُوَ <شاعر>الشَّمَّاْخُ</شاعر></مقطع>
  <شاهدة هوية='٠٦٠٢٢' شاعر="الشَّمَّاْخُ">
    <بيت>
      <مصراع>أَلَا <ثبات>يَا</ثبات> اسْقِيَاْنِي قَبْلَ غَاْرَةِ سِنْجَاْلِ</مصراع>
      <مصراع>وَقَبْلَ مَنَاْيَا قَدْ حَضَرْنَ وَآجَاْلِ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٦٩٦٦٨'>وَأَمَّا <حرف>مِنْ</حرف></مقطع>
  <مقطع هوية='١٧٨٠٦'>فَتَكُوْنُ لِاْبْتِدَاْءِ الْغَاْيَةِ فِي الْأَمَاْكِنِ</مقطع>
  <مقطع هوية='٦١١٣٧'>وَذٰلِكَ قَوْلُكَ <حرف>مِنْ مَكَاْنِ كَذَا وَكَذَا إِلَى مَكَاْنِ كَذَا وَكَذَا</حرف></مقطع>
  <مقطع هوية='٥٤٥٦٢'>وَتَقُوْلُ إِذَا كَتَبْتَ كِتَاْبًا
  <قول هوية='٧٤٤٩٠'>مِنْ فُلَاْنٍ إِلَى فُلَاْنٍ</قول></مقطع>
  <مقطع هوية='٧٠٥٤١'>فَهَذِهِ الْأَسْمَاْءُ سِوَى الْأَمَاْكِنِ بِمَنْزِلَتِهَا</مقطع>
  <مقطع هوية='٣٧٨٦٢'>وَتَكُوْنُ أَيْضًا لِلتَّبْعِيْضِ</مقطع>
  <مقطع هوية='١٠٣٧١'>تَقُوْلُ <قول هوية='٤٦٧٤٠'>هٰذَا مِنْ الثَّوْبِ</قول> وَ<قول هوية='٢٧٦٧٨'>هٰذَا مِنْهُمْ</قول> كَأَنَّكَ قُلْتَ <حرف>بَعْضُهُ</حرف>
  </مقطع>
  <مقطع هوية='٨٦٢٣٥'>وَقَدْ تَدْخُلُ فِي مَوْضِعٍ لَوْ لَمْ تَدْخُلْ فِيْهِ كَاْنَ الْكَلَاْمُ مُسْتَقِيِمًا</مقطع>
  <مقطع هوية='٢٧١٩٩'>وَلَكِنَّهَا تَوْكِيْدٌ بِمَنْزِلَةِ <حرف>مَا</حرف></مقطع>
  <مقطع هوية='١٢١٨٦'>إِلَّا أَنَّهَا تَجُرُّ لِأَنَّهَا حَرْفُ إِضَاْفَةٍ</مقطع>
  <مقطع هوية='٣٤٤٢٥'>وَذٰلِكَ قَوْلُكَ <قول هوية='٦١٣٧٠'>مَا أَتَاْنِي مِنْ رَجُلٍ</قول></مقطع>
  <مقطع هوية='٠٢٧٥٦'>وَ<قول هوية='٦٨٦٥٦'>مَا رَأَيْتُ مِنْ أَحَدٍ</قول>
  </مقطع>
  <مقطع هوية='٤٣٩٦٧'>وَلَوْ أُخْرِجَتْ <حرف>مِنْ</حرف> كَاْنَ الْكَلَاْمُ حَسَنًا</مقطع>
  <مقطع هوية='٦٣٣٧٤'>وَلَكِنَّهُ أَكَّدَ بِـ <حرف>مِنْ</حرف> لِأَنَّ هٰذَا مَوْضِعُ تَبْعِيْضٍ</مقطع>
  <مقطع هوية='٧٣٤٦٣'>فَأَرَاْدَ أَنَّهُ لَمْ يَأْتِهِ بَعْضُ الرِّجَاْلِ وَالنَّاْسِ</مقطع>
  <مقطع هوية='٨٦٦٢٥'>وَكَذٰلِكَ <قول هوية='٢٥٣٧٥'>وَيْحَهُ مِنْ رَجُلٍ</قول>
  </مقطع>
  <مقطع هوية='٨٣٣٥٨'>إِنَّمَا أَرَاْدَ أَنْ يَجْعَلَ التَّعَجُّبَ مِنْ بَعْضِ الرِّجَاْلِ</مقطع>
  <مقطع هوية='٩١٠٩٢'>وَكَذٰلِكَ <قول هوية='٥٢٦٧٧'>لِي مِلْؤُهُ مِنْ عَسَلٍ</قول>
  </مقطع>
  <مقطع هوية='٥٣٨١٥'>وَكَذٰلِكَ <قول هوية='٠٠٨٠٢'>هُوَ أَفْضَلُ مِنْ زَيْدٍ</قول></مقطع>
  <مقطع هوية='٣٣٦٨٧'>إِنَّمَا أَرَاْدَ أَنْ يُفَضِّلَهُ عَلَى بَعْضٍ وَلَا يَعُمُّ</مقطع>
  <مقطع هوية='٩٠١٩٥'>وَجَعَلَ <حرف>زَيْدًا</حرف> الْمَوْضِعَ الَّذِي ارْتَفَعَ مِنْهُ</مقطع>
  <مقطع هوية='٦٩٣١٦'>أَوْ سَفَلَ مِنْهُ فِي قَوْلِكَ <قول هوية='٥٨٥٩٥'>شَرٌّ مِنْ زَيْدٍ</قول>
  </مقطع>
  <مقطع هوية='٣٦٣٥٧'>وَكَذٰلِكَ إِذَا قَاْلَ <قول هوية='٣٩١٨٥'>أَخْزَى اللهُ الْكَاْذِبَ مِنِّي وَمِنْكَ</قول>
  </مقطع>
  <مقطع هوية='٣٧٧٦٢'>إِلَّا أَنَّ هٰذَا وَ<حرف>أَفْضَلُ مِنْكَ</حرف> لَا يُسْتَغْنَى عَنْ <حرف>مِنْ</حرف> فِيْهِمَا</مقطع>
  <مقطع هوية='٨٩٠٩٥'>لِأَنَّهَا تُوْصِلُ الْأَمْرَ إِلَى مَا بَعْدَهَا</مقطع>
  <مقطع هوية='٧٧٨١١'>وَقَدْ تَكُوْنُ بَاْءُ الْإِضَاْفَةِ بِمَنْزِلَتِهَا فِي التَّوْكِيْدِ</مقطع>
  <مقطع هوية='١٩٦٣٤'>وَذٰلِكَ قَوْلُكَ <قول هوية='٧٩٠٥٤'>مَا زَيْدٌ بِمُنْطَلِقٍ</قول> وَ<قول هوية='١٤١٢٦'>لَسْتُ بِذَاْهِبٍ</قول></مقطع>
  <مقطع هوية='٣٨٢٤٠'>أَرَاْدَ أَنْ يَكُوْنَ مُؤَكِّدًا حَيْثُ نَفَى الِانْطِلَاْقَ وَالذَّهَاْبَ</مقطع>
  <مقطع هوية='٦٩٨٠٠'>وَكَذٰلِكَ <قول هوية='٧٨٢٤٠'>كَفَى بِالشَيْبِ</قول></مقطع>
  <مقطع هوية='٩١٨٠٦'>لَوْ أَلْقَى الْبَاْءَ اسْتَقَاْمَ الْكَلَاْمُ</مقطع>
  <مقطع هوية='٤١٢٤٦'>وَقَاْلَ الشَّاْعِرُ <شاعر>عَبْدُ بَنِي الْحَسْحَاْسِ</شاعر></مقطع>
  <شاهدة هوية='٠٧٧٧٧' شاعر="عَبْدُ بَنِي الْحَسْحَاْسِ">
    <بيت>
      <مصراع><ثبات>كَفَى الشَّيْبُ</ثبات> وَالْإِسْلَاْمُ لِلْمَرْءِ نَاْهِيًا</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٠٤٢١٢'>وَتَقُوْلُ <قول هوية='٢٨٨٩٧'>رَأَيْتُهُ مِنْ ذٰلِكَ الْمَوْضِعِ</قول></مقطع>
  <مقطع هوية='٧٥١٩٨'>فَجَعَلْتَهُ غَاْيَةَ رُؤْيَتِكَ</مقطع>
  <مقطع هوية='١٧١٤٥'>كَمَا جَعَلْتَهُ غَاْيَةً حَيْثُ أَرَدْتَ الِابْتِدَاْءَ وَالْمُنْتَهَى</مقطع>

  <رأس/>
  <مقطع هوية='٠٦١٠٦'>وَ<حرف>أَلْ</حرف> تُعَرِّفُ الِاسْمَ فِي قَوْلِكَ <حرف>الْقَوْمُ</حرف> وَ<حرف>الرَّجُلُ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٩٣٥٢٢'>وَأَمَّا <حرف>مُذْ</حرف></مقطع>
  <مقطع هوية='٢١٠٢٨'>فَتَكُوْنُ ابْتِدَاْءَ غَاْيَةِ الْأَيَّاْمِ وَالْأَحْيَاْنِ</مقطع>
  <مقطع هوية='٤٢٢٨٩'>كَمَا كَاْنَتْ <حرف>مِنْ</حرف> فِيْمَا ذَكَرْتُ لَكَ</مقطع>
  <مقطع هوية='٣٧٥٤٦'>وَلَا تَدْخُلُ وَاْحِدَةٌ مِنْهُمَا عَلَى صَاْحِبَتِهَا</مقطع>
  <مقطع هوية='٥٤٣٩١'>وَذٰلِكَ قَوْلُكَ <قول هوية='٦٥٧٥١'>مَا لَقِيْتُهُ مُذْ يَوْمِ الْجُمُعَةِ إِلَى الْيَوْمِ</قول></مقطع>
  <مقطع هوية='٣٩٣٣٣'>وَ<حرف>مُذْ غُدْوَةَ إِلَى السَّاْعَةِ</حرف></مقطع>
  <مقطع هوية='٢٩١٧٨'>وَ<قول هوية='٥١١٠١'>مَا لَقِيْتُهُ مُذْ الْيَوْمِ إِلَى سَاْعَتِكَ هَذِهِ</قول></مقطع>
  <مقطع هوية='٦٣٩٢٧'>فَجَعَلْتَ <حرف>الْيَوْمَ</حرف> أَوَّلَ غَاْيَتِكَ</مقطع>
  <مقطع هوية='٠٤٣٤٦'>فَأُجْرِيَتْ فِي بَاْبِهَا</مقطع>
  <مقطع هوية='١٠١٦٠'>كَمَا جَرَتْ <حرف>مِنْ</حرف> حَيْثُ قُلْتَ <حرف>مِنْ مَكَاْنِ كَذَا إِلَى مَكَاْنِ كَذَا</حرف></مقطع>
  <مقطع هوية='٤٦٠٠٩'>وَتَقُوْلُ <قول هوية='٦٧٣٤٨'>مَا رَأَيْتُهُ مُذْ يَوْمَيْنِ</قول> فَجَعَلْتَهَا غَاْيَةً</مقطع>
  <مقطع هوية='١٧٠٦١'>كَمَا قُلْتَ <قول هوية='٦٥٠٦١'>أَخَذْتُهُ مِنْ ذٰلِكَ الْمَكَاْنِ</قول></مقطع>
  <مقطع هوية='١٩٨٦٤'>فَجَعَلْتَهُ غَاْيَةً وَلَمْ تُرِدْ مُنْتَهًى</مقطع>

  <رأس/>
  <مقطع هوية='١٥٧٥٥'>وَأَمَّا <حرف>فِي</حرف></مقطع>
  <مقطع هوية='٦١٨٣٢'>فَهِيَ لِلْوِعَاْءِ</مقطع>
  <مقطع هوية='٤٠٧٧٥'>تَقُوْلُ <قول هوية='١٧٧٦٠'>هُوَ فِي الْجِرَاْبِ</قول>
  وَ<حرف>فِي الْكِيْسِ</حرف></مقطع>
  <مقطع هوية='٦٨٦٨٦'>وَ<قول هوية='٧١٨٠٦'>هُوَ فِي بَطْنِ أُمِّهِ</قول></مقطع>
  <مقطع هوية='٥٧٢٥١'>وَكَذٰلِكَ <قول هوية='٧٦٢٧٣'>هُوَ فِي الْغُلِّ</قول></مقطع>
  <مقطع هوية='٢٩٢٥٢'>لِأَنَّهُ جَعَلَهُ إِذْ أَدْخَلَهُ فِيْهِ كَالْوِعَاْءِ لَهُ</مقطع>
  <مقطع هوية='٢٧٨١٨'>وَكَذٰلِكَ <قول هوية='٦٣٢٣٥'>هُوَ فِي الْقُبَّةِ</قول>
  وَ<حرف>فِي الدَّاْرِ</حرف></مقطع>
  <مقطع هوية='٦٤٣٥٤'>وَإِنِ اتَّسَعْتَ فِي الْكَلَاْمِ فَهِيَ عَلَى هٰذَا</مقطع>
  <مقطع هوية='٧٠٣٧١'>وَإِنَّمَا تَكُوْنُ كَالْمَثَلِ</مقطع>
  <مقطع هوية='٧٣٩٩١'>يُجَاْءُ بِهِ يُقَاْرِبُ الشَّيْءَ وَلَيْسَ مِثْلَهُ</مقطع>

  <رأس/>
  <مقطع هوية='٢٣٧٣٠'>وَأَمَّا <حرف>عَنْ</حرف></مقطع>
  <مقطع هوية='٤١٢٦١'>فَلِمَا عَدَا الشَّيْءَ</مقطع>
  <مقطع هوية='٦٣٢٨٦'>وَذٰلِكَ قَوْلُكَ <قول هوية='٠٩٤٥٠'>أَطْعَمَهُ عَنْ جُوْعٍ</قول></مقطع>
  <مقطع هوية='٧٣٤٦٧'>جَعَلَ الْجُوْعَ مُنْصَرِفًا تَاْرِكًا لَهُ قَدْ جَاْوَزَهُ</مقطع>
  <مقطع هوية='٧٦١١٥'>وَقَاْلَ <قول هوية='٤٢٢٦٧'>قَدْ سَقَاْهُ عَنْ الْعَيْمَةِ</قول> وَالْعَيْمَةُ شَهْوَةُ اللَّبَنِ</مقطع>
  <مقطع هوية='٤٣٤٢٢'>قَاْلَ <سند>أَبُو عَمْرٍو</سند> سَمِعْتُ أَبَا زَيْدٍ يَقُوْلُ
  <قول هوية='٧٨٧٦٠'>رَمَيْتُ عَنْ الْقَوْسِ</قول></مقطع>
  <مقطع هوية='٥٧٨١٢'>وَنَاْسٌ يَقُوْلُوْنَ <قول هوية='٥٦٩٣٩'>رَمَيْتُ عَلَيْهَا</قول></مقطع>
  <مقطع هوية='١٠٠٣٨'>وَأَنْشَدَ</مقطع>
  <شاهدة هوية='١٥٦٥٤'>
    <بيت>
      <مصراع>أَرْمِي <ثبات>عَلَيْهَا</ثبات> وَهِيَ فَرْعٌ أَجْمَعُ</مصراع>
      <مصراع>وَهِيَ ثَلَاْثُ أَذْرُعٍ وَإِصْبَعُ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='١٦٥١٢'>وَ<قول هوية='٢١٠٧٨'>كَسَاْهُ عَنْ الْعُرْيِ</قول></مقطع>
  <مقطع هوية='٧٢٦٠١'>جَعَلَهُمَا <قول هوية='٤٣٨٨٨'>قَدْ تَرَاْخِيَا عَنْهُ</قول></مقطع>
  <مقطع هوية='٢٣٠٠٦'>وَ<قول هوية='٦٩٨٤٧'>رَمَيْتُ عَنْ الْقَوْسِ</قول> لِأَنَّهُ بِهَا قَذَفَ سَهْمَهُ عَنْهَا وَعَدَّاْهَا</مقطع>
  <مقطع هوية='٠٢١٠٤'>وَتَقُوْلُ <قول هوية='٦٨٧٣٦'>جَلَسَ عَنْ يَمِيْنِهِ</قول></مقطع>
  <مقطع هوية='١٥٦٥٢'>فَجَعَلَهُ مُتَرَاْخِيًا عَنْ بَدَنِهِ</مقطع>
  <مقطع هوية='٥٤٦٥٠'>وَجَعَلَهُ فِي الْمَكَاْنِ الَّذِي بِحِيَاْلِ يَمِيْنِهِ</مقطع>
  <مقطع هوية='٥٦٣٨٧'>وَتَقُوْلُ <قول هوية='٩٩٥٢٨'>أَضْرَبْتُ عَنْهُ</قول> وَ<قول هوية='١٥٠٠٤'>أَعْرَضْتُ عَنْهُ</قول> وَ<قول هوية='٢٢٥٢٠'>انْصَرَفَ عَنْهُ</قول></مقطع>
  <مقطع هوية='٥٠٩٢٥'>إِنَّمَا تُرِيْدُ أَنَّهُ تَرَاْخَى عَنْهُ وَجَاْوَزَهُ إِلَى غَيْرِهِ</مقطع>
  <مقطع هوية='٨٧٦٧٩'>وَتَقُوْلُ <قول هوية='٢٥٩٠٨'>أَخَذْتُ عَنْهُ حَدِيْثًا</قول> أَيْ عَدَا مِنْهُ إِلَيَّ حَدِيْثٌ</مقطع>
  <مقطع هوية='٨٨٢١٩'>وَقَدْ تَقَعُ <حرف>مِنْ</حرف> مَوْقِعَهَا أَيْضًا</مقطع>
  <مقطع هوية='٠٩٠٩٤'>تَقُوْلُ <قول هوية='٨١٣٥١'>أَطْعَمَهُ مِنْ جُوْعٍ</قول></مقطع>
  <مقطع هوية='٨٠٧٣٧'>وَ<قول هوية='٩٥٧٤٠'>كَسَاْهُ مِنْ عُرْيٍ</قول></مقطع>
  <مقطع هوية='٩٢٣٩١'>وَ<قول هوية='٢٩٩٠٥'>سَقَاْهُ مِنَ الْعَيْمَةِ</قول></مقطع>

  <رأس/>
  <مقطع هوية='٣٦٩٢٦'>وَمَا جَاْءَ مِنَ الْأَسْمَاْءِ غَيْرَ الْمُتَمَكِّنَةِ عَلَى حَرْفَيْنِ</مقطع>
  <مقطع هوية='٨٣٩٥٣'>أَكْثَرُ مِمَّا جَاْءَ مِنَ الْمُتَمَكِّنَةِ عَلَى حَرْفَيْنِ نَحْوُ <حرف>يَدٍ</حرف> وَ<حرف>دَمٍ</حرف></مقطع>
  <مقطع هوية='٩٠٨٦٣'>لِأَنَّهَا حَيْثُ لَمْ تَمَكَّنْ ضَاْرَعَتْ هَذِهِ الْحُرُوْفَ</مقطع>
  <مقطع هوية='٩٨٧٠٢'>لِأَنَّهُ لَمْ يُفْعَلْ بِهَا مَا فُعِلَ بِتِلْكَ الْأَسْمَاْءِ الْمُتَمَكِّنَةِ</مقطع>
  <مقطع هوية='١٩٧٣٧'>وَلَمْ تَصَرَّفْ تَصَرُّفَهَا</مقطع>
  <مقطع هوية='٩٦٥٨٣'>وَمَا جَاْءَ عَلَى حَرْفَيْنِ مِمَّا وَُضِعَ مَوَاْضِعَ الْفِعْلِ</مقطع>
  <مقطع هوية='١٢٧٩٩'>أَكْثَرُ مِمَّا جَاْءَ مِنَ الْفِعْلِ الْمُتَصَرِّفِ</مقطع>
  <مقطع هوية='٦٧٧١١'>لِأَنَّهَا حَيْثُ لَمْ تَصَرَّفْ ضَاْرَعَتْ هَذِهِ الْحُرُوْفَ</مقطع>
  <مقطع هوية='٠٨٣٤٩'>لِأَنَّهَا لَيْسَتْ بِفِعْلٍ يَتَصَرَّفُ</مقطع>
  <مقطع هوية='٢٤٨٠٩'>وَسَأُبَيِّنُ لَكَ مِنْ ذٰلِكَ إِنْ شَاْءَ اللهُ</مقطع>

  <رأس/>
  <مقطع هوية='٧٢٠٧٩'>فَمِنَ الْأَسْمَاْءِ <حرف>ذَا</حرف> وَ<حرف>ذِهْ</حرف></مقطع>
  <مقطع هوية='٤٢٨٦٢'>وَمَعْنَاْهُمَا أَنَّكَ بِحَضْرَتِهِمَا وَهُمَا اسْمَاْنِ مُبْهَمَاْنِ</مقطع>
  <مقطع هوية='٧٦٩٩٢'>وَقَدْ بُيِّنَا فِي غَيْرِ هٰذَا الْمَوْضِعِ</مقطع>
  <مقطع هوية='٣٣٥٨١'>وَ<حرف>أَنَا</حرف> وَهِيَ عَلَاْمَةُ الْمُضْمَرِ</مقطع>
  <مقطع هوية='٤٤٠٧٨'>وَكَذٰلِكَ <حرف>هُوَ</حرف> وَ<حرف>هِيَ</حرف>
  </مقطع>
  <مقطع هوية='٠٢٧٥٤'>وَ<حرف>كَمْ</حرف> وَهِيَ لِلْمَسْأَلَةِ عَنْ الْعَدَدِ</مقطع>
  <مقطع هوية='٨٧٦٩٣'>وَ<حرف>مَنْ</حرف> وَهِيَ لِلْمَسْأَلَةِ عَنْ الْأَنَاْسِيِّ</مقطع>
  <مقطع هوية='٦٣١٠٤'>وَيَكُوْنُ بِهَا الْجَزَاْءُ لِلْأَنَاْسِيِّ</مقطع>
  <مقطع هوية='٦٥٨٦٩'>وَيَكُوْنُ بِمَنْزِلَةِ <حرف>الَّذِي</حرف> لِلْأَنَاْسِيِّ</مقطع>
  <مقطع هوية='٢٥٩٦٤'>وَقَدْ بُيِّنَ جَمِيْعُ ذٰلِكَ فِي مَوْضِعِهِ</مقطع>
  <مقطع هوية='١٦١٧٩'>وَ<حرف>مَا</حرف> مِثْلُهَا</مقطع>
  <مقطع هوية='٥٦٣٨٩'>إِلَّا أَنَّ <حرف>مَا</حرف> مُبْهَمَةٌ تَقَعُ عَلَى كُلِّ شَيْءٍ</مقطع>
  <مقطع هوية='٥٧٢٨٧'>وَ<حرف>أَنْ</حرف> بِمَنْزِلَةِ <حرف>الَّذِي</حرف></مقطع>
  <مقطع هوية='٢٩٨٧٦'>تَكُوْنُ مَعَ الصِّلَةِ بِمَنْزِلَةِ <حرف>الَّذِي</حرف> مَعَ صِلَتِهَا اسْمًا</مقطع>
  <مقطع هوية='٦٩٣٨٧'>فَيَصِيْرُ <قول هوية='٩١٦٩٦'>يُرِيْدُ أَنْ يَفْعَلَ</قول> بِمَنْزِلَةِ <قول هوية='٥٥٤٢٨'>يُرِيْدُ الْفِعْلَ</قول></مقطع>
  <مقطع هوية='٩٧٥٢٠'>كَمَا أَنَّ <حرف>الَّذِي ضَرَبَ</حرف> بِمَنْزِلَةِ <حرف>الضَّاْرِبِ</حرف></مقطع>
  <مقطع هوية='٦٩٥١٥'>وَقَدْ بُيِّنَتْ فِي بَاْبِهَا</مقطع>
  <مقطع هوية='٥٧٥٤٦'>وَ<حرف>قَطْ</حرف> مَعْنَاْهَا الِاكْتِفَاْءِ</مقطع>
  <مقطع هوية='٥٦٢٠٠'>وَ<حرف>مَعَ</حرف> وَهِيَ لِلْصُحْبَةِ</مقطع>
  <مقطع هوية='٤٧١١٤'>وَ<حرف>مُذْ</حرف> فِيْمَنْ رَفَعَ بِمَنْزِلَةِ <حرف>إِذْ</حرف> وَ<حرف>حَيْثُ</حرف></مقطع>
  <مقطع هوية='١٩٣٤٢'>وَمَعْنَاْهَا إِذَا رَفَعْتَ قَدْ بُيِّنَ فِيْمَا مَضَى
  بِقَوْلِ <سند>الْخَلِيْلِ</سند></مقطع>
  <مقطع هوية='٥٠٨٦٨'>وَأَمَّا <حرف>عَنْ</حرف> فَاسْمٌ إِذَا قُلْتَ <قول هوية='٤٢٩٣٢'>مِنْ عَنْ يَمِيْنِكَ</قول></مقطع>
  <مقطع هوية='٦٨٢٧٥'>لِأَنَّ <حرف>مِنْ</حرف> لَا تَعْمَلُ إِلَّا فِي الْأَسْمَاْءِ</مقطع>
  <مقطع هوية='٢٦٦٤٢'>وَ<حرف>عَلُ</حرف> مَعْنَاْهَا الْإِتْيَاْنُ مِنْ فَوْقٍ</مقطع>

  <مقطع هوية='٨٣٦٥٩'>وَقَاْلَ <شاعر>امْرُؤُ الْقَيْسِ</شاعر></مقطع>
  <شاهدة هوية='٢٦٠٦٤' شاعر="امْرُؤُ الْقَيْسِ">
    <بيت>
      <مصراع>كَجُلْمُوْدِ صَخْرٍ حَطَّهُ السَّيْلُ <ثبات>مِنَ عَلِ</ثبات></مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='٩٩٢٣٤'>وَقَاْلَ <شاعر>جَرِيْرٌ</شاعر></مقطع>
  <شاهدة هوية='١٧١٤١' شاعر="جَرِيْرٌ">
    <بيت>
      <مصراع>حَتَّى اخْتَطَفْتُكَ يَا فَرَزْدَقُ <ثبات>مِنْ عَلِ</ثبات></مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='١٠٠٩٦'>وَ<حرف>إِذْ</حرف> وَهِيَ لِمَا مَضَى مِنْ الدَّهْرِ</مقطع>
  <مقطع هوية='٠٩٠٥٢'>وَهِيَ ظَرْفٌ بِمَنْزِلَةِ <حرف>مَعَ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='١٦١٨٩'>وَأَمَّا مَا هُوَ فِي مَوْضِعِ الْفِعْلِ</مقطع>
  <مقطع هوية='٢٥١٨٦'>فَقَوْلُكَ <حرف>مَهْ</حرف> وَ<حرف>صَهْ</حرف></مقطع>
  <مقطع هوية='٦١٦٢٥'>وَ<حرف>حَلْ</حرف> لِلنَّاْقَةِ وَ<حرف>سَا</حرف> لِلْحِمَاْرِ</مقطع>
  <مقطع هوية='٣٦٣٠٣'>وَمَا مِثْلُ ذٰلِكَ فِي الْكَلَاْمِ عَلَى نَحْوِهِ فِي الْأَسْمَاْءِ</مقطع>
  <مقطع هوية='٤٥٢٩٢'>إِلَّا أَنَّا تَرَكْنَا ذِكْرَهُ لِأَنَّهُ إِنَّمَا هُوَ أَمْرٌ وَنَهْيٌ</مقطع>
  <مقطع هوية='٤٧٨٠١'>يَعْنِي <حرف>هَلُمَّ</حرف> وَ<حرف>إِيْهٍ</حرف></مقطع>
  <مقطع هوية='٧٤٣٨٠'>وَلَا يَخْتَلِفُ اخْتِلَاْفَ الْأَسْمَاْءِ فِي الْمَعَاْنِي</مقطع>

  <رأس/>
  <مقطع هوية='٥٢٧٢٧'>وَاعْلَمْ أَنَّ بَعْضَ الْعَرَبِ يَقُوْلُ
  <قول هوية='٣٥١٧٨'>مُ اللهِ لَأَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='٤٥١١٢'>يُرِيْدُ <قول هوية='١٤٥٣٣'>أَيْمُ اللهِ</قول></مقطع>
  <مقطع هوية='٨٩٨٤٠'>فَحَذَفَ حَتَّى صَيَّرَهَا عَلَى حَرْفٍ</مقطع>
  <مقطع هوية='٣٢٥٥٩'>حَيْثُ لَمْ يَكُنْ مُتَمَكِّنًا يُتَكَلَّمُ بِهِ وَحْدَهُ</مقطع>
  <مقطع هوية='٣٢٢٥٣'>فَجَاْءَ عَلَى حَرْفٍ</مقطع>
  <مقطع هوية='٨٣٣٤٤'>حَيْثُ ضَاْرَعَ مَا جَاْءَ عَلَى حَرْفٍ</مقطع>
  <مقطع هوية='٧٨٦٦٨'>كَمَا كَثُرَتْ الْأَسْمَاْءُ فِي الْحَرْفَيْنِ</مقطع>
  <مقطع هوية='٨٧٩٦٥'>حَيْثُ ضَاْرَعَتْ مَا قَبْلَهَا مِنْ غَيْرِ الْأَسْمَاْءِ</مقطع>

  <رأس/>
  <مقطع هوية='٧١٣٣٣'>وَأَمَّا مَا جَاْءَ عَلَى ثَلَاْثَةِ أَحْرُفٍ</مقطع>
  <مقطع هوية='٠١٥٠٠'>فَهُوَ أَكْثَرُ الْكَلَاْمِ فِي كُلِّ شَيْءٍ مِنَ الْأَسْمَاْءِ وَالْأَفْعَاْلِ وَغَيْرِهِمَا</مقطع>
  <مقطع هوية='٦١٠٠٧'>مَزِيْدًا فِيْهِ وَغَيْرَ مَزِيْدٍ فِيْهِ</مقطع>
  <مقطع هوية='٠٢٥٩٩'>وَذٰلِكَ لِأَنَّهُ كَأَنَّهُ هُوَ الْأَوَّلُ</مقطع>
  <مقطع هوية='٥٠٣٧٧'>فَمِنْ ثَمَّ تَمَكَّنَ فِي الْكَلَاْمِ</مقطع>

  <رأس/>
  <مقطع هوية='٧٩٥٢٠'>ثُمَّ مَا كَاْنَ عَلَى أَرْبَعَةِ أَحْرُفٍ بَعْدَهُ</مقطع>

  <رأس/>
  <مقطع هوية='٤١٠٤٨'>ثُمَّ بَنَاْتُ الْخَمْسَةِ وَهِيَ أَقْلُّ</مقطع>
  <مقطع هوية='٤٤٨١٩'>لَا تَكُوْنُ فِي الْفِعْلِ الْبَتَّةَ</مقطع>
  <مقطع هوية='٨٧٠٨١'>وَلَا يُكَسَّرُ بِتَمَاْمِهِ لِلْجَمْعِ</مقطع>
  <مقطع هوية='٠٧٩٣٦'>لِأَنَّهَا الْغَاْيَةُ فِي الْكَثْرَةِ فَاسْتُثْقِلَ ذٰلِكَ فِيْهَا</مقطع>
  <مقطع هوية='٦٨٥٥٧'>فَالْخَمْسَةُ أَقْصَى الْغَاْيَةِ فِي الْكَثْرَةِ</مقطع>

  <رأس/>
  <مقطع هوية='٩٣٨٦٨'>فَالْكَلَاْمُ عَلَى ثَلَاْثَةِ أَحْرُفٍ وَأَرْبَعَةِ أَحْرُفٍ وَخَمْسَةٍ</مقطع>
  <مقطع هوية='٤٩١١٦'>لَا زِيَاْدَةَ فِيْهَا وَلَا نُقْصَاْنَ</مقطع>
  <مقطع هوية='٠٩٢٠٩'>وَالْخَمْسَةُ أَقُلُ الثَّلَاْثَةِ فِي الْكَلَاْمِ</مقطع>

  <رأس/>
  <مقطع هوية='١٢٥١٣'>فَالثَّلَاْثَةُ أَكْثَرُ مَا تَبْلُغُ بِالزِّيَاْدَةِ سَبْعَةُ أَحْرُفٍ</مقطع>
  <مقطع هوية='٢٧٧٥٧'>وَهِيَ أَقْصَى الْغَاْيَةِ وَالْمَجْهُوْدِ</مقطع>
  <مقطع هوية='٣٣٨٨٢'>وَذٰلِكَ نَحْوُ <حرف>اشْهِيْبَاْبُ</حرف></مقطع>
  <مقطع هوية='٨٧٩٩٠'>فَهُوَ يَجْرِي عَلَى مَا بَيْنَ الثَّلَاْثَةِ وَالسَّبْعَةِ</مقطع>
  <رأس/>
  <مقطع هوية='٣١٤٢٩'>وَالْأَرْبَعَةُ تَبْلُغُ هٰذَا</مقطع>
  <مقطع هوية='٧٦٨٧٧'>نَحْوُ <حرف>احْرِنْجَاْمٍ</حرف></مقطع>
  <مقطع هوية='٠٧٧٧٨'>وَلَا تَبْلُغُ السَّبْعَةَ إِلَّا فِي هَذَيْنِ الْمَصْدَرَيْنِ</مقطع>
  <رأس/>
  <مقطع هوية='٢٢٣٥٨'>وَأَمَّا بَنَاْتُ الْخَمْسَةِ فَتَبْلُغُ بِالزِّيَاْدَةِ سِتَّةً</مقطع>
  <مقطع هوية='٤٦٣٩٠'>نَحْوُ <حرف>عَضْرَفُوْطَ</حرف></مقطع>
  <مقطع هوية='٧٦٤٣١'>وَلَا تَبْلُغُ سَبْعَةً كَمَا بَلَغَتْهَا الْثَّلَاْثَةُ وَالْأَرْبَعَةُ</مقطع>
  <مقطع هوية='٧٦١٢٧'>لِأَنَّهَا لَا تَكُوْنُ فِي الْفِعْلِ فَيَكُوْنَ لَهَا مَصْدَرٌ نَحْوُ هٰذَا</مقطع>

  <رأس/>
  <مقطع هوية='٩٩٦٩٥'>فَعَلَى هٰذَا عِدَّةُ حُرُوْفِ الْكَلِمِ</مقطع>
  <مقطع هوية='٢٧٣٩١'>فَمَا قَصُرَ عَنِ الثَّلَاْثَةِ فَمَحْذُوْفٌ</مقطع>
  <مقطع هوية='٧٠٦٨١'>وَمَا جَاْوَزَ الْخَمْسَةَ فَمَزِيْدٌ فِيْهِ</مقطع>
  <مقطع هوية='٩٢٢٣٨'>وَسَأَكْتُبُ لَكَ مِنْ مَعَاْنِي مَا عِدَّةُ حُرُوْفِهِ ثَلَاْثَةٌ فَصَاْعِدًا</مقطع>
  <مقطع هوية='٩٣٤٤٣'>نَحْوُ مَا كَتَبْتُ لَكَ مِنْ مَعَاْنِي الْحَرْفِ وَالْحَرْفَيْنِ إِنِ شَاْءَ اللهُ</مقطع>

  <رأس/>
  <مقطع هوية='٤٢٧٥٧'>أَمَّا <حرف>عَلَى</حرف></مقطع>
  <مقطع هوية='٨١٠٧٦'>فَاسْتِعَلَاْءُ الشَّيْءِ</مقطع>
  <مقطع هوية='٠٢٦١٦'>تَقُوْلُ <قول هوية='٨٢٠٦٤'>هٰذَا عَلَى ظَهْرِ الْجَبَلِ</قول></مقطع>
  <مقطع هوية='٨٨٢١٨'>وَ<قول هوية='٩٣٨٤٩'>هِيَ عَلَى رَأْسِهِ</قول>
  </مقطع>
  <مقطع هوية='٢٦٣١٠'>وَيَكُوْنُ أَنْ يَطْوِيَ أَيْضًا مُسْتَعْلِيًا</مقطع>
  <مقطع هوية='٢٢٥٣٤'>كَقَوْلِكَ <قول هوية='٥٣٢٧٢'>مَرَّ الْمَاْءُ عَلَيْهِ</قول> وَ<قول هوية='٩٩٢٤٠'>أَمْرَرْتُ يَدِي عَلَيْهِ</قول></مقطع>
  <مقطع هوية='٩٠٩٨٢'>وَأَمَّا <قول هوية='٢٣٤٣٤'>مَرَرْتُ عَلَى فُلَاْنٍ</قول> فَجَرَى هٰذَا كَالْمَثَلِ</مقطع>
  <مقطع هوية='٨٤٧٥٥'>وَ<قول هوية='٥٦٨٣٢'>عَلَيْنَا أَمِيْرٌ</قول> كَذٰلِكَ
  وَ<قول هوية='١٤١١٩'>عَلَيْهِ مَاْلٌ</قول> أَيْضًا</مقطع>
  <مقطع هوية='٣٨٩٠٧'>وَهٰذَا لِأَنَّهُ شَيْءٌ اعْتَلَاْهُ</مقطع>
  <مقطع هوية='٨٠٨٨١'>وَيَكُوْنُ <قول هوية='٣٤٤٦٥'>مَرَرْتُ عَلَيْهِ</قول>
   أَنْ يُرِيْدَ مُرُوْرَهُ عَلَى مَكَاْنِهِ وَلَكِنَّهُ اتَّسَعَ</مقطع>
  <مقطع هوية='٨٢٨٦٦'>وَتَقُوْلُ <قول هوية='٠١٠٨٣'>عَلَيْهِ مَاْلٌ</قول> وَهٰذَا كَالْمَثَلِ</مقطع>
  <مقطع هوية='٩٤٢٨٨'>كَمَا يَثْبُتُ الشَّيْءُ عَلَى الْمَكَاْنِ كَذٰلِكَ يَثْبُتُ هٰذَا عَلَيْهِ</مقطع>
  <مقطع هوية='٨٠٤٤٣'>فَقَدْ يَتَّسِعُ هٰذَا فِي الْكَلَاْمِ وَيَجِيْءُ كَالْمَثَلِ</مقطع>
  <مقطع هوية='٦٢٧٢٢'>وَهُوَ اسْمٌ وَلَا يَكُوْنُ إِلَّا ظَرْفًا</مقطع>
  <مقطع هوية='٠٥٥١٦'>وَيَدُّلُكَ عَلَى أَنَّهُ اسْمٌ قَوْلُ بَعْضِ الْعَرَبِ <قول هوية='٢٤٤٢١'>نَهَضَ مِنْ عَلَيْهِ</قول></مقطع>

  <مقطع هوية='٦١٤٣٣'>قَاْلَ الشَّاْعِرُ</مقطع>
  <شاهدة هوية='٥٣٨٢٥'>
    <بيت>
      <مصراع>غَدَتْ <ثبات>مِنْ عَلَيْهِ</ثبات> بَعْدَ مَا تَمَّ خِمْسُهَا</مصراع>
      <مصراع>تَصِلُّ وَعَنْ قَيْضٍ بِبَيْدَاْءَ مَجْهَلِ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٨٦٤٨٦'>وَأَمَّا <حرف>إِلَى</حرف></مقطع>
  <مقطع هوية='٦٣٠٣٧'>فَمُنْتَهًى لِابْتِدَاْءِ الْغَاْيَةِ</مقطع>
  <مقطع هوية='٩٢٧٢١'>تَقُوْلُ <قول هوية='٨٧٥٨٦'>مِنْ كَذَا إِلَى كَذَا</قول>
  </مقطع>
  <مقطع هوية='٨٧٨٣٠'>وَكَذٰلِكَ <حرف>حَتَّى</حرف> وَقَدْ بُيِّنَ أَمَرُهَا فِي بَاْبِهَا</مقطع>
  <مقطع هوية='٦٠٩٢٧'>وَلَهَا فِي الْفِعْلِ نَحْوٌ لَيْسَ لِـ <حرف>إِلَى</حرف></مقطع>
  <مقطع هوية='٨٤٠٧٠'>وَيَقُوْلُ الرَّجُلُ <قول هوية='١٥٤٣٧'>إِنَّمَا أَنَا إِلَيْكَ</قول></مقطع>
  <مقطع هوية='٦٤٨٠٥'>أَيْ <قول هوية='٩٦٥٥٩'>إِنَّمَا أَنْتَ غَاْيَتِي</قول></مقطع>
  <مقطع هوية='٥٥٨٠٨'>وَلَا تَكُوْنُ <حرف>حَتَّى</حرف> هٰهُنَا</مقطع>
  <مقطع هوية='٤٤١٨٤'>فَهٰذَا أَمْرُ <حرف>إِلَى</حرف> وَأَصْلُهُ وَإِنْ اتَّسَعَتْ</مقطع>
  <مقطع هوية='٤٥٤٦٥'>وَهِيَ أَعَمُّ فِي الْكَلَاْمِ مِنْ <حرف>حَتَّى</حرف>
  </مقطع>
  <مقطع هوية='٧٩٧٩٤'>تَقُوْلَ <قول هوية='٥١٦٤٨'>قُمْتُ إِلَيْهِ</قول></مقطع>
  <مقطع هوية='٢٦٢٦٤'>فَجَعَلْتَهُ مُنْتَهَاْكَ مِنْ مَكَاْنِكَ</مقطع>
 <مقطع هوية='٢٧٨٦٥'>وَلَا تَقُوْلُ <حرف>حَتَّاْهُ</حرف></مقطع>

 <رأس/>
 <مقطع هوية='٩٠٦٢٩'>وَأَمَّا <حرف>حَسْبُ</حرف> فَمَعْنَاْهُ كَمَعْنَى <حرف>قَطْ</حرف></مقطع>
  <مقطع هوية='٤١٠٨٦'>وَأَمَّا <حرف>غَيْرُ</حرف> وَ<حرف>سِوَى</حرف> فَبَدَلٌ</مقطع>
  <مقطع هوية='٣٨٥٣١'>وَ<حرف>كُلٌّ</حرف> عَمٌّ</مقطع>
  <مقطع هوية='٧٤٧٧٧'>وَ<حرف>بَعْضٌ</حرف> اخْتِصَاْصٌ</مقطع>
  <مقطع هوية='٧٣٥٢٦'>وَ<حرف>مِثْلٌ</حرف> تَسْوِيَةٌ</مقطع>
  <مقطع هوية='٤٤٩٣٠'>وَأَمَّا <قول هوية='٨١٥٢٥'>بَلْهَ زَيْدٍ</قول></مقطع>
  <مقطع هوية='٩٨٤٤٠'>فَيَقُوْلُ <قول هوية='٨٨٥٨٤'>دَعْ زَيْدًا</قول></مقطع>
  <مقطع هوية='٥٧٦٣٢'>وَ<حرف>بَلْهَ</حرف> هٰهُنَا بِمَنْزِلَةِ الْمَصْدَرِ</مقطع>
  <مقطع هوية='٤٧١٨٨'>كَمَا تَقُوْلُ <حرف>ضَرْبَ زَيْدٍ</حرف></مقطع>

  <مقطع هوية='٠٤٨٩٢'>وَ<حرف>عِنْدَ</حرف> لِحُضُوْرِ الشَّيْءِ وَدُنُوِّهِ</مقطع>
  <مقطع هوية='١٤٤٧١'>وَأَمَّا <حرف>قِبَلَ</حرف> فَهُوَ لِمَا وَلِيَ الشَّيْءَ</مقطع>
  <مقطع هوية='١٥٤٢٦'>تَقُوْلُ <قول هوية='٩٩١٥٦'>ذَهَبَ قِبَلَ السُّوْقِ</قول> أَيْ <حرف>نَحْوَ السُّوْقِ</حرف></مقطع>
  <مقطع هوية='٣٧٩٣٦'>وَ<قول هوية='٦٤٦٧٥'>لِي قِبَلَكَ مَاْلٌ</قول>
  أَيْ <حرف>فِيْمَا يَلِيْكَ</حرف></مقطع>
  <مقطع هوية='٥٠٨٢١'>وَلَكِنَّهُ اتَّسَعَ حَتَّى أُجْرِيَ مُجْرَى <حرف>عَلَى</حرف> إِذَا قُلْتَ <قول هوية='٠٣٣٩٢'>لِي عَلَيْكَ</قول></مقطع>
  <مقطع هوية='٥٦٦١٨'>وَأَمَّا <حرف>نَوْلَ</حرف> فَتَقُوْلُ <قول هوية='١٤٩٤٦'>نَوْلُكَ أَنْ تَفْعَلَ كَذَا وَكَذَا</قول></مقطع>
  <مقطع هوية='٥٠٨٧٢'>أَيْ <قول هوية='٨٧١٨١'>يَنْبَغِي لَكَ فِعْلُ كَذَا وَكَذَا</قول>
  </مقطع>
  <مقطع هوية='٧١٦٨٣'>وَأَصْلُهُ مِنَ التَّنَاْوُلِ</مقطع>
  <مقطع هوية='٠٨٩٩٢'>كَأَنَّهُ يَقُوْلُ <قول هوية='٦٩٧١٧'>تُنَاْوُلُكَ كَذَا وَكَذَا</قول></مقطع>
  <مقطع هوية='٨٥٢٥٥'>وَإِذَا قَاْلَ <قول هوية='١١٠٤٢'>لَا نَوْلُكَ</قول> فَكَأَنَّهُ يَقُوْلُ <قول هوية='٣٨٨٥٢'>أَقْصِرْ</قول></مقطع>
  <مقطع هوية='٨٤٩٩٩'>وَلَكِنَّهُ صَاْرَ فِيْهِ مَعْنَى <حرف>يَنْبَغِي لَكَ</حرف></مقطع>

  <مقطع هوية='٨٩٣٢٩'>وَأَمَّا <حرف>إِذَا</حرف> فَلِمَا يُسْتَقْبَلُ مِنَ الدَّهْرِ</مقطع>
  <مقطع هوية='٢٤٧٢٩'>وَفِيْهَا مُجَاْزَاْةٌ وَهِيَ ظَرْفٌ</مقطع>
  <مقطع هوية='٢٤٩٧١'>وَتَكُوْنُ لِلشَّيْءِ تُوَاْفِقُهُ فِي حَاْلٍ أَنْتَ فِيْهَا</مقطع>
  <مقطع هوية='٧٢٢٧١'>وَذٰلِكَ قَوْلُكَ <قول هوية='٦٦٥٨٥'>مَرَرْتُ فَإِذَا زَيْدٌ قَاْئِمٌ</قول></مقطع>
  <مقطع هوية='٢٣٤٩٤'>وَتَكُوْنُ <حرف>إِذْ</حرف> مِثْلَهَا أَيْضًا</مقطع>
  <مقطع هوية='٥٩٧٣٠'>وَلَا يَلِيْهَا إِلَّا الْفِعْلُ الْوَاْجِبُ</مقطع>
  <مقطع هوية='٣٥٧٧٤'>وَذٰلِكَ قَوْلُكَ <قول هوية='٩٨٥٧٨'>بَيْنَمَا أَنَا كَذٰلِكَ إِذْ جَاْءَ زَيْدٌ</قول></مقطع>
  <مقطع هوية='٥٠٥١٩'>وَ<قول هوية='٧٠٩٠٥'>قَصَدْتُ قَصْدَهُ إِذِ انْتَفَخَ عَلَيَّ فُلَاْنٌ</قول></مقطع>
  <مقطع هوية='٢٤٧٧٠'>فَهٰذَا لِمَا تُوَاْفِقُهُ وَتَهْجُمُ عَلَيْهِ مِنْ حَاْلٍ أَنْتَ فِيْهَا</مقطع>

  <مقطع هوية='٢٤٠٩١'>وَأَمَّا <حرف>لَكِنَّ</حرف> خَفِيْفَةً وَثَقِيْلَةً فَتُوْجِبُ بِهَا بَعْدَ نَفْيٍ</مقطع>
  <مقطع هوية='٤٧٦٤٨'>وَأَمَّا <حرف>سَوْفَ</حرف> فَتَنْفِيْسٌ فِيْمَا لَمْ يَكُنْ بَعْدُ</مقطع>
  <مقطع هوية='١٤١١٨'>أَلَا تَرَاْهُ يَقُوْلُ <قول هوية='١٨٥٤٣'>سَوَّفْتُهُ</قول></مقطع>
  <مقطع هوية='٥٥٠٤٢'>وَأَمَّا <حرف>قَبْلُ</حرف> فَلِلْأَوَّلِ</مقطع>
  <مقطع هوية='٤٧٨٠١'>وَ<حرف>بَعْدُ</حرف> لِلْآخِرِ</مقطع>
  <مقطع هوية='٥٧٦٤٠'>وَهُمَا اسْمَاْنِ يَكُوْنَاْنِ ظَرْفَيْنِ</مقطع>
  <مقطع هوية='٦٣٣١٣'>وَ<حرف>كَيْفَ</حرف> عَلَى أَيِّ حَاْلٍ</مقطع>
  <مقطع هوية='١٢٢٤٩'>وَ<حرف>أَيْنَ</حرف> أَيُّ مَكَاْنٍ</مقطع>
  <مقطع هوية='٠٧٠٨٩'>وَ<حرف>مَتَى</حرف> أَيُّ حِيْنٍ</مقطع>
  <مقطع هوية='٥٦٩١٠'>وَأَمَّا <حرف>حَيْثُ</حرف> فَمَكَاْنٌ</مقطع>
  <مقطع هوية='٢٨٤١٤'>بِمَنْزِلَةِ قَوْلِكَ <قول هوية='٣٩١١٤'>هُوَ فِي الْمَكَاْنِ الَّذِي فِيْهِ زَيْدٌ</قول></مقطع>

  <رأس/>
  <مقطع هوية='٣٨٨٨٧'>وَهَذِهِ الْأَسْمَاْءُ تَكُوْنُ ظُرُوْفًا</مقطع>
  <مقطع هوية='٦٨٢٧٠'>وَأَمَّا <حرف>خَلْفُ</حرف> فَمُؤَخَّرُ الشَّيْءِ</مقطع>
  <مقطع هوية='٢٣٦٧٢'>وَ<حرف>أَمَاْمُ</حرف> مُقَدَّمُهُ</مقطع>
  <مقطع هوية='٦١٠١٩'>وَ<حرف>قُدَّاْمُ</حرف> بِمَنْزِلَةِ <حرف>أَمَاْمُ</حرف></مقطع>
  <مقطع هوية='١٤٥٧٧'>وَ<حرف>فَوْقُ</حرف> أَعْلَى الشَّيْءِ</مقطع>
  <مقطع هوية='٣٦١١٣'>وَقَاْلُوْا <قول هوية='٦٣٣٥١'>فَوْقَكَ فِي الْعِلْمِ وَالْعَقْلِ</قول> عَلَى نَحْوِ الْمَثَلِ</مقطع>
  <مقطع هوية='٢٥٣٦٢'>وَهَذِهِ الْأَسْمَاْءُ تَكُوْنُ ظُرُوْفًا</مقطع>

  <رأس/>
  <مقطع هوية='٩١٤٧١'>وَ<حرف>لَيْسَ</حرف> نَفْيٌ</مقطع>
  <مقطع هوية='٨٧١٤١'>وَ<حرف>أَيُّ</حرف> مَسْأَلَةٌ لِيُبَيَّنَ لَكَ بَعْضُ الشَّيْءِ</مقطع>
  <مقطع هوية='٣٨٢٦٣'>وَهِيَ تَجْرِي مَجْرَى <حرف>مَا</حرف> فِي كُلِّ شَيْءٍ</مقطع>
  <مقطع هوية='٦٦٣٨٢'>وَ<حرف>مَنْ</حرف> مِثْلُ <حرف>أَيٍّ</حرف> أَيْضًا إِلَّا أَنَّهُ لِلنَّاْسِ</مقطع>
  <مقطع هوية='٥٦٠٩٠'>وَ<حرف>إِنَّ</حرف> تَوْكِيْدٌ لِقَوْلِهِ <قول هوية='٠٩٧٤٩'>زَيْدٌ مُنْطَلِقٌ</قول></مقطع>
  <مقطع هوية='١٣٥٤١'>وَإِذَا خَفَّفْتَ فَهِيَ كَذٰلِكَ</مقطع>
  <مقطع هوية='٢٩٨٠٤'>تُؤَكِّدُ مَا تُكَلِّمُ بِهِ وَلِيَثْبُتَ الْكَلَاْمُ</مقطع>
  <مقطع هوية='١٣٧٥٢'>غَيْرَ أَنَّ لَاْمَ التَّوْكِيْدِ تَلْزَمُهَا عِوَضًا مِمَّا ذَهَبَ مِنْهَا</مقطع>
  <مقطع هوية='٥١٩٩٠'>وَ<حرف>لَيْتَ</حرف> تَمَنٍّ</مقطع>
  <مقطع هوية='٧٠٧٠٤'>وَ<حرف>لَعَلَّ</حرف> وَ<حرف>عَسَى</حرف> طَمَعٌ وَإِشْفَاْقٌ</مقطع>
  <مقطع هوية='٣٨٦١٦'>وَأَمَّا <حرف>لَدُنْ</حرف> فَالْمَوْضِعُ الَّذِي هُوَ أَوَّلُ الْغَاْيَةِ</مقطع>
  <مقطع هوية='٧٨٦٦٣'>وَهُوَ اسْمٌ يَكُوْنُ ظَرْفًا</مقطع>
  <مقطع هوية='٦٥٣٠٣'>يَدُلُّكَ عَلَى أَنَّهُ اسْمٌ قَوْلُهُمْ <حرف>مَنْ لَدُنْ</حرف></مقطع>
  <مقطع هوية='٤٨٣٧٢'>وَقَدْ يَحْذَفُ بَعْضُ الْعَرَبِ النُّوْنَ حَتَّى يَصِيْرَ عَلَى حَرْفَيْنِ</مقطع>
  <مقطع هوية='٣١٦٩٠'>قَاْلَ الْرَّاْجِزُ <شاعر>غَيْلَاْنُ</شاعر></مقطع>
  <شاهدة هوية='٤٣٤٩٦' شاعر="غَيْلَاْنُ">
    <بيت>
      <مصراع>يَسْتَوْعِبُ الْبَوْعَيْنِ مِنْ جَرِيْرِهِ</مصراع>
      <مصراع>مِنْ <ثبات>لَدُ</ثبات> لَحْيَيْهِ إِلَى مُنْحُوْرِهِ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٣١٩٢٠'>وَ<حرف>لَدَى</حرف> بِمَنْزِلَةِ <حرف>عِنْدَ</حرف></مقطع>
  <مقطع هوية='٠٩١٤٦'>وَأَمَّا <حرف>دُوْنَ</حرف> فَتَقْصِيْرٌ عَنْ الْغَاْيَةِ وَهُوَ يَكُوْنُ ظَرْفًا</مقطع>

  <رأس/>
  <مقطع هوية='٤١٠١٧'>وَاعْلَمْ أَنَّ مَا يَكُوْنُ ظَرْفًا</مقطع>
  <مقطع هوية='٩٠٠٤١'>بَعْضُهُ أَشَدُّ تَمَكُّنًا فِي الْأَسْمَاْءِ مِنْ بَعْضٍ</مقطع>
  <مقطع هوية='٢٨٣٧٥'>وَمِنْهُ مَا لَا يَكُوْنُ إِلَّا ظَرْفًا</مقطع>
  <مقطع هوية='٩٨٠١٩'>وَقَدْ بُيِّنَ ذٰلِكَ فِي مَوْضِعِهِ</مقطع>

  <رأس/>
  <مقطع هوية='٦٠٤٢٨'>وَأَمَّا <حرف>قُبَاْلَةُ</حرف> فْمُوَاْجَهَةٌ</مقطع>
  <مقطع هوية='٩٦٣٩٣'>وَأَمَّا <حرف>بَلَى</حرف> فَتُوْجِبُ بِهِ بَعْدَ النَّفْيِ</مقطع>
  <مقطع هوية='٢٨٥٣٩'>وَأَمَّا <حرف>نَعَمْ</حرف> فَعِدَةٌ وَتَصْدِيْقٌ</مقطع>
  <مقطع هوية='٥٦٢٩٣'>تَقُوْلُ <قول هوية='٧٢٦٧٠'>قَدْ كَاْنَ كَذَا وَكَذَا</قول>
  فَيَقُوْلُ <قول هوية='١٦٦٨٠'>نَعَمْ</قول></مقطع>
  <مقطع هوية='٦٦٦٢١'>وَلَيْسَا اسْمَيْنِ</مقطع>
  <مقطع هوية='٦٤٣٥٣'>وَ<حرف>قُبَاْلَةَ</حرف> اسْمٌ يَكُوْنُ ظَرْفًا</مقطع>
  <مقطع هوية='١٢١٢٦'>فَإِذَا اسْتَفْهَمْتُ فَقُلْتُ <قول هوية='٤٣٥٢٤'>أَتَفْعَلُ</قول> أَجَبْتَ بِـ<حرف>نَعَمْ</حرف></مقطع>
  <مقطع هوية='٧٧٢٦٣'>فَإِذَا قُلْتُ <قول هوية='٦٢٠٨٦'>أَلَسْتَ تَفْعَلُ</قول> قَاْلَ <قول هوية='٥٩٦٣٠'>بَلَى</قول></مقطع>
  <مقطع هوية='٨٠٥٦٢'>يَجْرِيَاْنِ مَجْرَاْهُمَا قَبْلَ أَنْ تَجِئَ الْأَلِفُ</مقطع>
  <مقطع هوية='٩٤٩١٨'>وَأَمَّا <حرف>بَجَلْ</حرف> فَبِمَنْزِلَةِ <حرف>حَسْبُ</حرف></مقطع>
  <مقطع هوية='٤٠٣٥٩'>وَأَمَّا <حرف>إِذَنْ</حرف> فَجَوَاْبٌ وَجَزَاْءٌ</مقطع>
  <مقطع هوية='٨٧٩٤٦'>وَأَمَّا <حرف>لَمَّا</حرف> فَهِيَ لِلْأَمْرِ الَّذِي قَدْ وَقَعَ لِوُقُوْعِ غَيْرِهِ</مقطع>
  <مقطع هوية='٩٥٤٣٥'>وَإِنَّمَا تَجِيْءُ بِمَنْزِلَةِ <حرف>لَوْ</حرف> لِمَا ذَكَرْنَا</مقطع>
  <مقطع هوية='٧٩٤٥٥'>فَإِنَّمَا هُمَا لِابْتِدَاْءٍ وَجَوَاْبٍ</مقطع>
  <مقطع هوية='٦٠٦٦٤'>وَكَذٰلِكَ <حرف>لَوْمَا</حرف> وَ<حرف>لَوْلَا</حرف></مقطع>
  <مقطع هوية='٣٦٦٧٩'>فَهُمَا لِابْتِدَاْءٍ وَجَوَاْبٍ</مقطع>
  <مقطع هوية='٦١٤٨٤'>فَالْأَوَّلُ سَبَبُ مَا وَقَعَ وَمَا لَمْ يَقَعْ</مقطع>

  <مقطع هوية='٣٢٧٠٣'>وَأَمَّا <حرف>أَمَّا</حرف> فَفِيْهَا مَعْنَى الْجَزَاْءِ</مقطع>
  <مقطع هوية='٤١٤٢١'>كَأَنَّهُ يَقُوْلُ <قول هوية='٨٠٤٤٤'>عَبْدُ اللهِ مَهْمَا يَكُنْ مِنْ أَمْرِهِ فَمُنْطَلِقٌ</قول></مقطع>
  <مقطع هوية='٥٩٧٦٢'>أَلَا تَرَى أَنَّ الْفَاْءَ لَاْزِمَةٌ لَهَا أَبَدًا</مقطع>

  <مقطع هوية='٣٧٢٤٧'>وَأَمَّا <حرف>أَلَا</حرف> فَتَنْبِيْهٌ</مقطع>
  <مقطع هوية='٥٤٨٥٥'>تَقُوْلُ <قول هوية='٧٣١٠٣'>أَلَا إِنَّهُ ذَاْهِبٌ</قول>
  <حرف>أَلَا</حرف> بَلَى</مقطع>
  <مقطع هوية='٨٩٧٨٤'>وَأَمَّا <حرف>كَلَّا</حرف> فَرَدْعٌ وَزَجْرٌ</مقطع>
  <مقطع هوية='٠٦٦٥٧'>وَ<حرف>أَنَّى</حرف> تَكُوْنُ فِي مَعْنَى <حرف>كَيْفَ</حرف> وَ<حرف>أَيْنَ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٦٥٤٠٨'>وَإِنَّمَا كَتَبْنَا مِنْ الثَّلَاْثَةِ وَمَا جَاْوَزَهَا</مقطع>
  <مقطع هوية='٨٧١٥٦'>غَيْرَ الْمُتَمَكِّنِ الْكَثِيْرَ الِاسْتِعْمَاْلِ</مقطع>
  <مقطع هوية='٧٤١١٣'>مِنَ الْأَسْمَاْءِ وَغَيْرِهَا الَّذِي تَكَلَّمُ بِهِ الْعَاْمَّةُ</مقطع>
  <مقطع هوية='٦٢٠٣٤'>لِأَنَّهُ أَشَدُّ تَفْسِيْرًا</مقطع>
  <مقطع هوية='٧٤٤٧٨'>وَكَذٰلِكَ الْوَاْضِحُ عِنْدَ كُلِّ أَحَدٍ هُوَ أَشَدُّ تَفْسِيْرًا</مقطع>
  <مقطع هوية='٩٩٣٣٨'>لِأَنَّهُ تُوَضَّحُ بِهِ الْأَشْيَاْءُ</مقطع>
  <مقطع هوية='١٢٥٨٩'>فَكَأَنَّهُ تَفْسِيْرُ التَّفْسِيْرِ</مقطع>
  <مقطع هوية='٥٣١٩٥'>أَلَا تَرَى أَنَّ لَوْ أَنَّ إِنْسَاْنًا قَاْلَ
  <قبس>مَا مَعْنَى <حرف>أَيَّاْنَ</حرف></قبس></مقطع>
  <مقطع هوية='٨٢١٠٩'>فَقُلْتَ <حرف>مَتَى</حرف> كُنْتَ قَدْ أَوْضَحْتَ</مقطع>
  <مقطع هوية='٩٩٢٧٥'>وَإِذَا قَاْلَ <قبس>مَا مَعْنَى <حرف>مَتَى</حرف></قبس></مقطع>
  <مقطع هوية='٥٥٠٦٩'>قُلْتَ <حرف>فِي أَيِّ زَمَاْنٍ</حرف></مقطع>
  <مقطع هوية='٣٨١٣٣'>فَسَأَلَكَ عَنْ الْوَاْضِحِ</مقطع>
  <مقطع هوية='٤٠٣٦٠'>شَقَّ عَلَيْكَ أَنْ تَجِيْءَ بِمَا تُوْضِحُ بِهِ الْوَاْضِحَ</مقطع>
  <مقطع هوية='٨٥١٠٨'>وَإِنَّمَا كَتَبْنَا مِنَ الثَّلَاْثَةِ عَلَى نَحْوِ الْحَرْفِ وَالْحَرْفَيْنِ</مقطع>
  <مقطع هوية='٨٨٤٦٤'>وَفِيْهِ الْإِشْكَاْلُ وَالنَّظَرُ</مقطع>

