<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-١٥٥"
     درنبورج="٢-١٥٨"
     البكاء="٥-٢٢٩"
     هارون="٣-٥٢٣"
     يعقوب="٤-٨"
     رقم="٤٠٥">

  <عنوان>
    <مقطع هوية='٩٥١٦٤'>هٰذَا بَاْبُ النُّوْنِ الثَّقِيْلَةِ وَالْخَفِيْفَةِ فِي فِعْلِ الِاثْنَيْنِ وَفِعْلِ جَمِيْعِ النِّسَاْءِ</مقطع>
  </عنوان>

  <رأس/>
  <مقطع هوية='٦٤٥٧٤'>فَإِذَا أَدْخَلْتَ الثَّقِيْلَةَ فِي فِعْلِ الِاثْنَيْنِ</مقطع>
  <مقطع هوية='٤١٨٧٣'>ثَبَتَتْ الْأَلِفُ الَّتِي قَبْلَهَا</مقطع>
  <مقطع هوية='٤٥٩٤٠'>وَذٰلِكَ قَوْلُكَ <قول هوية='٤١٧٠٣'>لَا تَفْعَلَانِّ ذٰلِكَ</قول></مقطع>
  <مقطع هوية='٢٢٥٢٤'>وَ<آية هوية='٨٩٤٣٨' سورة="١٠" آية="٨٩">لَا تَتَّبِعَآنِّ سَبِيْلَ ٱلَّذِيْنَ لَا يَعْلَمُوْنَ</آية></مقطع>
  <مقطع هوية='٠٠١٣٥'>وَتَقُوْلُ <قول هوية='٥٣٦١٦'>افْعَلَانِّ ذٰلِكَ</قول>
  وَ<قول هوية='٤١٩٦٢'>هَلْ تَفْعَلَانِّ ذٰلِكَ</قول></مقطع>
  <مقطع هوية='٠٦٦٦٠'>فَنُوْنُ الرَّفْعِ تُذْهَبُ هٰهُنَا</مقطع>
  <مقطع هوية='٩٦٧١٨'>كَمًا ذَهَبَتْ فِي فِعْلِ الْجَمِيْعِ</مقطع>
  <مقطع هوية='٥٦٠٥٨'>وَإِنَّمَا تَثْبُتُ الأَلِفُ هٰهُنَا فِي كَلَاْمِهِمْ</مقطع>
  <مقطع هوية='٠١٨١٨'>لأَنَّهُ قَدْ يَكُوْنُ بَعْدَ الأَلِفِ حَرْفٌ سَاْكِنٌ</مقطع>
  <مقطع هوية='٣٧١٢٠'>إِذَا كَاْنَ مُدْغَمًا فِي حَرْفٍ مِنْ مَوْضِعِهِ</مقطع>
  <مقطع هوية='٨٦٩٣٢'>وَكَاْنَ الآخِرُ لَاْزِمًا لِلأَوَّلِ</مقطع>
  <مقطع هوية='٧٨٤١٢'>وَلَمْ يَكُنْ لَحَاْقُ الآخِرِ بَعْدَ اسْتِقْرَاْرِ الأَوَّلِ فِي الْكَلَاْمِ</مقطع>
  <مقطع هوية='٧٥٣٣٥'>وَذٰلِكَ نَحْوَ قَوْلِكَ <حرف>رَادٌّ</حرف> وَ<حرف>أُرَادُّ</حرف></مقطع>
  <مقطع هوية='٩٢١٨٠'>فَالدَّاْلُ الآخِرَةُ لَمْ تَلْحَقِ الأُوْلَى</مقطع>
  <مقطع هوية='٤٤٩٧٦'>وَ<!-- لَمْ --> تَكُوْنُ الأُوْلَى فِي شَيْءٍ يَكُوْنُ كَلَاْمًا بِهَا
  وَالآخِرَةُ لَيْسَتْ بَعْدَهَا</مقطع>
  <مقطع هوية='١٧٤٤٣'>وَلَكِنَّهُمَا يَقَعَاْنِ جَمِيْعًا</مقطع>
  <مقطع هوية='٧٨١٩٦'>وَكَذٰلِكَ الثَّقِيْلَةُ هُمَا نُوْنَاْنِ تَقَعَاْنِ مَعًا</مقطع>
  <مقطع هوية='٦٥٦٩٩'>لَيْسَتْ تَلْحَقُ الآخِرَةُ الأُوْلَى بَعْدَ مَا يَسْتَقِرُّ كَلَاْمًا</مقطع>
  <مقطع هوية='٠٨٢٥٦'>فَالْخَفِيْفَةُ فِي الْكَلَاْمِ عَلَى حِدَةٍ وَالثَّقِيْلَةُ عَلَى حِدَةٍ</مقطع>
  <مقطع هوية='٠٨٢٧١'>وَلِأَنْ تَكُوْنَ الْخَفِيْفَةُ حُذِفَ عَنْهَا الْمُتَحَرِّكُ أَشْبَهَ</مقطع>
  <مقطع هوية='٨٣٨٤٠'>لأَنَّ الثَّقِيْلَةَ فِي الْكَلَاْمِ أَكْثَرُ</مقطع>
  <مقطع هوية='٢٥٧٨٥'>وَلَكِنَّا جَعَلْنَاْهَا عَلَى حِدَةٍ</مقطع>
  <مقطع هوية='٤١٦٧٦'>لأَنَّهَا فِي الْوَقْفِ كَالتَّنْوِيْنِ</مقطع>
  <مقطع هوية='٧٧٥٢٢'>وَتَذْهَبُ إِذَا كَاْنَ بَعْدَهَا أَلِفٌ خَفِيْفٌةٌ أَوْ أَلِفٌ وَلَاْمٌ</مقطع>
  <مقطع هوية='٩١٠٨٠'>كَمَا تَذْهَبُ لِالْتِقَاْءِ السَّاْكِنَيْنِ مَا لَمْ يُحْذَفْ عَنْهُ شَيْءٌ</مقطع>
  <مقطع هوية='١٢٨٤٢'>وَلَوْ كَاْنَتْ بِمَنْزِلَةِ نُوْنٍ <حرف>لَكِنْ</حرف> وَ<حرف>أَنْ</حرف> وَ<حرف>كَأَنْ</حرف> الَّتِي حُذِفَتْ عَنْهَا الْمُتَحَرِّكَةُ</مقطع>
  <مقطع هوية='٩٤٨٤٩'>لَكَاْنَتْ مِثْلَهَا فِي الْوَقْفِ وَالْأَلِفِ الْخَفِيْفَةِ وَالْأَلَفِ وَاللَّاْمِ</مقطع>
  <مقطع هوية='٩١٨١٠'>فَإِنَّمَا النُّوْنُ الثَّقِيْلَةُ بِمَنْزِلَةِ بَاْءِ <حرف>قُبَّ</حرف>
  وَطَاْءِ <حرف>قَطُّ</حرف></مقطع>
  <مقطع هوية='٨١١٠٨'>وَلَيْسَ حَرْفٌ سَاْكِنٌ فِي هَذِهِ الصِّفَةِ</مقطع>
  <مقطع هوية='٣٠٥١٥'>إِلَّا بَعْدَ أَلِفٍ أَوْ حَرْفِ لِيْنٍ كَالْأَلِفِ</مقطع>
  <مقطع هوية='٦٢٢٤٨'>وَذٰلِكَ نَحْوُ <!-- تَعَوُّدِ --> <قول هوية='٤٠٠٦٠'>تُمودَّ الثَّوْبُ</قول>
  وَ<قول هوية='٣٠٣٨٥'>تَضْرِبِينِّي</قول> تُرِيْدُ الْمَرْأَةَ</مقطع>
  <مقطع هوية='٩١٤٠٥'>وَتَكُوْنُ فِي يَاْءِ <حرف>أَصَيْمَّ</حرف></مقطع>
  <مقطع هوية='٦٦٨٥٥'>وَلَيْسَ مِثْلَ هَذِهِ الْوَاْوِ وَالْيَاْءِ</مقطع>
  <مقطع هوية='١١٨٥٥'>لِأَنَّ حَرَكَةَ مَا قَبْلَهُنَّ مِنْهُنَّ</مقطع>
  <مقطع هوية='٦٤٢٩٦'>كَمَا أَنَّ مَا قَبْلَ الْأَلِفِ مَفْتُوْحٌ</مقطع>
  <مقطع هوية='٨٣٨٨٩'>وَقَدْ أَجَاْزُوْهُ فِي مِثْلِ يَاْءِ <حرف>أُصَيْمَّ</حرف> لِأَنَّهُ حَرْفُ لِيْنٍ</مقطع>

  <رأس/>
  <مقطع هوية='٣٤٣٢٠'>وَقَاْلَ <سند>الْخَلِيْلُ</سند> إِذَا أَرَدْتَ الْخَفِيْفَةَ فِي فِعْلِ الِاثْنَيْنِ</مقطع>
  <مقطع هوية='٦٢٦٤٤'>كَاْنَ بِمَنْزِلَتِهِ إِذَا لَمْ تُرِدْ الْخَفِيْفَةَ فِي فِعْلِ الِاثْنَيْنِ فِي الْوَصْلِ وَالْوَقْفِ</مقطع>
  <مقطع هوية='١١١٢٢'>لِأَنَّهُ لَا يَكُوْنُ بَعْدَ الْأَلِفِ حَرْفٌ سَاْكِنٌ لَيْسَ بِمَدْغَمٍ</مقطع>
  <مقطع هوية='٨٨٣٧٥'>وَلَا تَحْذِفُ الْأَلِفَ فَيَلْتَبِسَ فِعْلُ الْوَاْحِدِ وَالِاثْنَيْنِ</مقطع>
  <مقطع هوية='٠٨٢٢٩'>وَذٰلِكَ قَوْلُكَ <حرف>اضْرِبَا</حرف> وَأَنْتَ تُرِيْدُ النُّوْنَ</مقطع>
  <مقطع هوية='٦٩٤٦٥'>وَكَذٰلِكَ لَوْ قُلْتَ <حرف>اضْرِبَاْنِي</حرف> وَ<حرف>اضْرِبَا نُعْمَاْنَ</حرف></مقطع>
  <مقطع هوية='٦٧٢٤١'>لَا تَرُدَّنَّ الْخَفِيْفَةَ</مقطع>
  <مقطع هوية='٨٦٠٦٣'>وَلَا تَقُلْ <قبس>ذَا مَوْضِعُ إِدْغَاْمٍ فَأَرُدُّهَا</قبس></مقطع>
  <مقطع هوية='٠٠٧٤٥'>لِأَنَّهَا قَدْ ثَبَتَتْ مَدْغَمَةً وَالرَّدُّ خَطَأٌ هٰهُنَا</مقطع>
  <مقطع هوية='٧٦٠٦٥'>إِذْ كَاْنَ مَحْذُوْفًا فِي الْوَصْلِ وَالْوَقْفِ
  إِذَا لَمْ تُتْبِعْهُ كَلَاْمًا</مقطع>
  <مقطع هوية='٢١٨٥٩'>وَكَيْفَ تَرُدُّهُ وَأَنْتَ لَوْ جَمَعْتَ هَذِهِ النُّوْنَ إِلَى نُوْنٍ ثَاْنِيَةٍ</مقطع>
  <مقطع هوية='٥٢٢٥٤'>لَاعْتَلَّتْ وَأُدْغِمَتْ وَحُذِفَتْ فِي قَوْلِ بَعْضِ الْعَرَبِ</مقطع>
  <مقطع هوية='٣٢١٨٤'>فَإِذَا كَفُّوْا مَؤُنَتَهَا لَمْ يَكُوْنُوْا لَيَرُدُّوْهَا إِلَى مَا يَسْتَثْقِلُوْنَ</مقطع>
  <مقطع هوية='٦٥٨٩٢'>وَلَوْ قُلْتَ ذَا لَقُلْتَ <قول هوية='٠٢١٢٨'>اضْرِبَا نُّعْمَاْنَ</قول></مقطع>
  <مقطع هوية='٨٧٢٨٥'>لأَنَّ النُّوْنَ تُدْغَمُ فِي النُّوْنِ</مقطع>
  <مقطع هوية='٣٦٩١١'>وَلَوْ قُلْتَ ذَا لَقُلْتَ <قول هوية='٤٣٩١٥'>اضْرِبَانّ أبَا</قول></مقطع>
  <مقطع هوية='٣٣٩٥٥'>كَمَا فِي قَوْلِ مَنْ لَمْ يَهْمِزْ</مقطع>
  <مقطع هوية='٣٤٩٤٩'>لِأَنَّ ذَا مَوْضِعٌ لَمْ يَمْتَنِعْ فِيْهِ السَّاْكِنُ مِنْ التَّحْرِيْكِ</مقطع>
  <مقطع هوية='٣٢٠٢٨'>فَتَرُدُّهَا إِذَا وَثِقْتُ بِالتَّحْرِيْكِ</مقطع>
  <مقطع هوية='١٩٣٨٦'>كَمَا رَدَدْتُهَا حَيْثُ وَثِقْتَ بِالْإِدْغَاْمِ</مقطع>
  <مقطع هوية='٠٨٢٤٤'>فَلَا تَرُدُّ فِي شَيْءٍ مِنْ هٰذَا</مقطع>
  <مقطع هوية='٣٢٠٦٢'>لِأَنَّكَ جِئْتَ بِهِ إِلَى شَيْءٍ قَدْ لَزِمَهُ الْحَذْفُ</مقطع>
  <مقطع هوية='٤٨٣٥٢'>أَلَا تَرَى أَنَّكَ لَوْ لَمْ تَخَفِ اللُّبْسَ فَحَذَفْتَ الْأَلِفَ لَمْ تَرُدَّهَا</مقطع>
  <مقطع هوية='٤١٣٢٤'>فَكَذٰلِكَ لَا تَرُدُّ النُّوْنَ</مقطع>
  <مقطع هوية='٢٣٤٥٧'>وَلَوْ قُلْتَ ذَا لَقُلْتَ <حرف>جِيْؤُوْنِّي</حرف>
  فِي قَوْلِكَ <حرف>جِيْؤُنِي</حرف></مقطع>
  <مقطع هوية='٠٥٩٣١'>لِأَنَّ الْوَاْوَ قَدْ ثَبَتَتْ وَبَعْدَهَا سَاْكِنٌ مُدْغَمٌ</مقطع>
  <مقطع هوية='٨٥٦٨١'>وَلَقُلْتَ <قول هوية='٢٣٠١٧'>جِيْؤُو نُّعْمَاْنَ</قول></مقطع>
  <مقطع هوية='٥٩٦٨٨'>وَالنُّوْنُ لَا تُرَدُّ هٰهُنَا</مقطع>
  <مقطع هوية='٨٢٥٤١'>كَمَا لَا تُرَدُّ فِي الْوَصْلِ وَالْوَقْفِ هَذِهِ الْوَاْوُ
  فِي نَحْوِ مَا ذَكَرْنَا</مقطع>
  <مقطع هوية='٧٨٦٤٤'>وَذٰلِكَ أَنَّكَ تَقُوْلُ لِلْجَمِيْعِ <قول هوية='٦٣٧٠٧'>جِيْؤُنَّ زَيْدًا</قول>
  تُرِيْدُ الثَّقِيْلَةَ</مقطع>
  <مقطع هوية='٣٨٣٩٨'>وَلَا تَرُدُّهَا فِي الْوَقْفِ وَلَا فِي الْوَصْلِ</مقطع>

  <رأس/>
  <مقطع هوية='٠٥٦٩٤'>وَإِنْ أَرَدْتَ الْخَفِيْفَةَ فِي فِعْلِ الِاثْنَيْنِ الْمُرْتَفِعِ</مقطع>
  <مقطع هوية='٤١٠٤٢'>قُلْتَ <قول هوية='٥٩٥١٧'>هَلْ تَضْرِبَاْنِ زَيْدًا</قول></مقطع>
  <مقطع هوية='١٨٠٢٨'>لِأَنَّكَ قَدْ أَمِنْتَ النُّوْنَ الْخَفِيْفَةَ</مقطع>
  <مقطع هوية='٩٣١٢٧'>وَإِنَّمَا أَذْهَبْتَ النَّوْنَ لِأَنَّهَا لَا تَثْبُتُ مَعَ نُوْنِ الرَّفْعِ</مقطع>
  <مقطع هوية='١٦٢٦٠'>فَإِذَا بَقِيَتْ نُوْنُ الرَّفْعِ لَمْ تَثْبُتْ بَعْدَهَا النُّوْنُ الْخَفِيْفَةُ</مقطع>
  <مقطع هوية='٥٥٦٠٨'>فَلَمَّا أَمِنُوْهَا ثَبَتَتْ نُوْنُ الرَّفْعِ فِي الصِّلَةِ</مقطع>
  <مقطع هوية='٢٠٧٨٩'>كَمَا ثَبَتَتْ نُوْنُ الرَّفْعِ فِي فِعْلِ الْجَمِيْعِ فِي الْوَقْفِ</مقطع>
  <مقطع هوية='٣٣٨٠٥'>وَرَدَدْتَ نُوْنَ الْجَمِيْعِ كَمَا رَدَدْتَ يَاْءَ <حرف>اضْرِبِي</حرف>
  وَوَاْوَ <حرف>اضْرِبُوا</حرف></مقطع>
  <مقطع هوية='٠١٩٦١'>حِيْنَ أَمِنْتَ الْبَدَلَ مِنَ الْخَفِيْفَةِ فِي الْوَقْفِ</مقطع>

  <رأس/>
  <مقطع هوية='٨٦٣١٣'>وَإِذَا أَدْخَلْتَ الثَّقِيْلَةَ فِي فِعْلِ جَمِيْعِ النِّسَاْءِ</مقطع>
  <مقطع هوية='٣٥٧٣٦'>قُلْتَ <قول هوية='١٧٥٨٣'>اضْرِبَنَانِّ يَا نِسْوَةُ</قول></مقطع>
  <مقطع هوية='٠٠٧٩٩'>وَ<قول هوية='٩٠٧٠١'>هَلْ تَضْرِبْنَاْنِّ</قول> وَ<قول هوية='٥٢٩٢٨'>لَتَضْرِبْنَانِّ</قول></مقطع>
  <مقطع هوية='٢٦٨١٩'>فَإِنَّمَا أَلْحَقْتَ هَذِهِ الْأَلِفَ كَرَاْهِيَةَ النُّوْنَاْتِ</مقطع>
  <مقطع هوية='٠٦٣٤٠'>فَأَرَاْدُوْا أَنْ يَفْصِلُوْا لِالْتِقَاْئِهَا</مقطع>
  <مقطع هوية='٥٠٣٨٠'>كَمَا حَذَفُوْا نُوْنَ الْجَمِيْعِ لِلنُّوْنَاْتِ</مقطع>
  <مقطع هوية='٩٢٧٦٢'>وَلَمْ يَحْذِفُوْا نُوْنَ النِّسَاْءِ كَرَاْهِيَةَ أَنْ يَلْتَبِسَ فِعْلَهُنَّ وَفِعْلُ الْوَاْحِدِ</مقطع>
  <مقطع هوية='٥٤٩٩٢'>وَكُسِرَتِ الثُّقَيْلَةُ هٰهُنَا لأَنَّهَا بَعْدَ أَلِفٍ زَاْئِدَةٍ</مقطع>
  <مقطع هوية='٦٢٨١٢'>فَجُعِلَتْ بِمَنْزِلَةِ نُوْنِ الِاثْنَيْنِ</مقطع>
  <مقطع هوية='٧٢٦١٣'>حَيْثُ كَاْنَتْ كَذٰلِكَ وَهِيَ فِيْمَا سِوَى ذٰلِكَ مَفْتُوْحَةٌ</مقطع>
  <مقطع هوية='٦٥١٨١'>لِأَنَّهُمَا حَرْفَاْنِ الْأَوَّلُ مِنْهُمَا سَاْكِنٌ</مقطع>
  <مقطع هوية='٦٣١٤٧'>فَفُتِحَتْ كَمَا فُتِحَتْ نُوْنُ <حرف>أَيْنَ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٧٦٣٨١'>وَإِذَا أَرَدْتَ الْخَفِيْفَةَ فِي فِعْلِ جَمِيْعِ النِّسَاْءِ</مقطع>
  <مقطع هوية='٠٠٢٩٣'>قُلْتَ فِي الْوَقْفِ وَالْوَصْلِ <قول هوية='٥٥٩١٣'>اضْرِبْنَ زَيْدًا</قول>
  وَ<قول هوية='٧٩٣٦٤'>لَيَضْرِبْنَ زَيْدًا</قول></مقطع>
  <مقطع هوية='٢٤٩٢٤'>يَكُوْنُ بِمَنْزِلَتِهِ إِذَا لَمْ تُرِدْ الْخَفِيْفَةَ</مقطع>
  <مقطع هوية='٦٤١٥٢'>وَتَحْذِفُ الْأَلِفَ الَّتِي فِي قَوْلِكَ <قول هوية='٥٧٢٥٧'>اضْرِبْنَانِّ</قول></مقطع>
  <مقطع هوية='١٢١٥٦'>لِأَنَّهَا لَيْسَتْ بِاسْمٍ كَأَلِفِ <حرف>اضْرِبَا</حرف></مقطع>
  <مقطع هوية='٣٣٩٧٩'>وَإِنَّمَا جِئْتَ بِهَا كَرَاْهِيَةَ النُّوْنَاْتِ</مقطع>
  <مقطع هوية='٠١٢٨٠'>فَلَمَّا أَمِنْتَ النُّوْنَ لَمْ تَحْتَجْ إِلَيْهَا فَتَرَكْتَهَا</مقطع>
  <مقطع هوية='٥٣٤٩٢'>كَمَا أَثْبَتَّ نُوْنَ الِاثْنَيْنِ فِي الرَّفْعِ إِذَا أَمِنْتَ النُّوْنَ</مقطع>
  <مقطع هوية='٥٨٩٩٩'>وَذٰلِكَ لِأَنَّهَا لَمْ تَكُنْ لَتَثْبُتُ مَعَ نُوْنِ الْجَمِيْعِ كَرَاْهِيَةَ الْتِقَاْئِهِمَا</مقطع>
  <مقطع هوية='١٢٧٣٠'>وَلَا بَعْدَ الْأَلِفِ</مقطع>
  <مقطع هوية='٨٦٧١٨'>كَمَا لَمْ تَثْبُتْ فِي الِاثْنَيْنِ</مقطع>
  <مقطع هوية='٦٣٣٦٩'>فَلَمَّا اسْتَغْنَوْا عَنْهَا تَرَكُوْهَا</مقطع>

  <رأس/>
  <مقطع هوية='٠٦٣٩٧'>وَأَمَّا <سند>يُوْنُسُ</سند> وَنَاْسٌ مِنْ النَّحْوِيِّيْنَ</مقطع>
  <مقطع هوية='٨٨٦١٥'>فَيَقُوْلُوْنَ <قول هوية='٢٤٣١٧'>اضْرِبَانْ زَيْدًا</قول>
  وَ<قول هوية='٠٤٥٩٣'>اضْرِبْنَانْ زَيْدًا</قول></مقطع>
  <مقطع هوية='٧٤٤٤٩'>فَهٰذَا لَمْ تَقُلْهُ الْعَرَبُ وَلَيْسَ لَهُ نَظِيْرٌ فِي كَلَاْمِهَا</مقطع>
  <مقطع هوية='٥٧٣٥٤'>لَا يَقَعُ بَعْدَ الْأَلِفِ سَاْكِنٌ إِلَّا أَنْ يُدْغَمَ</مقطع>

  <رأس/>
  <مقطع هوية='٦٧٨٨٦'>وَيَقُوْلُوْنَ فِي الْوَقْفِ <حرف>اضْرِبَا</حرف>
  وَ<حرف>اضْرِبْنَا</حرف></مقطع>
  <مقطع هوية='٤٧٠٨٠'>فَيَمُدُّوْنَ وَهُوَ قِيَاْسُ قَوْلِهِمْ</مقطع>
  <مقطع هوية='٧٢٤٥٨'>لأَنَّهَا تَصِيْرُ أَلِفًا</مقطع>
  <مقطع هوية='٢٤٩٠٥'>فَإِذَا اجْتَمَعَتْ أَلِفَاْنِ مُدَّ الْحَرْفُ</مقطع>
  <مقطع هوية='٦٨٢٦٢'>وَإِذَا وَقَعَ بَعْدَهَا أَلِفٌ وَلَاْمٌ أَوْ أَلِفٌ مَوْصُوْلَةٌ</مقطع>
  <مقطع هوية='١٦٨٣٢'>جَعَلُوْهَا هَمْزَةً مُخَفَّفَةً وَفَتَحُوْهَا</مقطع>
  <مقطع هوية='٦٣٥٩٣'>وَإِنَّمَا الْقِيَاْسُ فِي قَوْلِهِمْ أَنْ يَقُوْلُوْا <قول هوية='٩٦٢٣٨'>اضْرِبَ الرَّجُلَ</قول></مقطع>
  <مقطع هوية='٥١٨٩٧'>كَمَا تَقُوْلُ بِغَيْرِ الْخَفِيْفَةِ</مقطع>
  <مقطع هوية='٥٢١٦٩'>إِذَا كَاْنَ بَعْدَهَا أَلِفُ وَصْلٍ أَوْ أَلِفٌ وَلَاْمٌ ذَهَبَتْ</مقطع>
  <مقطع هوية='٦٠٨٣٤'>فَيَنْبَغِي لَهُمْ أَنْ يُذْهِبُوْهَا لِذَا</مقطع>
  <مقطع هوية='٩٣٥٨٩'>ثُمَّ تَذْهَبُ الْأَلِفُ</مقطع>
  <مقطع هوية='٥٩٢٠٢'>كَمَا تَذْهَبُ الْأَلِفُ وَأَنْتَ تُرِيْدُ النُّوْنَ فِي الْوَاْحِدِ
  إِذَا وَقَفْتَ</مقطع>
  <مقطع هوية='١٢٤٨٦'>فَقُلْتَ <حرف>اضْرِبَا</حرف></مقطع>
  <مقطع هوية='٣٦٦٣٤'>ثُمَّ قُلْتَ <حرف>اضْرِبَ الرَّجُلَ</حرف></مقطع>
  <مقطع هوية='١٩٠٤٦'>لِأَنَّهُمْ إِذَا قَاْلُوْا <قول هوية='٧٧٤٨٨'>اضْرِبَانْ زَيْدًا</قول>
  فَقَدْ جَعَلُوْهَا بِمَنْزِلَتِهَا فِي <قول هوية='٥٩٦٨٩'>اضْرِبَنْ زَيْدًا</قول></مقطع>
  <مقطع هوية='١٠٧٠٠'>فَيَنْبَغِي لَهُمْ أَنْ يُجْرُوْا عَلَيْهَا هُنَاْكَ
  مَا يُجْرَى عَلَيْهَا فِي الْوَاْحِدِ</مقطع>

