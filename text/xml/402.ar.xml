<باب xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
     بلاق="٢-١٤٩"
     درنبورج="٢-١٥٢"
     البكاء="٥-٢١٧"
     هارون="٣-٥٠٨"
     يعقوب="٣-٥٦٨"
     رقم="٤٠٢">

  <عنوان>
    <مقطع هوية='٩٥٦٤٩'>هٰذَا بَاْبُ النُّوْنِ الثَّقِيْلَةِ وَالْخَفِيْفَةِ</مقطع>
  </عنوان>

  <مقطع هوية='٠٣٦١١'>اعْلَمْ أَنَّ كُلَّ شَيْءٍ دَخَلَتْهُ الْخَفِيْفَةُ فَقَدْ تَدْخُلُهُ الثَّقِيْلَةُ</مقطع>
  <مقطع هوية='٢٢٣٤٦'>كَمَا أَنَّ كُلَّ شَيْءٍ تَدْخُلُهُ الثَّقِيْلَةُ تَدْخُلُهُ الْخَفِيْفُةُ</مقطع>
  <مقطع هوية='٤٣٠٩٣'>وَزَعَمَ <سند>الْخَلِيْلُ</سند> أَنَّهُمَا تَوْكِيْدٌ</مقطع>
  <مقطع هوية='١٧٠٢٥'>كَـ<حرف>مَا</حرف> الَّتِي تَكُوْنُ فَصْلًا</مقطع>
  <مقطع هوية='٧٣٥٧٨'>فَإِذَا جِئْتَ بِالْخَفِيْفَةِ فَأَنْتَ مُؤَكِّدٌ</مقطع>
  <مقطع هوية='٣٨٣٧٧'>وَإِذَا جِئْتَ بِالثَّقِيْلَةِ فَأَنْتَ أَشَدُّ تَوْكِيْدًا</مقطع>

  <رأس/>
  <مقطع هوية='٧٨٧٢٣'>وَلَهَا مَوَاْضِعُ سَأُبَيِّنُهَا إِنْ شَاْءَ اللهُ</مقطع>
  <مقطع هوية='٨٧٤٨٤'>وَمَوَاْضِعُهَا فِي الْفِعْلِ</مقطع>

  <رأس/>
  <مقطع هوية='٠٦٢٨١'>فَمِنْ مَوَاْضِعِهَا الْفِعْلُ الَّذِي لِلْأَمْرِ وَالنَّهْيِ</مقطع>
  <مقطع هوية='٣٥٨٣٩'>وَذٰلِكَ قَوْلُكَ <قول هوية='٨٨٠٩٨'>لَا تَفْعَلَنَّ ذَاْكَ</قول></مقطع>
  <مقطع هوية='٢٩٠٥٦'>وَ<قول هوية='٠٧٩٦٢'>اضْرِبَنَّ زَيْدًا</قول></مقطع>
  <مقطع هوية='٥٩٩٥٤'>فَهٰذِهِ الثَّقِيْلَةُ</مقطع>
  <مقطع هوية='٥٤٨٠٧'>وَإِذَا خَفَّفْتَ قُلْتَ <قول هوية='٨١٠٧٥'>افْعَلَنْ ذَاْكَ</قول></مقطع>
  <مقطع هوية='٥٨٨٥٦'>وَ<قول هوية='٢٩١٢٨'>لَا تَضْرِبَنْ زَيْدًا</قول></مقطع>

  <رأس/>
  <مقطع هوية='٠٥٩٧٤'>ومِنْ مَوَاْضِعِهَا الْفِعْلُ الَّذِي لَمْ يَجِبْ
  الَّذِي دَخَلَتْهُ لَاْمُ الْقَسَمِ</مقطع>
  <مقطع هوية='٥٤٣٥٢'>فَذٰلِكَ لَا تُفَاْرِقُهُ الْخَفِيْفَةُ أَوْ الثَّقِيْلَةُ</مقطع>
  <مقطع هوية='٧٦٤٩٣'>لَزِمَهُ ذٰلِكَ كَمَا لَزِمَتْهُ اللَّاْمُ فِي الْقَسَمِ</مقطع>
  <مقطع هوية='٦٢٥٤٢'>وَقَدْ بَيَّنَّا ذٰلِكَ فِي بَاْبِهِ</مقطع>

  <رأس/>
  <مقطع هوية='١٢٩٧٠'>فَأَمَّا الْأَمْرُ وَالنَّهْيُ</مقطع>
  <مقطع هوية='٠٢٤٦٨'>فَإِنْ شِئْتَ أَدْخَلْتَ فِيْهِ النُّوْنَ</مقطع>
  <مقطع هوية='٤١٥٨٥'>وَإِنْ شِئْتَ لَمْ تُدْخِلْ</مقطع>
  <مقطع هوية='٨٨٤٢٤'>لِأَنَّهُ لَيْسَ فِيْهِمَا مَا فِي ذَا</مقطع>
  <مقطع هوية='٢٨٩٨٣'>وَذٰلِكَ قَوْلُكَ <قول هوية='٨٨٢٦٤'>لَتَفْعَلَنَّ ذَاْكَ</قول>
  وَ<قول هوية='٥٠٠٤١'>لَتَفْعَلَاْنِّ ذَاْكَ</قول> وَ<قول هوية='٥٦٩٥٤'>لَتَفْعَلُنَّ ذَاْكَ</قول></مقطع>
  <مقطع هوية='٣٥٧٠١'>فَهٰذِهِ الثَّقِيْلَةُ</مقطع>
  <مقطع هوية='٠٩٦٤٤'>وَإِنْ خَفَّفْتَ قُلْتَ <قول هوية='٦٦٢٠٢'>لَتَفْعَلَنْ ذَاْكَ</قول>
  وَ<قول هوية='٤٠١٦٦'>لَتَفْعَلُنْ ذَاْكَ</قول></مقطع>

  <مقطع هوية='٨٦٠١٦'>فَمِمَّا جَاْءَ فِيْهِ النُّوْنُ فِي كِتَاْبِ اللهِ عَزَّ وَجَلَّ</مقطع>
  <مقطع هوية='٩٩٤٩١'><آية هوية='٦٨٢١٠' سورة="١٠" آية="٨٩"> وَلَا تَتَّبِعَآنِّ سَبِيْلَ ٱلَّذِيْنَ لَا يَعْلَمُوْنَ</آية></مقطع>

  <مقطع هوية='٥٤٨٠٨'>وَ<آية هوية='٦٣٦٠٤' سورة="١٨" آية="٢٣">وَلَا تَقُوْلَنَّ لِشَايْءٍ
  إِنِّي فَاْعِلٌ ذٰلِكَ غَدًا <نهاية آية="٣٢"/></آية></مقطع>

  <مقطع هوية='٧٤٣٦٦'>وَقَوْلُهُ تَعَاْلَى</مقطع>
  <مقطع هوية='٢٣٤٠٧'><آية هوية='٧١٣٠١' سورة="٤" آية="١١٩">وَلَأَمُرَنَّهُمْ فَلَيُبَتِّكُنَّ
  ءَاذَانَ ٱلْأَنْعَاْمِ وَلَأَمُرَنَّهُمْ فَلَيُغَيِّرُنَّ خَلْقَ ٱللَّهِ</آية></مقطع>

  <مقطع هوية='٣٧٢٢٨'>وَ<آية هوية='٩٣٠٥٦' سورة="١٢" آية="٣٢">لَيُسْجَنَنَّ وَلَيَكُوْنًا مِّنَ ٱلصَّاْغِرِيْنَ</آية></مقطع>
  <مقطع هوية='٣٧٦٠٦'>وَ<حرف>لَيَكُوْنَنْ</حرف> خَفِيْفَةٌ</مقطع>

  <مقطع هوية='٧٢٨١٧'>وَأَمَّا الْخَفِيْفَةُ فَقَوْلُهُ تَعَاْلَى</مقطع>
  <مقطع هوية='٧٣٩٢٢'><آية هوية='٠١٨٤٤' سورة="٩٦" آية="١٥">لَنَسْفَعَۢا بِٱلنَّاْصِيَةِ </آية></مقطع>

  <مقطع هوية='٣٣٨٥٨'>وَقَاْلَ <شاعر>الْأَعْشَى</شاعر></مقطع>
  <شاهدة هوية='١٨٦٢٦' شاعر="الْأَعْشَى">
    <بيت>
      <مصراع>فَإِيَّاْكَ وَالْمَيْتَاْتِ لَا <ثبات>تَقْرَبَنَّهَا</ثبات></مصراع>
      <مصراع>وَلَا تَعْبُدِ الشَّيْطَاْنَ وَاَللهَ <ثبات>فَاعْبُدَا</ثبات></مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٨٤٠٤٤'>فَالْأُوْلَى ثَقِيْلَةٌ وَالْأُخْرَى خَفِيْفَةٌ</مقطع>

  <مقطع هوية='١١٠٠٣'>وَقَاْلَ <شاعر>زُهَيْرٌ</شاعر></مقطع>
  <شاهدة هوية='١٧٧٧٧' شاعر="زُهَيْرُ">
    <بيت>
      <مصراع><ثبات>تَعَلَّمَنْ</ثبات> هَا لَعَمْرُ اللهِ ذَا قَسَمًا</مصراع>
      <مصراع>فَاقْصِدْ بِذَرْعِكَ وَانَظُرْ أَيْنَ تَسْلِكُ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٨٨٦٥٩'>فَهٰذِهِ الْخَفِيْفَةُ</مقطع>

  <مقطع هوية='١٠٣٦٢'>وَقَاْلَ <شاعر>الْأَعْشَى</شاعر></مقطع>
  <شاهدة هوية='٤٩٩٤٦' شاعر="الْأَعْشَى">
    <بيت>
      <مصراع>أَبَا ثَاْبِتٍ <ثبات>لَا تَعْلَقَنْكَ</ثبات> رِمَاْحُنَا</مصراع>
      <مصراع>أَبَا ثَاْبِتٍ فَاذْهَبْ وَعِرْضُكَ سَاْلِمُ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٧٢٥٥١'>فَهٰذِهِ الْخَفِيْفَةُ</مقطع>

  <مقطع هوية='١٧٣٩١'>وَقَاْلَ <شاعر>النَّاْبِغَةُ الذُّبْيَاْنِي</شاعر></مقطع>
  <شاهدة هوية='٤٨٧١٥' شاعر="النَّاْبِغَةُ الذُّبْيَاْنِي">
    <بيت>
      <مصراع><ثبات>لَا أَعْرِفَنْ</ثبات> رَبْرَبًا حُوْرًا مَدَاْمِعُهَا</مصراع>
      <مصراع>كَأَنَّ أَبْكَاْرَهَا نِعَاْجُ دُوَّاْرِ</مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='١٤١١٧'>وَقَاْلَ <شاعر>النَّاْبِغَةُ</شاعر> أَيُضَا</مقطع>
  <شاهدة هوية='٢٩٤٥٠' شاعر="النَّاْبِغَةُ الذُّبْيَاْنِي">
    <بيت>
      <مصراع><ثبات>فَلْتَأْتِيَنْكَ</ثبات> قَصَاْئِدٌ <ثبات>وَلْيَدْفَعَنْ</ثبات></مصراع>
      <مصراع>جَيْشٌ إِلَيْكَ قَوَاْدِمَ الْأَكْوَاْرِ</مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='٩٥٥١٥'>وَالدُّعَاْءِ بِمَنْزِلَةِ الْأَمْرِ وَالنَّهْيِ</مقطع>

  <مقطع هوية='٦٧٥٩٠'>قَاْلَ <!-- ابْنُ رَوَاْحَةَ --> <شاعر>كَعْبُ ابْنُ مَاْلِكٍ</شاعر></مقطع>
  <شاهدة هوية='٩٢٥٧٢' شاعر="كَعْبُ ابْنُ مَاْلِكٍ">
    <بيت>
      <مصراع><ثبات>فَأَنْزِلَنْ</ثبات> سَكِيْنَةً عَلَيْنَا</مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='٤٢٠٠٥'>وَقَاْلَ <شاعر>لَبِيْدٌ</شاعر></مقطع>
  <شاهدة هوية='٠٥٤٤٧' شاعر="لَبِيْدٌ">
    <بيت>
      <مصراع><ثبات>فَلَتَصْلُقَنَّ</ثبات> بَنِي ضَبِيْنَةَ صَلْقَةً</مصراع>
      <مصراع><ثبات>تُلْصِقَنْهُمْ</ثبات> بِخَوَاْلِفِ الْأَطْنَاْبِ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٣٣٨٢٠'>هٰذِهِ الثّقِيْلَةُ وَهُوَ أَكْثَرُ مِنْ أَنْ يُحْصَى</مقطع>

  <مقطع هوية='٨٢٥٣١'>وَقَاْلَتْ <شاعر>لَيْلَى الْأَخِيْلِيَّةُ</شاعر></مقطع>
  <شاهدة هوية='١٥٥٣٣' شاعر="لَيْلَى الْأَخِيْلِيَّةُ">
    <بيت>
      <مصراع>تُسَاْوِرُ سَوَّاْرًا إِلَى الْمَجْدِ وَالْعُلَا</مصراع>
      <مصراع>وَفِي ذِمَّتِي لَئِنْ فَعَلْتَ <ثبات>لَيَفْعَلَا</ثبات></مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='٨٩٩٠٦'>وَقَاْلَ <شاعر>النَّاْبِغَةُ الْجَعْدِيُّ</شاعر></مقطع>
  <شاهدة هوية='٨٧٧٥٢' شاعر="النَّاْبِغَةُ الْجَعْدِيُّ">
    <بيت>
      <مصراع>فَمَنْ يَكُ لَمْ يَثْأَرْ بِأَعْرَاْضِ قَوْمِهِ</مصراع>
      <مصراع>فَإِنّيِ وَرَبِّ الرَّاْقِصَاْتِ <ثبات>لَأَثْأَرَا</ثبات></مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='٦٠٩٤٣'>فَهٰذِهِ الْخَفِيْفَةُ خُفِّفَتْ</مقطع>
  <مقطع هوية='٢٦٠٤٢'>كَمَا تُثَقَّلُ إِذَا قُلْتَ <حرف>لَأَثْأَرَنَّ</حرف></مقطع>

  <رأس/>
  <مقطع هوية='٥٠٥٨٧'>وَمِنْ مَوَاْضِعِهَا الْأَفْعَاْلُ غَيْرُ الْوَاْجِبَةِ</مقطع>
  <مقطع هوية='٠٦٤٧٩'>الَّتِي تَكُوْنُ بَعْدَ حُرُوْفِ الِاسْتِفْهَاْمِ</مقطع>
  <مقطع هوية='٩٤٣٢٤'>وَذٰلِكَ لِأَنَّكَ تُرِيْدُ <حرف>أَعْلَمْنِي</حرف> إِذَا اسْتَفْهَمْتَ</مقطع>
  <مقطع هوية='٣٣٥٣٦'>وَهِيَ أَفْعَاْلٌ غَيْرُ وَاْجِبَةٍ</مقطع>
  <مقطع هوية='٩٨٢٦٨'>فَصَاْرَتْ بِمَنْزِلَةِ أَفْعَاْلِ الْأَمْرِ وَالنَّهْيِ</مقطع>
  <مقطع هوية='٨٧١١٣'>فَإِنْ شِئْتَ أَقْحَمْتَ النُّوْنَ</مقطع>
  <مقطع هوية='٦٢٨٣٠'>وَإِنْ شِئْتَ تَرَكْتَ</مقطع>
  <مقطع هوية='٦٢٣٠٤'>كَمَا فَعَلْتَ ذٰلِكَ فِي الْأَمْرِ وَالنَّهْيِ</مقطع>
  <مقطع هوية='٠٤٢٨٦'>وَذٰلِكَ قَوْلُكَ <قول هوية='٢٨٣٥٠'>هَلْ تَقُوْلَنَّ</قول>
  وَ<قول هوية='١٥٩٣٨'>أَتَقُوْلَنَّ ذَاْكَ</قول></مقطع>
  <مقطع هوية='٧١٦٠١'>وَ<قول هوية='٨٠٣٣١'>كَمْ تَمْكُثَنَّ</قول>
  وَ<قول هوية='٠٤٩٩٠'>انْظُرْ مَاْذَا تَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='٢٤٥٠١'>وَكَذٰلِكَ جَمِيْعُ حُرُوْفِ الِاسْتِفْهَاْمِ</مقطع>

  <مقطع هوية='١٧٣٢٢'>وَقَاْلَ <شاعر>الْأَعْشَى</شاعر></مقطع>
  <شاهدة هوية='٧٤٢٤٧' شاعر="الْأَعْشَى">
    <بيت>
      <مصراع>فَـ<ثبات>هَلْ يَمْنَعَنِّي</ثبات> ارْتِيَاْدِي الْبِلَاْ</مصراع>
      <مصراع>دَ مِنْ حَذَرِ الْمَوْتِ أَنْ يَأْتِيَنْ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٠١٠٩١'>وقَاْلِ</مقطع>
  <شاهدة هوية='٨٥٠٤٢'>
    <بيت>
      <مصراع>فَأَقْبَلْ عَلَى رَهْطِي وَرَهْطِكَ نَبْتَحِثْ</مصراع>
      <مصراع>سَاْعِينَا حَتَّى تَرَى <ثبات>كَيْفَ نَفْعَلَا</ثبات></مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٦٧٧٢٢'>وَقَاْلَ مقنّع</مقطع>
  <شاهدة هوية='٦٣٧٢٦'>
    <بيت>
      <مصراع><ثبات>أَ</ثبات>فَبَعْدَ كِنْدَةَ <ثبات>تَمْدَحَنَّ</ثبات> قَبِيْلَا</مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='٤٢٨٢٢'>وقَاْلِ</مقطع>
  <شاهدة هوية='٤٥١٧١'>
    <بيت>
      <مصراع><ثبات>هَلْ تَحْلِفَنْ</ثبات> يَا نُعْمَ لَا تَدِيْنُهَا</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٣٩٥٠١'>فَهٰذِهِ الْخَفِيْفَةُ</مقطع>

  <مقطع هوية='٥٠١٥٧'>وَزَعَمَ <سند>يُوْنُسُ</سند> أَنَّكَ تَقُوْلُ <قول هوية='٥٠٨٧٣'>هَلَّا تَقُوْلَنَّ</قول>
  وَ<قول هوية='٢١٤١٣'>أَلَّا تَقُوْلَنَّ</قول></مقطع>
  <مقطع هوية='٣٠٦٤٩'>وَهٰذَا أَقْرَبُ لِأَنَّكَ تَعْرِضُ</مقطع>
  <مقطع هوية='٨٠٦٣٧'>فَكَأَنَّكَ قُلْتَ <حرف>افْعَلْ</حرف></مقطع>
  <مقطع هوية='١١٥٥٩'>لِأَنَّهُ اسْتِفْهَاْمٌ فِيْهِ مَعْنَى الْعَرْضِ</مقطع>
  <مقطع هوية='٤٠٠١٥'>وَمِثْلُ ذٰلِكَ <حرف>لَوْلَا تَقُوْلَنَّ</حرف> لِأَنَّكَ تَعْرِضُ</مقطع>
  <مقطع هوية='١٤٥٥٨'>وَقَدْ بَيَّنَّا حُرُوْفَ الِاسْتِفْهَاْمِ</مقطع>
  <مقطع هوية='٢٣٥٢٩'>وَمُوَاْفَقَتَهَا الْأَمْرَ وَالنَّهْيَ</مقطع>
  <مقطع هوية='٨٩٠٥٩'>فِي بَاْبِ الْجَزَاْءِ وَغَيْرِهِ</مقطع>
  <مقطع هوية='٨٣٣٢٣'>وَهٰذَا مِمَّا وَافَقَتْهَا فِيْهِ</مقطع>
  <مقطع هوية='١٤١٣٨'>وَتُرِكَ تَفْسِيْرُهُنَّ هٰهُنَا لِلَّذِي فَسَّرْنَا فِيْمَا مَضَى</مقطع>

  <رأس/>
  <مقطع هوية='٤٦٧٣٨'>وَمِنْ مَوَاْضِعِهَا حُرُوْفُ الْجَزَاْءِ</مقطع>
  <مقطع هوية='٦٠٤٢٩'>إِذَا وَقَعَتْ بَيْنَهَا وَبَيْنَ الْفِعْلِ <حرف>مَا</حرف> لِلتَّوْكِيْدِ</مقطع>
  <مقطع هوية='٢٢٩٩٣'>وَذِلِكَ لِأَنَّهُمْ شَبَّهُوْا <حرف>مَا</حرف>
  بِاللَّاْمِ الَّتِي فِي <حرف>لَتَفْعَلَنَّ</حرف></مقطع>
  <مقطع هوية='٤٥١٣٥'>لَمَّا وَقَعَ التَّوْكِيْدُ قَبْلَ الْفِعْلِ أَلْزَمُوْا النُّوْنَ آخِرَهُ</مقطع>
  <مقطع هوية='٦٢٤٥٠'>كَمَا أَلْزَمُوْا هٰذِهِ اللَّاْمَ</مقطع>
  <مقطع هوية='٦٧٤٥٩'>وَإِنْ شِئْتَ لَمْ تُقْحِمِ النُّوْنَ</مقطع>
  <مقطع هوية='٧٦٢٤١'>كَمَا أَنَّكَ إِنْ شِئْتَ لَمْ تَجِئْ بِهَا</مقطع>
  <مقطع هوية='٤٩٨٧٥'>فَأَمَّا اللَّاْمُ فَهِيَ لَاْزِمَةٌ فِي الْيَمِيْنِ</مقطع>
  <مقطع هوية='٨٩٤٠١'>فَشَبَّهُوْا <حرف>مَا</حرف> هٰذِهِ إِذَا جَاْءَتْ تَوْكِيْدًا قَبْلَ الْفِعْلِ</مقطع>
  <مقطع هوية='٦٣٥٢٠'>بِهٰذِهِ اللَّاْمِ الَّتِي جَاْءَتْ لِإِثْبَاْتِ النُّوْنِ</مقطع>
  <مقطع هوية='٥٤١٤١'>فَمِنْ ذٰلِكَ قَوْلُكَ <قول هوية='٦٦٥٦٢'>إِمَّا تَأْتِيَنِّي آتِكَ</قول></مقطع>
  <مقطع هوية='١٨٧٥٥'>وَ<قول هوية='٣٧١٨٥'>أَيُّهُمْ مَا يَقُوْلَنَّ ذَاْكَ تِجْزِهِ</قول></مقطع>
  <مقطع هوية='٩٠١٤٣'>وَتَصْدِيْقُ ذٰلِكَ قَوْلُهُ عَزَّ وَجَلَّ</مقطع>
  <مقطع هوية='١٢٨٦٥'><آية هوية='٥٢٢٥٠' سورة="١٧" آية="٢٨">
  وَإِمَّا تُعْرِضَنَّ عَنْهُمُ ٱبْتِغَاْءَ رَحْمَةٍ مِّنْ رَّبِّكَ</آية></مقطع>
  <مقطع هوية='٥٣٧٦٤'>وَقَاْلَ عَزَّ وَجَلَّ
  <آية هوية='٦٥٧٨٥' سورة="١٩" آية="٢٦">فَإِمَّا تَرَيِنَّ مِنَ ٱلْبَشَرِ <!-- أَحَدًا --></آية></مقطع>

  <رأس/>
  <مقطع هوية='٤٨٨٠٨'>وَقَدْ تَدْخُلُ النُّوْنُ بِغَيْرِ <حرف>مَا</حرف> فِي الْجَزَاْءِ</مقطع>
  <مقطع هوية='١٣٠٧٩'>وَذٰلِكَ قَلِيْلٌ فِي الشِّعْرِ</مقطع>
  <مقطع هوية='٤٧٣٨٣'>شَبَّهُوْهُ بِالنَّهْيِ حِيْنَ كَاْنَ مَجْزُوْمًا غَيْرَ وَاْجِبٍ</مقطع>
  <مقطع هوية='٣١٨٠٤'>وَقَاْلَ الشَّاْعِرُ</مقطع>
  <شاهدة هوية='٠٩٤٧٥'>
    <بيت>
      <مصراع>نَبَتُّمْ نَبَاْتَ الْخَيْزُرَاْنِيِّ فِي الثَّرَى</مصراع>
      <مصراع>حَدِيْثًا مَتَى مَا يَأْتِكَ الْخَيْرُ <ثبات>يَنْفَعَا</ثبات></مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='٤٢٥٠٢'>وَقَاْلَ <شاعر>ابْنُ الْخَرِعِ</شاعر></مقطع>
  <شاهدة هوية='٢٩٨٩٦' شاعر="ابْنُ الْخَرِعِ">
    <بيت>
      <مصراع>فَمَهْمَا تَشَأْ مِنْهُ فَزَاْرَةُ تُعْطِكُمْ</مصراع>
      <مصراع>وَمَهْمَا تَشَأْ مِنْهُ فَزَاْرَةُ <ثبات>تَمْنَعَا</ثبات></مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='٧٠١٩٩'>وَقَاْلَ</مقطع>
  <شاهدة هوية='٢٠٨٤٨'>
    <بيت>
      <مصراع>مَنْ <ثبات>يُثْقَفَنْ</ثبات> مِنْهُمْ فَلَيْسَ بِآئِبٍ</مصراع>
      <مصراع>أَبَدًا وَقَتْلُ بَنِي قُتَيْبَةَ شَاْفِ</مصراع>
    </بيت>
  </شاهدة>

  <مقطع هوية='٧٨٢٨٨'>وَقَاْلَ</مقطع>
  <شاهدة هوية='١٢٥٨٤'>
    <بيت>
      <مصراع>يَحْسَبُهُ الْجَاْهِلُ مَا <ثبات>لَمْ يَعْلَمَا</ثبات></مصراع>
      <مصراع>شَيْخًا عَلَى كُرْسِيِّهِ مُعَمَّمُ</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٨٨٢٤٠'>شَبَّهَهُ بِالْجَزَاْءِ حَيْثُ كَاْنَ مَجْزُوْمًا</مقطع>
  <مقطع هوية='٠٥٩٠٣'>وَكَاْنَ غَيْرَ وَاْجِبٍ</مقطع>
  <مقطع هوية='٣٩٨١٤'>وَهٰذَا لَا يَجُوْزُ إِلَّا فِي اضْطِرَاْرٍ</مقطع>
  <مقطع هوية='٩٧١١٨'>وَهِيَ فِي الْجَزَاْءِ أَقْوَى</مقطع>

  <رأس/>
  <مقطع هوية='٠٣٦٠٧'>وَقَدْ يَقُوْلُوْنَ <قول هوية='٥٤٥٥٦'>أَقْسَمْتُ لَمَّا لَمْ تَفْعَلَنَّ</قول></مقطع>
  <مقطع هوية='٧٣٧٣٩'>لِأَنَّ ذَا طَلَبٌ فَصَاْرَ كَقَوْلِكَ <حرف>لَا تَفْعَلَنَّ</حرف></مقطع>
  <مقطع هوية='١٤١١٩'>كَمَا أَنَّ قَوْلَكَ <قول هوية='٠٦٥٠٠'>أَتُخْبِرَنِّي</قول>
  فِيْهِ مَعْنَى <حرف>افْعَلْ</حرف></مقطع>
  <مقطع هوية='٢٣٧٠٩'>وَهُوَ كَالْأَمْرِ فِي الِاسْتِغْنَاْءِ وَالْجَوَاْبِ</مقطع>

  <رأس/>
  <مقطع هوية='٠٥٢٦٩'>وَمِنْ مَوَاْضِعِهَا أَفْعَاْلُ غَيْرِ الْوَاْجِبِ</مقطع>
  <مقطع هوية='٧٤٥٦٣'>الَّتِي فِي قَوْلِكَ <قول هوية='٥٩٦٣١'>بِجَهْدٍ مَا تَبْلُغَنَّ</قول>
  وأَشْبَاْهِهِ</مقطع>
  <مقطع هوية='٥٠٦٣٨'>وَإِنَّمَا كَاْنَ ذٰلِكَ لِـ<حرف>مَكَاْنٍ مَا</حرف></مقطع>
  <مقطع هوية='٩١٣٧٣'>وَتَصْدِيْقُ ذٰلِكَ قَوْلُهُمْ فِي مَثَلِ</مقطع>
  <شاهدة هوية='٧٢١٩٨'>
    <بيت>
      <مصراع>فِي <ثبات>عَضَةٍ مَّا يَنْبُتَنَّ</ثبات> شَكِيْرُهَا</مصراع>
    </بيت>
  </شاهدة>
  <مقطع هوية='٩٦٥١٥'>وَقَاْلَ أَيْضًا فِي مَثَلٍ آخَرَ <قول هوية='٢٠٦٦٠'>بِأَلَمٍ مَّا تُخْتَنِنَّهُ</قول></مقطع>
  <مقطع هوية='٨٩٠٣٠'>وَقَاْلُوْا <قول هوية='١٨٤٠١'>بِعَيْنٍ مَّا أَرَيَنَّكَ</قول></مقطع>
  <مقطع هوية='١٦٩٨٢'>فَـ<حرف>مَا</حرف> هٰهُنَا بِمَنْزِلَتِهَا فِي الْجَزَاْءِ</مقطع>

  <رأس/>
  <مقطع هوية='٦٢٥٧٤'>وَيَجُوْزُ لِلْمُضْطَرِّ <قول هوية='٦٨٢٩٠'>أَنْتَ تَفْعَلَنَّ ذَاْكَ</قول></مقطع>
  <مقطع هوية='١٨٦٠٦'>شَبَّهُوْهُ بِالَّتِي بَعْدَ حُرُوْفِ الِاسْتِفْهَاْمِ</مقطع>
  <مقطع هوية='٧٧٨٢١'>لأَنَّهَا لَيْسَتْ مَجْزُوْمَةً</مقطع>
  <مقطع هوية='٤٥١٠٠'>وَالَّتِي فِي الْقَسَمِ مُرْتَفِعَةٌ</مقطع>
  <مقطع هوية='٨٨٣٧٧'>فَأَشْبَهَتْهَا فِي هٰذِهِ الأَشْيَاْءِ</مقطع>
  <مقطع هوية='٩٣٤٢٦'>فَجُعِلَتْ بِمَنْزِلَتِهَا حِيْنَ اضْطُرُّوْا</مقطع>

  <مقطع هوية='٥٥٤٨٩'>وَقَاْلَ الشَّاْعِرُ <شاعر>جَذِيْمَةُ الأَبْرَشِ</شاعر></مقطع>
  <شاهدة هوية='٥٥٩٨٤' شاعر="جَذِيْمَةُ الأَبْرَشِ">
    <بيت>
      <مصراع>رُبَّمَا أَوْفَيْتُ فِي عَلَمٍ</مصراع>
      <مصراع><ثبات>تَرْفَعَنْ</ثبات> ثَوْبِي شَمَاْلَاْتُ</مصراع>
    </بيت>
  </شاهدة>

  <رأس/>
  <مقطع هوية='٠٣٦٨٨'>وَزَعْمُ <سند>يُوْنُسُ</سند>
  أَنَّهُمْ يَقُوْلُوْنَ <قول هوية='٥٣١٤٠'>رُبَّمَا تَقُوْلَنَّ ذَاْكَ</قول></مقطع>
  <مقطع هوية='١١٣٤٩'>وَكَثُرَ <قول هوية='١٠٠٩٢'>مَا تَقُوْلَنَّ ذَاْكَ</قول></مقطع>
  <مقطع هوية='٨٣١٠٢'>لِأَنَّهُ فِعْلٌ غَيْرُ وَاْجِبٍ</مقطع>
  <مقطع هوية='٢٨٩٢٥'>وَلَا يَقَعُ بَعْدَ هٰذِهِ الْحُرُوْفِ إِلَّا وَ <حرف>مَا</حرف> لَهُ لَاْزِمَةٌ</مقطع>
  <مقطع هوية='٩٩٤٨٩'>فَأَشْبَهَتْ عِنْدَهُمْ لَاْمَ الْقَسَمِ</مقطع>

  <رأس/>
  <مقطع هوية='٩٣٥٦٣'>وَإِنْ شِئْتَ لَمْ تُقْحِمْ النُّوْنَ فِي هٰذَا النَّحْوِ</مقطع>
  <مقطع هوية='٥٢٩٠٥'>فَهُوَ أَكْثَرُ وَأَجْوَدُ</مقطع>
  <مقطع هوية='٥٥١٧٨'>وَلَيْسَ بِمَنْزِلَتِهِ فِي الْقَسَمِ</مقطع>
  <مقطع هوية='٤٧٧٦٨'>لِأَنَّ اللَّاْمَ إِنَّمَا أُلْزِمَتْ الْيَمِيْنَ</مقطع>
  <مقطع هوية='٣٠١٦٥'>كَمَا أُلْزِمَتِ النُّوْنُ اللَّاْمَ</مقطع>
  <مقطع هوية='٦٣٣٦٩'>وَلَيْسَتْ مَعَ الْمُقْسَمِ بِهِ بِمَنْزِلَةِ حَرْفٍ وَاْحِدٍ</مقطع>
  <مقطع هوية='٥٧٩٩٥'>وَلَوْ لَمْ تُلْزَمِ اللَّاْمُ الْتَبَسَ بِالنَّفْيِ
  إِذَا حَلَفَ أَنَّهُ لَا يَفْعَلُ</مقطع>
  <مقطع هوية='٦٩٠٩٧'>فَـ<حرف>مَا</حرف> تَجِيْءُ لِتُسَهِّلَ الْفِعْلَ بَعْدَ <حرف>رُبٍّ</حرف></مقطع>
  <مقطع هوية='٣٩٨٩٤'>وَلَا يُشْبِهُ ذَا الْقَسَمَ</مقطع>
  <مقطع هوية='٥٨٦٥٠'>وَمِثْلُ ذٰلِكَ <قول هوية='٥٦١٥٤'>حَيْثُمَا تَكُوْنَنْ آتِكَ</قول></مقطع>
  <مقطع هوية='٠٤٢٦١'>لِأَنَّهَا سَهَّلَتْ الْفِعْلَ أَنْ يَكُوْنَ مُجَاْزَاْةً</مقطع>

  <رأس/>
  <مقطع هوية='٨٠٧٠٣'>وَإِنَّمَا كَاْنَ تَرْكُ النُّوْنِ فِي هٰذَا أَجْوَدَ</مقطع>
  <مقطع هوية='٨٠٨٤٣'>لِأَنَّ <حرف>مَا</حرف> وَ<حرف>رُبَّ</حرف> بِمَنْزِلَةِ حَرْفٍ وَاْحِدٍ نَحْوُ <حرف>قَدْ</حرف> وَ<حرف>سَوْفَ</حرف></مقطع>
  <مقطع هوية='٩٩٢٢٥'>وَ<حرف>مَا</حرف> وَ<حرف>حَيْثُ</حرف> بِمَنْزِلَةِ <حرف>أَيْنَ</حرف></مقطع>
  <مقطع هوية='٢٢٢٩٥'>وَاللَّاْمُ لَيْسَتْ مَعَ الْمُقْسَمِ بِهِ بِمَنْزِلَةِ حَرْفٍ وَاْحِدٍ</مقطع>
  <مقطع هوية='٢٠٤١٣'>وَلَيْسَتْ كَـ<حرف>مَا</حرف>
  الَّتِي فِي <قول هوية='٠٦٥٦٩'>بِأَلَمِ مَا تُخْتِنَنَّهُ</قول></مقطع>
  <مقطع هوية='٩١٤٩١'>لِأَنَّهَا لَيْسَتْ مَعَ مَا قَبْلَهَا بِمَنْزِلَةِ حَرْفٍ وَاْحِدٍ</مقطع>
  <مقطع هوية='٣١٣٨١'>وَلِأَنَّ اللَّاْمَ لَا تَسْقُطُ كَمَا تَسْقُطُ <حرف>مَا</حرف>
  مِنْ هٰذَا إِنْ شِئْتَ</مقطع>

