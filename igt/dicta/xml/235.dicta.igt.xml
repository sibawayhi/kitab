<?xml version="1.0" encoding="utf-8"?>
<dicta xmlns="http://www.sibawayhi.org/schema/2024/05/igt" bab="235">
   <dictum id="٠٤٨٠٤">
      <text>
         <ar>لَا يَقْطَعِ اللهُ يَمِيْنَكَ</ar>
         <free>May God not cut of your oath</free>
      </text>
      <igt>
         <t>
            <ar>لَا</ar>
         </t>
         <t>
           <ar>يَقْطَعِ</ar>
           <xlit>yaqṭaʕ</xlit>
         </t>
         <t>
            <ar>اللهُ</ar>
         </t>
         <t>
           <ar>يَمِيْنَكَ</ar>
           <xlit>yamīn<infla/>-ka</xlit>
         </t>
      </igt>
   </dictum>
   <dictum id="١٥٩٦٠">
      <text>
         <ar>لَيَجْزِكَ اللهُ خَيْرًا</ar>
         <free>May God reward you <ed>with</ed> good</free>
      </text>
      <igt>
         <t>
           <ar>لَيَجْزِكَ</ar>
           <xlit>li-yajz<infli/>-ka</xlit>
         </t>
         <t>
            <ar>اللهُ</ar>
         </t>
         <t>
            <ar>خَيْرًا</ar>
         </t>
      </igt>
   </dictum>
</dicta>
