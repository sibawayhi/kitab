<?xml version="1.0" encoding="utf-8"?>
<dicta xmlns="http://www.sibawayhi.org/schema/2024/05/igt" bab="237">
   <dictum id="٠٧٩٤١">
      <text>
         <ar>إِذَنْ أَجِيْئَكَ</ar>
         <free>then I (should) come <ed>to</ed> you</free>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>أَجِيْئَكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٤٦٩٦٠">
      <text>
         <ar>إِذَنْ آتِيَكَ</ar>
         <free>then I (should) come <ed>to</ed> you</free>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>آتِيَكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٠٧٨٠٦">
      <text>
         <ar>إِذَنْ وَاللهِ أَجِيْئَكَ</ar>
         <free>Then, by God, I (should) come to you</free>
         <alt>In that case, by God, I (should) come to you</alt>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>وَاللهِ</ar>
         </t>
         <t>
            <ar>أَجِيْئَكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٥٣٤٢٨">
      <text>
         <ar>أُرَى وَاللهِ زَيْدًا فَاْعِلًا</ar>
         <free>I am made to see, by God, that Zayd is doing</free>
         <alt>It looks to me, by God, that Zayd is doing</alt>
      </text>
      <igt>
         <t>
            <ar>أُرَى</ar>
         </t>
         <t>
            <ar>وَاللهِ</ar>
         </t>
         <t>
            <ar>زَيْدًا</ar>
         </t>
         <t>
            <ar>فَاْعِلًا</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٤٣٦٢٧">
      <text>
         <ar>زَيْدًا حَسِبْتُ أَخَاْكَ</ar>
         <free>Zayd[acc] I reckoned your brother[acc]</free>
      </text>
      <igt>
         <t>
            <ar>زَيْدًا</ar>
         </t>
         <t>
            <ar>حَسِبْتُ</ar>
         </t>
         <t>
            <ar>أَخَاْكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٧٢٣١٥">
      <text>
         <ar>زَيْدٌ حَسِبْتُ أَخُوْكُ</ar>
         <free>Zayd[nom], I reckoned, is your brother[nom]</free>
      </text>
      <igt>
         <t>
            <ar>زَيْدٌ</ar>
         </t>
         <t>
            <ar>حَسِبْتُ</ar>
         </t>
         <t>
            <ar>أَخُوْكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٣٧٧١٩">
      <text>
         <ar>فَإِذَنْ آتِيَكَ وَإِذَنْ أُكْرِمَكَ</ar>
         <free>so then I (should) come to you
         and then I (should) honor you</free>
         <alt>then in that case I (should) come to you
         and in that case I (should) honor you</alt>
      </text>
      <igt>
         <t>
            <ar>فَإِذَنْ</ar>
         </t>
         <t>
            <ar>آتِيَكَ</ar>
         </t>
         <t>
            <ar>وَإِذَنْ</ar>
         </t>
         <t>
            <ar>أُكْرِمَكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٣٦٣٣٨">
      <text>
         <ar>فَإِذَنْ لَا أَجِيْئُكَ</ar>
         <free>So then I do/will not come to you</free>
         <alt>So then I am not coming to you</alt>
         <alt>Then in that case I do/will not come to you</alt>
      </text>
      <igt>
         <t>
            <ar>فَإِذَنْ</ar>
         </t>
         <t>
            <ar>لَا</ar>
         </t>
         <t>
            <ar>أَجِيْئُكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٧٤٨٦٠">
      <text>
         <ar>كَاْنَ أُرَى زَيْدٌ ذَاْهِبًا</ar>
         <free>It looked to me <ed>that</ed> Zayd was going</free>
         <alt>It was the case <ed>that</ed> it looked to me
         <ed>that</ed> Zayd was going</alt>
      </text>
      <igt>
         <t>
            <ar>كَاْنَ</ar>
         </t>
         <t>
            <ar>أُرَى</ar>
         </t>
         <t>
            <ar>زَيْدٌ</ar>
         </t>
         <t>
            <ar>ذَاْهِبًا</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="١٤٦٠٥">
      <text>
         <ar>إِنِّي أُرَى ذَاْهِبٌ</ar>
         <free>I indeed, it looks to me, am going</free>
         <alt>I indeed, apparently, am going</alt>
         <alt>It looks to me <ed>like</ed> I indeed am going</alt>
      </text>
      <igt>
         <t>
            <ar>إِنِّي</ar>
         </t>
         <t>
            <ar>أُرَى</ar>
         </t>
         <t>
            <ar>ذَاْهِبٌ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٩٣٩٥٦">
      <text>
         <ar>أَنَا إِذَنْ آتِيْكَ</ar>
         <free>I, in that case, will come <ed>to</ed> you</free>
      </text>
      <igt>
         <t>
            <ar>أَنَا</ar>
         </t>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>آتِيْكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٢٣٥٨٨">
      <text>
         <ar>إِنْ تَأْتِنِي إِذَنْ آتِكَ</ar>
         <free>If you should come <ed>to</ed> me,
         then I should come <ed>to</ed> you</free>
      </text>
      <igt>
         <t>
            <ar>إِنْ</ar>
         </t>
         <t>
            <ar>تَأْتِنِي</ar>
         </t>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>آتِكَ</ar>
         </t>
      </igt>
      <sidecomment>
        In this example <ar>إِذَنْ</ar> is
        inert; it does not change the inflection of
        the original <ar>إِنْ تَأْتِنِي آتِكَ</ar>
      </sidecomment>
   </dictum>

   <dictum id="٣٦٠٩٦">
      <text>
         <ar>وَاللهِ إِذَنْ لَا أَفْعَلُ</ar>
         <free>By God, in that case I will not do</free>
      </text>
      <igt>
         <t>
            <ar>وَاللهِ</ar>
         </t>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>لَا</ar>
         </t>
         <t>
            <ar>أَفْعَلُ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٤٦٩٤٠">
      <text>
         <ar>إِذَنْ وَاللهِ لَا أَفْعَلَ</ar>
         <free>In that case, by God, I should not do</free>
         <alt>In that case, by God, I would not do</alt>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>وَاللهِ</ar>
         </t>
         <t>
            <ar>لَا</ar>
         </t>
         <t>
            <ar>أَفْعَلَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٠٠٨٩٦">
      <text>
         <ar>وَاللهِ إِذَنْ أَفْعَلَ</ar>
         <free>By God, in that case I should do</free>
         <alt>By God, in that case I would do</alt>
      </text>
      <igt>
         <t>
            <ar>وَاللهِ</ar>
         </t>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>أَفْعَلَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٩٨٣٣٩">
      <text>
         <ar>وَاللهِ أَذْهَبَ إِذَنْ</ar>
         <free>By God, I should go in that case</free>
         <alt>By God, I would go in that case</alt>
      </text>
      <igt>
         <t>
            <ar>وَاللهِ</ar>
         </t>
         <t>
            <ar>أَذْهَبَ</ar>
         </t>
         <t>
            <ar>إِذَنْ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٣١٠٦٣">
      <text>
         <ar>إِنْ تَأْتِنِي آتِكَ وَإِذَنْ أُكْرِمْكَ</ar>
         <free>If you should come <ed>to</ed> me,
         I should come <ed>to</ed> you,
         and in that case I should honor you</free>
      </text>
      <igt>
         <t>
            <ar>إِنْ</ar>
         </t>
         <t>
            <ar>تَأْتِنِي</ar>
         </t>
         <t>
            <ar>آتِكَ</ar>
         </t>
         <t>
            <ar>وَإِذَنْ</ar>
         </t>
         <t>
            <ar>أُكْرِمْكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٩٢٨٠٨">
      <text>
         <ar>إِذَنْ عَبْدُ اللهِ يَقُوْلُ ذَاْكَ</ar>
         <free>In that case Abdullah says that</free>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>عَبْدُ</ar>
         </t>
         <t>
            <ar>اللهِ</ar>
         </t>
         <t>
            <ar>يَقُوْلُ</ar>
         </t>
         <t>
            <ar>ذَاْكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٣٣٤٦٦">
      <text>
         <ar>إِنَّمَا عَبْدُ اللهِ يَقُوْلُ ذَاْكَ</ar>
         <free>In fact Abdullah says that</free>
         <alt>Indeed Abdullah says that</alt>
      </text>
      <igt>
         <t>
            <ar>إِنَّمَا</ar>
         </t>
         <t>
            <ar>عَبْدُ</ar>
         </t>
         <t>
            <ar>اللهِ</ar>
         </t>
         <t>
            <ar>يَقُوْلُ</ar>
         </t>
         <t>
            <ar>ذَاْكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٤٧٠٥٥">
      <text>
         <ar>إِذَنْ أَفْعَلُ ذَاْكَ</ar>
         <free>In that case I will do that</free>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>أَفْعَلُ</ar>
         </t>
         <t>
            <ar>ذَاْكَ</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٠١١٧١">
      <text>
         <ar>إِذَنْ أَظُنُّهُ فَاْعِلًا</ar>
         <free>In that case I think him doing</free>
         <alt>In that case I think he <ed>is</ed> doing</alt>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
           <en>I think him</en>
           <ar>أَظُنُّهُ</ar>
           <xlit>Ɂaẓunn<influ/>-hu</xlit>
         </t>
         <t>
            <ar>فَاْعِلًا</ar>
         </t>
      </igt>
   </dictum>
   <dictum id="٥٠٥٣٦">
      <text>
         <ar>إِذَنْ إخَاْلُكَ كَاْذِبًا</ar>
         <free>In that case I imagine you <ed>are</ed> lying</free>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
           <en>I imagine you</en>
           <ar>إخَاْلُكَ</ar>
           <xlit>Ɂixālu-ka</xlit>
         </t>
         <t>
           <en>lying</en>
            <ar>كَاْذِبًا</ar>
            <xlit>kāðib<inflan/></xlit>
         </t>
      </igt>
   </dictum>
   <dictum id="٠٨٩٠٣">
      <text>
         <ar>إِذَنْ أَظُنَّكَ</ar>
         <free>In that case I should think you</free>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
           <en>I should think you</en>
           <ar>أَظُنَّكَ</ar>
           <xlit>Ɂaẓunn<infla/>-ka</xlit>
         </t>
      </igt>
   </dictum>
   <dictum id="٨٧٣١٣">
      <text>
         <ar>إِذَنْ يَضْرِبَكَ</ar>
         <free>In that case he should strike you</free>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
           <en>he should strike you</en>
           <ar>يَضْرِبَكَ</ar>
           <xlit>yaḍrib<infla/>-ka</xlit>
         </t>
      </igt>
   </dictum>
   <dictum id="٩٨٩٥٣">
      <text>
         <ar>عَبْدُ اللهِ إِذَنْ يَأْتِيْكَ</ar>
         <free>Abdullah in that case comes to you</free>
      </text>
      <igt>
         <t>
            <ar>عَبْدُ</ar>
         </t>
         <t>
            <ar>اللهِ</ar>
         </t>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>يَأْتِيْكَ</ar>
            <xlit>yaɁtī-ka</xlit>
         </t>
      </igt>
   </dictum>
   <dictum id="٩٨٨٢٥">
      <text>
         <ar>إِذَنْ يَأْتِيَكَ عَبْدُ اللهِ</ar>
         <free>In that case Abdullah should come to you</free>
      </text>
      <igt>
         <t>
            <ar>إِذَنْ</ar>
         </t>
         <t>
            <ar>يَأْتِيَكَ</ar>
         </t>
         <t>
            <ar>عَبْدُ</ar>
         </t>
         <t>
            <ar>اللهِ</ar>
         </t>
      </igt>
   </dictum>
</dicta>
