         <t>
            <ar>هُمَا</ar>
         </t>
         <t>
            <ar>الْحَسَنَاْنِ</ar>
         </t>
         <t>
            <ar>الْوُجُوْهَ</ar>
         </t>
      </igt>
   </dictum>

